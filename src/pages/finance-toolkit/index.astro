---
import PageShell from "../../components/PageShell.astro";
import { getCollection } from "astro:content";

const FINANCE_CATEGORY = "Financial Models";

const all = await getCollection("toolkit");

const items = all.filter(
  (item) => (item.data.primaryCategory || "").trim() === FINANCE_CATEGORY
);

// Build grouped structure
const groupsMap = new Map();
for (const item of items) {
  const c = (item.data.primaryCategory || "Uncategorized").trim();
  if (!groupsMap.has(c)) groupsMap.set(c, []);
  groupsMap.get(c).push(item);
}

const categories = Array.from(groupsMap.keys()).sort((a, b) => a.localeCompare(b));
for (const c of categories) {
  groupsMap.get(c).sort((a, b) => a.data.title.localeCompare(b.data.title));
}
const groups = categories.map((c) => ({ category: c, items: groupsMap.get(c) }));

function catId(name) {
  return (
    "cat-" +
    String(name || "")
      .trim()
      .toLowerCase()
      .replace(/['"]/g, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
  );
}

const featured = items.filter((i) => i.data.featured === true).slice(0, 8);

const financeBreadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Finance Toolkit", path: "/finance-toolkit/" },
];
---

<PageShell
  title="Finance Toolkit"
  description="Financial models for founders and finance professionals."
  keywords="finance toolkit, financial models, founder finance tools, business models, finance frameworks, Altareen"
  breadcrumbs={financeBreadcrumbs}
>
  <div class="toolkit">
 

    {featured.length > 0 && (
      <section class="featuredBlock" id="__featured" data-group="__featured" data-expanded="true">
        <div class="groupHead">
          <div class="groupTitleWrap">
            <h2 class="groupTitle">
              Featured <span class="count">({featured.length})</span>
            </h2>
            <div class="groupRule" aria-hidden="true"></div>
          </div>
        </div>

        <div class="groupReveal" data-expand-wrap>
          <div class="grid" data-expand-grid>
            {featured.map((item) => (
<a
  class="card"
  href={item.data.link || `/toolkit/${item.slug}/`}
  target={item.data.link ? "_blank" : undefined}
  rel={item.data.link ? "noopener noreferrer" : undefined}
  data-title={item.data.title}
  data-category={item.data.primaryCategory || "Uncategorized"}
  data-when={item.data.whenToUse || ""}
  data-featured="true"
  onclick={`trackEvent('framework_click', {
    framework: '${item.slug}',
    framework_name: '${(item.data.title || "").replace(/'/g, "\\'")}',
    category: '${(item.data.primaryCategory || "Uncategorized").replace(/'/g, "\\'")}',
    featured: true,
    source: 'finance_toolkit',
    destination: '${item.data.link ? "external" : "internal"}',
    position: ${featured.findIndex((x) => x.slug === item.slug) + 1}
  })`}
>
                {item.data.link && (
                  <span class="externalBadge" aria-hidden="true" title="Opens external link">↗</span>
                )}

                {item.data.cover ? (
                  <div class="thumb" aria-hidden="true">
                    <img class="cover" src={item.data.cover} alt={`Cover for ${item.data.title}`} loading="lazy" />
                  </div>
                ) : (
                  <div class="thumb thumbEmpty" aria-hidden="true">
                    <span class="thumbMark">AL</span>
                  </div>
                )}

                <div class="meta">
                  <div class="cardTitle">{item.data.title}</div>

                  <div class="excerpt">
                    <div class="excerptLabel">Description</div>
                    <div class="whenToUse">
                      {item.data.whenToUse ? item.data.whenToUse : <span class="muted">—</span>}
                    </div>
                  </div>

                  {item.data.link && (
                    <div class="cardSubLabel" aria-hidden="true">External</div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="groupFooter">
          <button
            class="groupToggle"
            type="button"
            data-expand-toggle
            hidden
            aria-expanded="true"
            aria-label="View all models in this section"
          >
<span class="groupTogglePill" aria-hidden="true">
  <img class="groupToggleIcon" src="/homepage/downarrow.png" alt="" />
</span>
          </button>
        </div>
      </section>
    )}

    <div id="empty" class="empty" hidden>
      <div class="emptyTitle">No models found</div>
      <div class="emptyDesc">Try a different search term, or clear filters.</div>
      <button id="emptyClear" class="primary" type="button">Clear filters</button>
    </div>

{groups.map((g) => (
  <section class="group" id={catId(g.category)} data-group={g.category} data-expanded="true">
    <div class="groupHead">
      <div class="groupTitleWrap">
        <h2 class="groupTitle">
          {g.category} <span class="count">({g.items.length})</span>
        </h2>
        <div class="groupRule" aria-hidden="true"></div>
      </div>
    </div>

    <div class="groupReveal" data-expand-wrap>
      <div class="grid" data-expand-grid>
        {g.items.map((item) => (
<a
  class="card"
  href={item.data.link || `/toolkit/${item.slug}/`}
  target={item.data.link ? "_blank" : undefined}
  rel={item.data.link ? "noopener noreferrer" : undefined}
  data-title={item.data.title}
  data-category={item.data.primaryCategory || "Uncategorized"}
  data-when={item.data.whenToUse || ""}
  onclick={`trackEvent('framework_click', {
    framework: '${item.slug}',
    framework_name: '${(item.data.title || "").replace(/'/g, "\\'")}',
    category: '${(item.data.primaryCategory || "Uncategorized").replace(/'/g, "\\'")}',
    featured: false,
    source: 'finance_toolkit',
    destination: '${item.data.link ? "external" : "internal"}',
    position: ${g.items.findIndex((x) => x.slug === item.slug) + 1}
  })`}
>
                {item.data.link && (
                  <span class="externalBadge" aria-hidden="true" title="Opens external link">↗</span>
                )}

                {item.data.cover ? (
                  <div class="thumb" aria-hidden="true">
                    <img class="cover" src={item.data.cover} alt={`Cover for ${item.data.title}`} loading="lazy" />
                  </div>
                ) : (
                  <div class="thumb thumbEmpty" aria-hidden="true">
                    <span class="thumbMark">AL</span>
                  </div>
                )}

                <div class="meta">
                  <div class="cardTitle">{item.data.title}</div>

                  <div class="excerpt">
                    <div class="excerptLabel">Description</div>
                    <div class="whenToUse">
                      {item.data.whenToUse ? item.data.whenToUse : <span class="muted">—</span>}
                    </div>
                  </div>

                  {item.data.link && (
                    <div class="cardSubLabel" aria-hidden="true">External</div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="groupFooter">
          <button
  class="groupToggle"
  type="button"
  data-expand-toggle
  hidden
  aria-expanded="true"
  aria-label="View all models in this section"
>
<span class="groupTogglePill" aria-hidden="true">
  <img class="groupToggleIcon" src="/homepage/downarrow.png" alt="" />
</span>
          </button>
        </div>
      </section>
    ))}

    <button id="toTop" class="toTop" type="button" aria-label="Back to top">↑ Top</button>
    
       <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        try {
          const root = document.querySelector(".toolkit");
          const q = document.getElementById("q");
          const cat = document.getElementById("cat");
          const clear = document.getElementById("clear");
          const empty = document.getElementById("empty");
          const emptyClear = document.getElementById("emptyClear");
          const resultsText = document.getElementById("resultsText");

          const viewGrid = document.getElementById("viewGrid");
          const viewCompact = document.getElementById("viewCompact");
          const toTop = document.getElementById("toTop");

          const jumpChips = document.getElementById("jumpChips");
          const railLeft = document.getElementById("railLeft");
          const railRight = document.getElementById("railRight");
          const sectionsNav = document.querySelector(".sections");

          const expandableSections = Array.from(
            document.querySelectorAll("section.group, section.featuredBlock")
          );

          if (!root) throw new Error("Toolkit root not found (.toolkit). Script not attaching.");

          function normalize(s) {
            return (s || "").toLowerCase().trim();
          }

          function escAttr(s) {
            return String(s || "").replace(/\\/g, "\\\\").replace(/"/g, '\\"');
          }

          const controlsBar = document.querySelector(".controlsBar");
          const toolkitRoot = document.querySelector(".toolkit");

          function syncStickyControlBar() {
            if (!controlsBar) return;

            const stickyTop = parseFloat(getComputedStyle(controlsBar).top || "0") || 0;
            const rect = controlsBar.getBoundingClientRect();
            const isSticky = rect.top <= stickyTop + 0.5;

            controlsBar.classList.toggle("isStickyMobile", isSticky);

            if (isSticky && toolkitRoot) {
              const hostRect = toolkitRoot.getBoundingClientRect();
              const leftExpand = Math.max(0, hostRect.left);
              const rightExpand = Math.max(0, window.innerWidth - hostRect.right);
              controlsBar.style.setProperty("--sticky-expand-left", `${leftExpand}px`);
              controlsBar.style.setProperty("--sticky-expand-right", `${rightExpand}px`);
            } else {
              controlsBar.style.removeProperty("--sticky-expand-left");
              controlsBar.style.removeProperty("--sticky-expand-right");
            }
          }

          function queueStickyControlBarSync() {
            window.requestAnimationFrame(syncStickyControlBar);
          }

          function getHasActiveFilter() {
            return Boolean(normalize(q?.value) || (cat?.value || ""));
          }

          function setView(view) {
            root.dataset.view = view;

            const isGrid = view === "grid";
            viewGrid?.classList.toggle("isActive", isGrid);
            viewCompact?.classList.toggle("isActive", !isGrid);

            viewGrid?.setAttribute("aria-pressed", String(isGrid));
            viewCompact?.setAttribute("aria-pressed", String(!isGrid));

            try {
              localStorage.setItem("financeToolkitView", view);
            } catch {}

            requestAnimationFrame(() => refreshExpandableSections(getHasActiveFilter()));
          }

          function clearSectionsActive() {
            jumpChips?.querySelectorAll(".sectionBtn.isActive").forEach((b) => b.classList.remove("isActive"));
          }

          function setSectionsActiveByCategory(category) {
            clearSectionsActive();
            if (!category) return;
            const sel = `.sectionBtn[data-cat="${escAttr(category)}"]`;
            const btn = jumpChips?.querySelector(sel);
            if (btn) btn.classList.add("isActive");
          }

          let isManualNav = false;

          function temporarilyPauseScrollSpy() {
            isManualNav = true;
            window.setTimeout(() => (isManualNav = false), 700);
          }

          function countVisibleCards() {
            return document.querySelectorAll("a.card:not(.isHidden)").length;
          }

          function getVisibleCardsInSection(section) {
            return Array.from(section.querySelectorAll("a.card")).filter(
              (card) => !card.classList.contains("isHidden")
            );
          }

          function refreshExpandableSections(forceExpand = false) {
            const isCompact = root?.dataset.view === "compact";

            expandableSections.forEach((section) => {
              const wrap = section.querySelector("[data-expand-wrap]");
              const toggle = section.querySelector("[data-expand-toggle]");
              const footer = section.querySelector(".groupFooter");

              if (!wrap || !toggle || !footer) return;

              if (section.classList.contains("isHidden")) {
                toggle.hidden = true;
                footer.classList.remove("isVisible");
                toggle.setAttribute("aria-expanded", "false");
                section.classList.remove("isCollapsible", "isCollapsed", "isExpanded");
                wrap.style.removeProperty("--collapsed-h");
                return;
              }

              const cards = getVisibleCardsInSection(section);

              if (!cards.length) {
                toggle.hidden = true;
                footer.classList.remove("isVisible");
                toggle.setAttribute("aria-expanded", "false");
                section.classList.remove("isCollapsible", "isCollapsed", "isExpanded");
                wrap.style.removeProperty("--collapsed-h");
                return;
              }

              const firstTop = cards[0].offsetTop;
              const firstRow = cards.filter((card) => Math.abs(card.offsetTop - firstTop) < 2);
              const firstRowHeight = Math.max(
                ...firstRow.map((card) => card.offsetHeight + (card.offsetTop - firstTop))
              );

              const hasMoreThanOneRow = cards.length > firstRow.length;
              const peek = window.innerWidth <= 720 ? 14 : 18;
              const collapsedHeight = firstRowHeight + peek;

              const expanded = section.dataset.expanded === "true";
              const shouldForceExpand = forceExpand || isCompact;

              if (!hasMoreThanOneRow) {
                toggle.hidden = true;
                footer.classList.remove("isVisible");
                toggle.setAttribute("aria-expanded", "false");
                section.classList.remove("isCollapsible", "isCollapsed", "isExpanded");
                wrap.style.removeProperty("--collapsed-h");
                return;
              }

              if (shouldForceExpand) {
                toggle.hidden = true;
                footer.classList.remove("isVisible");
                toggle.setAttribute("aria-expanded", "true");
                section.classList.add("isCollapsible", "isExpanded");
                section.classList.remove("isCollapsed");
                wrap.style.removeProperty("--collapsed-h");
                return;
              }

              wrap.style.setProperty("--collapsed-h", `${Math.ceil(collapsedHeight)}px`);
              section.classList.add("isCollapsible");
              section.classList.toggle("isExpanded", expanded);
              section.classList.toggle("isCollapsed", !expanded);

              toggle.hidden = false;
              footer.classList.add("isVisible");
              toggle.setAttribute("aria-expanded", String(expanded));
              toggle.setAttribute(
                "aria-label",
                expanded ? "Show fewer models in this section" : "View all models in this section"
              );
            });
          }

          function applyFilter() {
            const query = normalize(q?.value);
            const selected = cat?.value || "";

            const sections = document.querySelectorAll("section.group, section.featuredBlock");

            sections.forEach((section) => {
              const cards = section.querySelectorAll("a.card");
              let visibleCount = 0;

              cards.forEach((card) => {
                const title = normalize(card.dataset.title);
                const c = card.dataset.category || "";
                const when = normalize(card.dataset.when || "");

                const catText = normalize(c);
                const matchText = !query || title.includes(query) || catText.includes(query) || when.includes(query);
                const matchCat = !selected || c === selected;

                const show = matchText && matchCat;
                card.classList.toggle("isHidden", !show);
                if (show) visibleCount++;
              });

              section.classList.toggle("isHidden", visibleCount === 0);
            });

            const totalVisible = countVisibleCards();
            if (empty) empty.hidden = totalVisible !== 0;

            if (resultsText) {
              const suffix = totalVisible === 1 ? "model" : "models";
              resultsText.textContent = `Showing ${totalVisible} ${suffix}`;
            }

            if (selected) {
              setSectionsActiveByCategory(selected);
            } else {
              clearSectionsActive();
              computeActiveSection();
            }

            refreshExpandableSections(Boolean(query || selected));
          }

          function clearFilters() {
            if (q) q.value = "";
            if (cat) cat.value = "";
            applyFilter();
            q?.focus();
          }

          function updateRails() {
            if (!jumpChips || !sectionsNav) return;

            const maxScroll = jumpChips.scrollWidth - jumpChips.clientWidth;
            const hasLeft = jumpChips.scrollLeft > 2;
            const hasRight = jumpChips.scrollLeft < maxScroll - 2;

            sectionsNav.classList.toggle("hasLeft", hasLeft);
            sectionsNav.classList.toggle("hasRight", hasRight);

            if (railRight) {
              railRight.style.opacity = hasRight ? "0.85" : "0.35";
              railRight.style.pointerEvents = hasRight ? "auto" : "none";
            }
          }

          try {
            const saved = localStorage.getItem("financeToolkitView");
            if (saved === "compact" || saved === "grid") setView(saved);
          } catch {}

          window.addEventListener("scroll", queueStickyControlBarSync, { passive: true });
          window.addEventListener("resize", queueStickyControlBarSync);
          window.visualViewport?.addEventListener("resize", queueStickyControlBarSync);
          window.visualViewport?.addEventListener("scroll", queueStickyControlBarSync);

          viewGrid?.addEventListener("click", () => setView("grid"));
          viewCompact?.addEventListener("click", () => setView("compact"));

          q?.addEventListener("input", applyFilter);

          cat?.addEventListener("change", () => {
            if (typeof window.trackEvent === "function") {
              window.trackEvent("toolkit_category_select", {
                category_name: cat.value || "All categories",
                source: "finance_toolkit",
              });
            }
            applyFilter();
          });

          clear?.addEventListener("click", clearFilters);
          emptyClear?.addEventListener("click", clearFilters);

          document.querySelectorAll("[data-jump]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const id = btn.getAttribute("data-jump");
              const el = id && document.getElementById(id);
              if (!el) return;

              if (q) q.value = "";
              if (cat) cat.value = "";
              applyFilter();

              temporarilyPauseScrollSpy();
              el.scrollIntoView({ behavior: "smooth", block: "start" });
            });
          });

          document.querySelectorAll("[data-expand-toggle]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const section = btn.closest("section.group, section.featuredBlock");
              if (!section) return;

              const expanded = section.dataset.expanded === "true";
              section.dataset.expanded = expanded ? "false" : "true";
              refreshExpandableSections(false);
            });
          });

          function scrollSections(dir) {
            if (!jumpChips) return;
            const step = Math.min(360, jumpChips.clientWidth * 0.7);
            jumpChips.scrollBy({ left: dir * step, behavior: "smooth" });
            setTimeout(updateRails, 250);
          }

          railLeft?.addEventListener("click", () => scrollSections(-1));
          railRight?.addEventListener("click", () => scrollSections(1));

          jumpChips?.addEventListener("scroll", updateRails, { passive: true });
          window.addEventListener("resize", () => {
            updateRails();
            refreshExpandableSections(getHasActiveFilter());
          });

          function updateToTop() {
            if (!toTop) return;
            const show = window.scrollY > 420;
            toTop.classList.toggle("isVisible", show);
          }

          window.addEventListener("scroll", updateToTop, { passive: true });
          toTop?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
          updateToTop();

          const observedSections = Array.from(document.querySelectorAll("section.group, section.featuredBlock"));
          let ticking = false;

          function computeActiveSection() {
            if (isManualNav) return;
            ticking = false;
            if (!observedSections.length || !jumpChips) return;

            const selected = cat?.value || "";
            if (selected) return;

            const y = window.scrollY + 120;
            let currentId = "";

            for (const s of observedSections) {
              if (s.classList.contains("isHidden")) continue;
              const top = s.offsetTop;
              if (top <= y) currentId = s.id || "";
            }

            if (!currentId) return;

            clearSectionsActive();
            const btn = jumpChips.querySelector(`.sectionBtn[data-jump="${escAttr(currentId)}"]`);
            if (btn) btn.classList.add("isActive");
          }

          window.addEventListener(
            "scroll",
            () => {
              if (!ticking) {
                ticking = true;
                requestAnimationFrame(computeActiveSection);
              }
            },
            { passive: true }
          );

          applyFilter();
          computeActiveSection();
          updateRails();
          queueStickyControlBarSync();
          setTimeout(queueStickyControlBarSync, 80);
          setTimeout(queueStickyControlBarSync, 220);
          window.addEventListener("load", queueStickyControlBarSync);

          requestAnimationFrame(() => refreshExpandableSections(getHasActiveFilter()));
          setTimeout(() => refreshExpandableSections(getHasActiveFilter()), 80);
          setTimeout(() => refreshExpandableSections(getHasActiveFilter()), 260);

          window.addEventListener("load", () => {
            refreshExpandableSections(getHasActiveFilter());
            updateRails();
          });
        } catch (e) {
          console.error("[finance-toolkit] init failed:", e);
        }
      });
    </script>

  <style>
  .toolkit {
    width: 100%;
    padding-top: 10px;
    padding-bottom: 76px;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    --tk-radius: 18px;
    --tk-radius-sm: 12px;
  }

.toTop {
  position: fixed;
  right: 22px;
bottom: max(28px, calc(env(safe-area-inset-bottom, 0px) + 0px));  
z-index: 200;
  isolation: isolate;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  height: 44px;
  padding: 0 14px;
  border: 1px solid rgba(79, 101, 145, 0.34);
  border-radius: 999px;
  background:
    linear-gradient(180deg, rgba(20, 30, 55, 0.92) 0%, rgba(10, 17, 33, 0.96) 100%);
  color: rgba(248, 250, 255, 0.94);
  box-shadow:
    0 1px 0 rgba(255,255,255,0.08) inset,
    0 12px 26px rgba(4, 9, 18, 0.24),
    0 24px 46px rgba(4, 9, 18, 0.12);
  backdrop-filter: blur(18px) saturate(130%);
  -webkit-backdrop-filter: blur(18px) saturate(130%);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: -0.01em;
  cursor: pointer;
  opacity: 0;
  pointer-events: none;
  transform: translateY(10px);
  transition:
    opacity 0.2s var(--ease),
    transform 0.2s var(--ease),
    border-color 0.2s var(--ease),
    box-shadow 0.2s var(--ease);
}

.toTop.isVisible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.toTop:hover {
  border-color: rgba(116, 145, 206, 0.48);
  box-shadow:
    0 1px 0 rgba(255,255,255,0.1) inset,
    0 16px 30px rgba(4, 9, 18, 0.28),
    0 30px 56px rgba(4, 9, 18, 0.16);
}

  .group,
  .featuredBlock {
    scroll-margin-top: 102px;
  }

  .isHidden {
    display: none !important;
  }

  .controlsBar {
    position: sticky;
    top: calc(var(--siteHeaderH, 64px) + 0px);
    z-index: 40;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    padding: 14px 16px;
    min-height: 56px;
    width: 100%;
    box-sizing: border-box;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--border) 76%, transparent);
    background:
      linear-gradient(
        180deg,
        rgb(from var(--surface) r g b / 0.72),
        rgb(from var(--surface) r g b / 0.64)
      );
    backdrop-filter: blur(14px) saturate(118%);
    -webkit-backdrop-filter: blur(14px) saturate(118%);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.7) inset,
      0 16px 34px rgba(0,0,0,0.035);
    margin: 0 0 14px;
    transition:
      box-shadow 0.2s var(--ease),
      border-color 0.2s var(--ease),
      border-radius 0.22s var(--ease),
      margin 0.22s var(--ease),
      padding 0.22s var(--ease),
      width 0.22s var(--ease);
  }

  .controlsBar:focus-within {
    border-color: color-mix(in srgb, var(--border) 90%, transparent);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.78) inset,
      0 20px 40px rgba(0,0,0,0.045);
  }

  .controlsBar.isStickyMobile {
    width: auto;
    max-width: none;
    margin-left: calc(var(--sticky-expand-left, 0px) * -1);
    margin-right: calc(var(--sticky-expand-right, 0px) * -1);
    border-radius: 0;
    border-left-color: transparent;
    border-right-color: transparent;
    padding-left: max(18px, env(safe-area-inset-left, 0px));
    padding-right: max(18px, env(safe-area-inset-right, 0px));
  }

  .field {
    flex: 1;
    min-width: 260px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 13px;
    border-radius: 13px;
    border: 1px solid color-mix(in srgb, var(--border) 76%, transparent);
    background: color-mix(in srgb, var(--surface) 99%, black 1%);
    transition: border-color 0.18s var(--ease), background 0.18s var(--ease);
  }

  .field:hover {
