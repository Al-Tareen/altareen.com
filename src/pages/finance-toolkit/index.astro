---
import PageShell from "../../components/PageShell.astro";
import { getCollection } from "astro:content";

const FINANCE_CATEGORY = "Financial Models";

const all = await getCollection("toolkit");

const items = all.filter(
  (item) => (item.data.primaryCategory || "").trim() === FINANCE_CATEGORY
);

// Build grouped structure
const groupsMap = new Map();
for (const item of items) {
  const c = (item.data.primaryCategory || "Uncategorized").trim();
  if (!groupsMap.has(c)) groupsMap.set(c, []);
  groupsMap.get(c).push(item);
}

const categories = Array.from(groupsMap.keys()).sort((a, b) => a.localeCompare(b));
for (const c of categories) {
  groupsMap.get(c).sort((a, b) => a.data.title.localeCompare(b.data.title));
}
const groups = categories.map((c) => ({ category: c, items: groupsMap.get(c) }));

function catId(name) {
  return (
    "cat-" +
    String(name || "")
      .trim()
      .toLowerCase()
      .replace(/['"]/g, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
  );
}

// Featured (Notion checkbox -> frontmatter `featured: true`)
const featured = items.filter((i) => i.data.featured === true).slice(0, 8);

---

<PageShell
  title="Finance Toolkit"
  description="Financial models for founders and finance professionals."
>
  <div class="toolkit" data-view="grid">
    <!-- Sticky controls -->
    <div class="controlsBar" role="search" aria-label="Search and filter financial models">
      <div class="field">
        <span class="icon" aria-hidden="true">⌕</span>
        <input id="q" class="input" type="search" placeholder="Search financial models…" />
      </div>

      <select id="cat" class="select" aria-label="Filter by category">
        <option value="">All categories</option>
        {categories.map((c) => <option value={c}>{c}</option>)}
      </select>

      <div class="rightActions">
        <div class="resultsInline" id="resultsText">Showing {items.length} models</div>

        <div class="viewToggle" role="group" aria-label="View toggle">
          <button id="viewGrid" class="toggleBtn isActive" type="button" aria-pressed="true">
            Grid
          </button>
          <button id="viewCompact" class="toggleBtn" type="button" aria-pressed="false">
            Compact
          </button>
        </div>

        <button id="clear" class="ghost" type="button">Clear</button>
      </div>
    </div>

    {featured.length > 0 && (
      <section class="featuredBlock" id="__featured" data-group="__featured">
        <div class="groupHead">
          <h2 class="groupTitle">
            Featured <span class="count">({featured.length})</span>
          </h2>
          <div class="groupRule" aria-hidden="true"></div>
        </div>

        <div class="grid">
{featured.map((item) => (
  <a
    class="card"
    href={item.data.link || `/toolkit/${item.slug}/`}
    target={item.data.link ? "_blank" : undefined}
    rel={item.data.link ? "noopener noreferrer" : undefined}
    data-title={item.data.title}
    data-category={item.data.primaryCategory || "Uncategorized"}
    data-when={item.data.whenToUse || ""}
    data-featured="true"
  >
    {item.data.link && (
      <span class="externalBadge" aria-hidden="true" title="Opens external link">↗</span>
    )}

    {item.data.cover ? (
      <div class="thumb" aria-hidden="true">
        <img class="cover" src={item.data.cover} alt={`Cover for ${item.data.title}`} loading="lazy" />
      </div>
    ) : (
      <div class="thumb thumbEmpty" aria-hidden="true">
        <span class="thumbMark">AL</span>
      </div>
    )}

    <div class="meta">
      <div class="cardTitle">{item.data.title}</div>

      <div class="excerpt">
        <div class="excerptLabel">Description</div>
        <div class="whenToUse">
          {item.data.whenToUse ? item.data.whenToUse : <span class="muted">—</span>}
        </div>
      </div>

      {item.data.link && (
        <div class="cardSubLabel" aria-hidden="true">External</div>
      )}
    </div>
  </a>
))}
        </div>
      </section>
    )}

    <!-- Empty state -->
    <div id="empty" class="empty" hidden>
      <div class="emptyTitle">No models found</div>
      <div class="emptyDesc">Try a different search term, or clear filters.</div>
      <button id="emptyClear" class="primary" type="button">Clear filters</button>
    </div>

    <!-- Groups -->
    {groups.map((g) => (
      <section class="group" id={catId(g.category)} data-group={g.category}>
        <div class="groupHead">
          <h2 class="groupTitle">
            {g.category} <span class="count">({g.items.length})</span>
          </h2>
          <div class="groupRule" aria-hidden="true"></div>
        </div>

        <div class="grid">
{g.items.map((item) => (
  <a
    class="card"
    href={item.data.link || `/toolkit/${item.slug}/`}
    target={item.data.link ? "_blank" : undefined}
    rel={item.data.link ? "noopener noreferrer" : undefined}
    data-title={item.data.title}
    data-category={item.data.primaryCategory || "Uncategorized"}
    data-when={item.data.whenToUse || ""}
  >
    {item.data.link && (
      <span class="externalBadge" aria-hidden="true" title="Opens external link">↗</span>
    )}

    {item.data.cover ? (
      <div class="thumb" aria-hidden="true">
        <img class="cover" src={item.data.cover} alt={`Cover for ${item.data.title}`} loading="lazy" />
      </div>
    ) : (
      <div class="thumb thumbEmpty" aria-hidden="true">
        <span class="thumbMark">AL</span>
      </div>
    )}

    <div class="meta">
      <div class="cardTitle">{item.data.title}</div>

      <div class="excerpt">
        <div class="excerptLabel">Description</div>
        <div class="whenToUse">
          {item.data.whenToUse ? item.data.whenToUse : <span class="muted">—</span>}
        </div>
      </div>

      {item.data.link && (
        <div class="cardSubLabel" aria-hidden="true">External</div>
      )}
    </div>
  </a>
))}
        </div>
      </section>
    ))}

    <!-- Back to top -->
    <button id="toTop" class="toTop" type="button" aria-label="Back to top">↑ Top</button>

    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        try {
          const root = document.querySelector(".toolkit");
          const q = document.getElementById("q");
          const cat = document.getElementById("cat");
          const clear = document.getElementById("clear");
          const empty = document.getElementById("empty");
          const emptyClear = document.getElementById("emptyClear");
          const resultsText = document.getElementById("resultsText");

          const viewGrid = document.getElementById("viewGrid");
          const viewCompact = document.getElementById("viewCompact");

          const toTop = document.getElementById("toTop");

          const jumpChips = document.getElementById("jumpChips");
          const railLeft = document.getElementById("railLeft");
          const railRight = document.getElementById("railRight");
          const sectionsNav = document.querySelector(".sections"); // ✅ used for hasLeft/hasRight

          if (!root) throw new Error("Toolkit root not found (.toolkit). Script not attaching.");

          function normalize(s) {
            return (s || "").toLowerCase().trim();
          }

          // Minimal attribute-escape for querySelector attribute match
          function escAttr(s) {
            return String(s || "").replace(/\\/g, "\\\\").replace(/"/g, '\\"');
          }

          function setView(view) {
            root.dataset.view = view;

            const isGrid = view === "grid";
            viewGrid?.classList.toggle("isActive", isGrid);
            viewCompact?.classList.toggle("isActive", !isGrid);

            viewGrid?.setAttribute("aria-pressed", String(isGrid));
            viewCompact?.setAttribute("aria-pressed", String(!isGrid));

            try {
              localStorage.setItem("financeToolkitView", view);
            } catch {}
          }

          function clearSectionsActive() {
            jumpChips?.querySelectorAll(".sectionBtn.isActive").forEach((b) => b.classList.remove("isActive"));
          }

          function setSectionsActiveByCategory(category) {
            if (!jumpChips) return;
            clearSectionsActive();
            if (!category) return;
            const sel = `.sectionBtn[data-cat="${escAttr(category)}"]`;
            const btn = jumpChips?.querySelector(sel);
            if (btn) btn.classList.add("isActive");
          }

let isManualNav = false; // prevents scrollspy from fighting right after a click

function temporarilyPauseScrollSpy() {
  isManualNav = true;
  window.setTimeout(() => (isManualNav = false), 700);
}

          function countVisibleCards() {
            return document.querySelectorAll("a.card:not(.isHidden)").length;
          }

          function applyFilter() {
            const query = normalize(q?.value);
            const selected = cat?.value || "";

            const sections = document.querySelectorAll("section.group, section.featuredBlock");

            sections.forEach((section) => {
              const cards = section.querySelectorAll("a.card");
              let visibleCount = 0;

              cards.forEach((card) => {
                const title = normalize(card.dataset.title);
                const c = card.dataset.category || "";
                const when = normalize(card.dataset.when || "");

                const catText = normalize(c);
                const matchText = !query || title.includes(query) || catText.includes(query) || when.includes(query);
                const matchCat = !selected || c === selected;

                const show = matchText && matchCat;
                card.classList.toggle("isHidden", !show);
                if (show) visibleCount++;
              });

              section.classList.toggle("isHidden", visibleCount === 0);
            });

            const totalVisible = countVisibleCards();
            if (empty) empty.hidden = totalVisible !== 0;

            if (resultsText) {
              const suffix = totalVisible === 1 ? "model" : "models";
              resultsText.textContent = `Showing ${totalVisible} ${suffix}`;
            }

if (selected) {
  // Dropdown-filter mode: highlight the matching capsule
  setSectionsActiveByCategory(selected);
} else {
  // Navigation mode: do NOT force a capsule active here
  // Let scrollspy decide as you scroll naturally
  clearSectionsActive();
  computeActiveSection?.(); // safe if defined below
}
          }
          function clearFilters() {
            if (q) q.value = "";
            if (cat) cat.value = "";
            applyFilter();
            q?.focus();
          }

          // ✅ Arrow visibility: left arrow only appears after scrolling right.
          function updateRails() {
            if (!jumpChips || !sectionsNav) return;

            const maxScroll = jumpChips.scrollWidth - jumpChips.clientWidth;

            const hasLeft = jumpChips.scrollLeft > 2;
            const hasRight = jumpChips.scrollLeft < maxScroll - 2;

            sectionsNav.classList.toggle("hasLeft", hasLeft);
            sectionsNav.classList.toggle("hasRight", hasRight);

            // Always keep right arrow available if there is more content to the right
            if (railRight) {
              railRight.style.opacity = hasRight ? "0.85" : "0.35";
              railRight.style.pointerEvents = hasRight ? "auto" : "none";
            }
          }

          // Init saved view
          try {
            const saved = localStorage.getItem("financeToolkitView");
            if (saved === "compact" || saved === "grid") setView(saved);
          } catch {}

          // Attach listeners
          viewGrid?.addEventListener("click", () => setView("grid"));
          viewCompact?.addEventListener("click", () => setView("compact"));

          q?.addEventListener("input", applyFilter);
          cat?.addEventListener("change", applyFilter);
          clear?.addEventListener("click", clearFilters);
          emptyClear?.addEventListener("click", clearFilters);

          // Jump buttons
document.querySelectorAll("[data-jump]").forEach((btn) => {
  btn.addEventListener("click", () => {
    const id = btn.getAttribute("data-jump");
    const el = id && document.getElementById(id);
    if (!el) return;

    // Clear filters so navigation shows full page
    if (q) q.value = "";
    if (cat) cat.value = "";
    applyFilter();

    temporarilyPauseScrollSpy();
    el.scrollIntoView({ behavior: "smooth", block: "start" });
  });
});
          // Section arrows — scroll the ACTUAL scroller
          function scrollSections(dir) {
            if (!jumpChips) return;
            const step = Math.min(360, jumpChips.clientWidth * 0.7);
            jumpChips.scrollBy({ left: dir * step, behavior: "smooth" });
            setTimeout(updateRails, 250); // ✅ update after smooth scroll starts
          }
          railLeft?.addEventListener("click", () => scrollSections(-1));
          railRight?.addEventListener("click", () => scrollSections(1));

          // ✅ update rails on manual scroll/resize
          jumpChips?.addEventListener("scroll", updateRails, { passive: true });
          window.addEventListener("resize", updateRails);

          // Back to top
          function updateToTop() {
            if (!toTop) return;
            const show = window.scrollY > 420;
            toTop.classList.toggle("isVisible", show);
          }
          window.addEventListener("scroll", updateToTop, { passive: true });
          toTop?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
          updateToTop();

          // Scrollspy (only when not category-filtered)
          const observedSections = Array.from(document.querySelectorAll("section.group, section.featuredBlock"));
          let ticking = false;

          function computeActiveSection() {
            if (isManualNav) return;
            ticking = false;
            if (!observedSections.length || !jumpChips) return;

            const selected = cat?.value || "";
            if (selected) return;

            const y = window.scrollY + 120;
            let currentId = "";

            for (const s of observedSections) {
              if (s.classList.contains("isHidden")) continue;
              const top = s.offsetTop;
              if (top <= y) currentId = s.id || "";
            }
            if (!currentId) return;

            clearSectionsActive();
            const btn = jumpChips.querySelector(`.sectionBtn[data-jump="${escAttr(currentId)}"]`);
            if (btn) btn.classList.add("isActive");
          }

          window.addEventListener(
            "scroll",
            () => {
              if (!ticking) {
                ticking = true;
                requestAnimationFrame(computeActiveSection);
              }
            },
            { passive: true }
          );

          // First run
          applyFilter();
          computeActiveSection();
          updateRails(); // ✅ initial arrow state
setTimeout(updateRails, 50);  // ✅ after layout settles
setTimeout(updateRails, 250); // ✅ after any late paint/font swap
        } catch (e) {
          console.error("[finance-toolkit] init failed:", e);
        }
      });
    </script>

<style>
  .toolkit {
    padding-top: 8px;
    padding-bottom: 72px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .group,
  .featuredBlock {
    scroll-margin-top: 96px;
  }

  .isHidden {
    display: none !important;
  }

  /* Controls bar */
  .controlsBar {
    position: sticky;
    top: calc(var(--siteHeaderH) + 12px);
    z-index: 90;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    padding: 12px 14px;
    min-height: 52px;
    box-sizing: border-box;
    border-radius: 14px;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    backdrop-filter: blur(10px);
-webkit-backdrop-filter: blur(10px);
background:
  linear-gradient(
    180deg,
    rgb(from var(--surface) r g b / 0.6),
    rgb(from var(--surface) r g b / 0.6)
  );
    box-shadow:
      0 1px 0 rgba(255,255,255,0.62) inset,
      0 8px 20px rgba(0,0,0,0.02);
    margin-bottom: 18px;
    transition: box-shadow 0.2s var(--ease), border-color 0.2s var(--ease);
    width: 100%;
    margin-left: 0;
    margin-right: 0;
  }

  .controlsBar:focus-within {
    border-color: color-mix(in srgb, var(--border) 88%, transparent);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.7) inset,
      0 10px 22px rgba(0,0,0,0.03);
  }

  .field {
    flex: 1;
    min-width: 240px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background: color-mix(in srgb, var(--surface) 99%, black 1%);
    transition: border-color 0.18s var(--ease), background 0.18s var(--ease);
  }

  .field:hover {
    border-color: color-mix(in srgb, var(--border) 88%, transparent);
  }

  .field:focus-within {
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    background: var(--surface);
  }

  .icon {
    opacity: 0.6;
    font-size: 14px;
    user-select: none;
    color: var(--ink-muted);
  }

  .input {
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--ink);
    font-size: 14px;
    line-height: 1.2;
    font-family: var(--font-sans);
  }

  .input::placeholder {
    color: color-mix(in srgb, var(--ink-muted) 88%, var(--ink) 12%);
  }

  .select {
    min-width: 180px;
    max-width: 240px;
    width: 100%;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background: color-mix(in srgb, var(--surface) 99%, black 1%);
    color: var(--ink);
    font-size: 14px;
    font-family: var(--font-sans);
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.18s var(--ease), background 0.18s var(--ease);
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .select:hover {
    border-color: color-mix(in srgb, var(--border) 88%, transparent);
  }

  .rightActions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .resultsInline {
    color: color-mix(in srgb, var(--ink-muted) 88%, var(--ink) 12%);
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    padding: 0 2px;
  }

  .ghost {
    min-height: 38px;
    padding: 0 12px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background: color-mix(in srgb, var(--surface) 98%, black 2%);
    color: var(--ink);
    font-size: 13px;
    font-weight: 550;
    cursor: pointer;
    box-shadow: 0 1px 0 rgba(255,255,255,0.6) inset;
    transition:
      background-color 0.18s var(--ease),
      border-color 0.18s var(--ease),
      transform 0.18s var(--ease);
  }

  .ghost:hover {
    background: color-mix(in srgb, var(--surface) 95%, black 2%);
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    transform: translateY(-1px);
  }

  .viewToggle {
    display: flex;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    border-radius: 10px;
    overflow: hidden;
    background: color-mix(in srgb, var(--surface) 98%, black 2%);
    box-shadow: 0 1px 0 rgba(255,255,255,0.55) inset;
  }

  .toggleBtn {
    min-height: 38px;
    padding: 0 12px;
    border: 0;
    background: transparent;
    color: color-mix(in srgb, var(--ink-muted) 82%, var(--ink) 18%);
    font-size: 13px;
    font-weight: 550;
    cursor: pointer;
    transition: background 0.18s var(--ease), color 0.18s var(--ease);
  }

  .toggleBtn:hover {
    color: var(--ink);
  }

  .toggleBtn.isActive {
    background: var(--surface);
    color: var(--ink);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--border) 70%, transparent);
  }

  /* Featured block */
  .featuredBlock {
    margin-top: 12px;
    padding: 18px;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 98%, white 2%),
        color-mix(in srgb, var(--surface) 98%, black 2%)
      );
    box-shadow:
      0 1px 0 rgba(255,255,255,0.62) inset,
      0 8px 20px rgba(0,0,0,0.018);
  }

  /* Group headers */
  .group {
    margin-top: 0;
  }

  .group + .group {
    margin-top: 34px;
  }

  .groupHead {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 12px;
  }

  .groupTitle {
    margin: 0;
    color: var(--ink);
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .count {
    font-weight: 500;
    color: color-mix(in srgb, var(--ink-muted) 88%, var(--ink) 12%);
    font-size: 0.9em;
  }

  .groupRule {
    display: none;
  }

  /* Grid + cards */
  .grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fill, minmax(272px, 1fr));
    align-items: stretch;
  }

  .card {
    position: relative; /* anchors external badge */
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    text-decoration: none;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 98%, white 2%),
        color-mix(in srgb, var(--surface) 98%, black 2%)
      );
    box-shadow:
      0 1px 0 rgba(255,255,255,0.62) inset,
      0 8px 20px rgba(0,0,0,0.018);
    height: 100%;
    color: inherit;
    transition:
      transform 0.2s var(--ease),
      box-shadow 0.2s var(--ease),
      border-color 0.2s var(--ease);
    box-sizing: border-box;
  }

  .card:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.72) inset,
      0 12px 24px rgba(0,0,0,0.035);
  }

  .thumb {
    width: 100%;
    aspect-ratio: 16/9;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.015) 0%, transparent 100%);
    border-bottom: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .thumb::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 55%, rgba(0, 0, 0, 0.025));
    pointer-events: none;
  }

.externalBadge {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 5;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  width: 22px;
  height: 22px;
  border-radius: 999px;

  /* homepage-like icon, but slightly more visible over image covers */
  color: var(--ink);
  font-size: 12px;
  line-height: 1;
  font-weight: 700;

  background: rgba(255, 255, 255, 0.78);
  border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);

  opacity: 0;
  transform: translate(-1px, 1px);
  pointer-events: none;

  transition:
    opacity 0.18s var(--ease),
    transform 0.18s var(--ease),
    border-color 0.18s var(--ease),
    background 0.18s var(--ease);
}

.card:hover .externalBadge,
.card:focus-visible .externalBadge,
.card:focus-within .externalBadge {
  opacity: 0.95;
  transform: translate(0, 0);
  background: rgba(255, 255, 255, 0.9);
  border-color: color-mix(in srgb, var(--border) 88%, transparent);
}

  .cover {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
    padding: 5px;
    box-sizing: border-box;
    transition: transform 0.22s var(--ease);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.86);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--border) 68%, transparent);
  }

  .card:hover .cover {
    transform: scale(1.01);
  }

