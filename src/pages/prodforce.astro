          orbitY: 78 + (ci % 3) * 28 + (Math.floor(ci / 4) % 2) * 12,
          speed: 0.46 + (ci % 5) * 0.1,
          phase: ci * 0.72,
          tilt: ((ci % 2 === 0 ? 1 : -1) * (0.08 + (ci % 3) * 0.03)),
          x: 0,
          y: 0,
