}
.pf-msg-assistant .pf-msg-role {
  color: #8b5cf6;
}
.pf-msg-bubble {
  padding: 14px 16px;
  border-radius: 12px;
  font-size: 14px;
  line-height: 1.65;
  color: #ddddf0;
  max-width: 100%;
}
.pf-msg-user .pf-msg-bubble {
  background: rgba(0,212,255,0.12);
  border: 1px solid rgba(0,212,255,0.2);
  align-self: flex-end;
  max-width: 85%;
}
.pf-msg-assistant .pf-msg-bubble {
