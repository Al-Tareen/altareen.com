}
.pf-msg-bubble h1 { font-size: 17px; font-weight: 700; }
.pf-msg-bubble h2 { font-size: 15px; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,0.07); padding-bottom: 6px; }
.pf-msg-bubble h3 { font-size: 14px; font-weight: 600; color: #00d4ff; }
.pf-msg-bubble p { margin: 8px 0; }
.pf-msg-bubble ul,
.pf-msg-bubble ol { padding-left: 18px; margin: 8px 0; }
.pf-msg-bubble li { margin: 5px 0; }
.pf-msg-bubble strong { color: #fff; font-weight: 700; }
.pf-msg-bubble em { color: #c4c4e0; font-style: italic; }
.pf-msg-bubble code {
