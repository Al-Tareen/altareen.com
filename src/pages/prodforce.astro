  /* ── Markdown renderer ─────────────────────────────────────────────────── */
  function renderMd(raw) {
    const lines = raw.split("\n");
    const out = [];
    let i = 0;
    while (i < lines.length) {
      const line = lines[i];
      // Fenced code block
      if (line.startsWith("```")) {
        const codeLines = [];
        i++;
        while (i < lines.length && !lines[i].startsWith("```")) {
          codeLines.push(escHtml(lines[i]));
          i++;
        }
        out.push("<pre><code>" + codeLines.join("\n") + "</code></pre>");
        i++;
        continue;
      }
      // Headings
      const h3m = line.match(/^### (.+)/);
      const h2m = line.match(/^## (.+)/);
      const h1m = line.match(/^# (.+)/);
      if (h3m) { out.push("<h3>" + inlineMd(escHtml(h3m[1])) + "</h3>"); i++; continue; }
      if (h2m) { out.push("<h2>" + inlineMd(escHtml(h2m[1])) + "</h2>"); i++; continue; }
      if (h1m) { out.push("<h1>" + inlineMd(escHtml(h1m[1])) + "</h1>"); i++; continue; }
      // HR
      if (/^---+$/.test(line)) { out.push("<hr>"); i++; continue; }
      // UL
      if (/^[-*] /.test(line)) {
        const items = [];
        while (i < lines.length && /^[-*] /.test(lines[i])) {
          items.push("<li>" + inlineMd(escHtml(lines[i].replace(/^[-*] /, ""))) + "</li>");
          i++;
        }
        out.push("<ul>" + items.join("") + "</ul>");
        continue;
      }
      // OL
      if (/^\d+\. /.test(line)) {
        const items = [];
        while (i < lines.length && /^\d+\. /.test(lines[i])) {
          items.push("<li>" + inlineMd(escHtml(lines[i].replace(/^\d+\. /, ""))) + "</li>");
          i++;
        }
        out.push("<ol>" + items.join("") + "</ol>");
        continue;
      }
      // Empty line
      if (!line.trim()) { i++; continue; }
      // Paragraph
      const paraLines = [];
      while (
        i < lines.length &&
        lines[i].trim() &&
        !lines[i].startsWith("#") &&
        !lines[i].startsWith("```") &&
        !/^[-*] /.test(lines[i]) &&
        !/^\d+\. /.test(lines[i]) &&
        !/^---/.test(lines[i])
      ) {
        paraLines.push(inlineMd(escHtml(lines[i])));
        i++;
      }
      if (paraLines.length) out.push("<p>" + paraLines.join("<br>") + "</p>");
    }
    return out.join("\n");
  }

  function inlineMd(t) {
    return t
      .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
      .replace(/\*([^*]+)\*/g, "<em>$1</em>")
      .replace(/`([^`]+)`/g, "<code>$1</code>");
  }

  function escHtml(s) {
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  /* ── Three.js scene ────────────────────────────────────────────────────── */
  function getSceneHex(mode) {
    return {
      idle: 0x00d4ff,
      intake: 0x38bdf8,
      clarify: 0xf59e0b,
      match: 0x34d399,
      specialists: 0x6366f1,
      synthesis: 0x8b5cf6,
      done: 0x10b981,
      error: 0xef4444,
    }[mode || "idle"] || 0x00d4ff;
  }

  function getSceneRgba(mode, alpha) {
    const hex = getSceneHex(mode);
    const r = (hex >> 16) & 255;
    const g = (hex >> 8) & 255;
    const b = hex & 255;
    return "rgba(" + r + "," + g + "," + b + "," + alpha + ")";
  }

  function getSceneHighlights() {
    const frameworksInFocus = Array.isArray(STATE.sceneFrameworks) && STATE.sceneFrameworks.length
      ? STATE.sceneFrameworks
      : (Array.isArray(STATE.sceneFrameworkDecisions) ? STATE.sceneFrameworkDecisions : []);
    const exactFrameworks = frameworksInFocus
      .map((framework) => framework.slug || framework.title)
      .filter(Boolean)
      .concat(STATE.sceneSelectedFramework ? [STATE.sceneSelectedFramework] : []);
    const categories = dedupeList(
      (Array.isArray(STATE.sceneCategoryDecisions) ? STATE.sceneCategoryDecisions : [])
        .map(function(decision) { return decision.category; })
        .concat(
          frameworksInFocus.map((framework) => framework.category)
        )
        .concat(STATE.sceneCategories || [])
        .concat(STATE.sceneSelectedCategory ? [STATE.sceneSelectedCategory] : [])
    );
    return {
      frameworkKeys: new Set(exactFrameworks),
      categories: new Set(categories),
      focus: STATE.sceneFocus,
    };
  }

  function findHighlightedFrameworkIndexes(fws, maxCount) {
    const highlights = getSceneHighlights();
    const exact = [];
    const byCategory = [];

    fws.forEach((framework, index) => {
      if (highlights.frameworkKeys.has(framework.slug) || highlights.frameworkKeys.has(framework.title)) {
        exact.push(index);
      } else if (highlights.categories.has(framework.category)) {
        byCategory.push(index);
      }
    });

    return (exact.length ? exact : byCategory).slice(0, maxCount);
  }

  function getActiveAgents() {
    const active = new Set();
    if (STATE.sceneMode === "intake" || STATE.sceneMode === "clarify" || STATE.sceneMode === "match") {
      active.add("Matcher");
    }
    if (STATE.sceneMode === "synthesis" || STATE.sceneMode === "done") {
      active.add("Synthesis");
    }
    if (STATE.sceneMode === "specialists") {
      const focus = String(STATE.sceneFocus || "").toLowerCase();
      const categories = Array.from(getSceneHighlights().categories).join(" ").toLowerCase();
      const focusContext = focus + " " + categories;
      if (/go-to-market|gtm|launch|pricing|retention|adoption/.test(focusContext)) active.add("GTM");
      if (/discovery|research|customer|user|interview|opportunity/.test(focusContext)) active.add("Discovery");
      if (/strategy|vision|positioning|north star|prioritization|roadmap|bet/.test(focusContext)) active.add("Strategy");
      if (active.size === 0) {
        active.add("Discovery");
        active.add("Strategy");
        active.add("GTM");
      }
    }
    if (STATE.sceneMode === "clarify" || STATE.sceneMode === "match" || STATE.sceneMode === "done") {
      const categories = Array.from(getSceneHighlights().categories).join(" ").toLowerCase();
      if (/discovery|delivery|metrics|analytics/.test(categories)) active.add("Discovery");
      if (/strategy|positioning|prioritization|roadmap|portfolio/.test(categories)) active.add("Strategy");
      if (/gtm|growth|market|sizing/.test(categories)) active.add("GTM");
    }
    return active;
  }

  function getSceneSize(container) {
    const rect = container.getBoundingClientRect();
    return {
      width: Math.max(1, Math.floor(rect.width || container.clientWidth || container.offsetWidth || 0)),
      height: Math.max(1, Math.floor(rect.height || container.clientHeight || container.offsetHeight || 0)),
    };
  }

  function sceneHexString(mode) {
    return "#" + getSceneHex(mode).toString(16).padStart(6, "0");
  }

  function rgbaFromHex(hex, alpha) {
    var arr = hexToRgbArray(hex);
    return (
      "rgba(" +
      Math.round(arr[0] * 255) +
      "," +
      Math.round(arr[1] * 255) +
      "," +
      Math.round(arr[2] * 255) +
      "," +
      alpha +
      ")"
    );
  }

  function roundRectPath(ctx, x, y, width, height, radius) {
    var r = Math.max(0, Math.min(radius, width / 2, height / 2));
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.lineTo(x + width - r, y);
    ctx.quadraticCurveTo(x + width, y, x + width, y + r);
    ctx.lineTo(x + width, y + height - r);
    ctx.quadraticCurveTo(x + width, y + height, x + width - r, y + height);
    ctx.lineTo(x + r, y + height);
    ctx.quadraticCurveTo(x, y + height, x, y + height - r);
    ctx.lineTo(x, y + r);
    ctx.quadraticCurveTo(x, y, x + r, y);
    ctx.closePath();
  }

  function drawScenePill(ctx, x, y, text, color, opts) {
    opts = opts || {};
    var fontSize = opts.fontSize || 10;
    var padX = opts.padX || 9;
    var padY = opts.padY || 5;
    var radius = opts.radius || 9;
    var glow = opts.glow || 0;
    ctx.save();
    ctx.font = "700 " + fontSize + "px system-ui, sans-serif";
    var label = String(text || "");
    var textWidth = ctx.measureText(label).width;
    var boxWidth = textWidth + padX * 2;
    var boxHeight = fontSize + padY * 2;
    var left = x - boxWidth / 2;
    var top = y - boxHeight / 2;
    roundRectPath(ctx, left, top, boxWidth, boxHeight, radius);
    ctx.fillStyle = opts.fill || "rgba(5, 9, 20, 0.82)";
    ctx.fill();
    ctx.lineWidth = opts.lineWidth || 1;
    ctx.strokeStyle = opts.stroke || rgbaFromHex(color, 0.42);
    ctx.stroke();
    if (glow) {
      ctx.shadowColor = color;
      ctx.shadowBlur = glow;
    }
    ctx.fillStyle = opts.textColor || color;
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(label, x, y + 0.5);
    ctx.restore();
  }

  function initConstellationScene(fws) {
    const canvas = document.getElementById("pfCanvas");
    const labelsEl = document.getElementById("pfAgentLabels");
    if (!canvas || !canvas.parentElement) return;
    const container = canvas.parentElement;
    const ctx = canvas.getContext("2d", { alpha: true });
    if (!ctx) return;

    if (window.__PF_SCENE_CLEANUP__) {
      try { window.__PF_SCENE_CLEANUP__(); } catch (err) { console.warn("[prodforce-scene-cleanup]", err); }
    }

    waitForSceneBox(container, function() {
      if (labelsEl) {
        labelsEl.innerHTML = "";
        labelsEl.style.display = "none";
      }

      var palette = buildCategoryPalette(fws, false);
      var categories = dedupeList(
        (fws || [])
          .map(function(fw) { return fw.category; })
          .filter(Boolean)
          .concat(Object.keys(palette))
      );

      var categoryCounts = {};
      fws.forEach(function(fw) {
        categoryCounts[fw.category] = (categoryCounts[fw.category] || 0) + 1;
      });

      var categoryBodies = categories.map(function(cat, ci) {
        var lane = ci % 4;
        var band = Math.floor(ci / 4);
        return {
          cat: cat,
          label: formatCategoryLabel(cat),
          color: palette[cat] || "#97a1ff",
          baseAngle: (ci / Math.max(categories.length, 1)) * Math.PI * 2 - Math.PI / 2,
          orbitXFactor: 0.18 + lane * 0.048 + band * 0.03,
          orbitYFactor: 0.14 + (ci % 3) * 0.055 + band * 0.028,
          speed: 0.11 + lane * 0.018 + (ci % 5) * 0.01,
          bobAmp: 18 + (ci % 4) * 5,
          bobSpeed: 0.62 + (ci % 3) * 0.08,
          zAmp: 1.6 + lane * 0.4,
          tilt: (ci % 2 === 0 ? 1 : -1) * (0.15 + band * 0.03),
          phase: ci * 0.73,
          size: 6.5 + lane * 1.2,
          x: 0,
          y: 0,
          z: 0,
          screen: null,
        };
      });

      var categoryBodyByCat = {};
      categoryBodies.forEach(function(body) {
        categoryBodyByCat[body.cat] = body;
      });

      var seenByCategory = {};
      var frameworkNodes = fws.map(function(fw, index) {
        var groupIndex = seenByCategory[fw.category] || 0;
        seenByCategory[fw.category] = groupIndex + 1;
        var ring = Math.floor(groupIndex / 6);
        var spoke = groupIndex % 6;
        return {
          frameworkIndex: index,
          slug: fw.slug,
          title: fw.title,
          category: fw.category,
          color: palette[fw.category] || "#97a1ff",
          baseAngle: (spoke / 6) * Math.PI * 2 + ring * 0.38,
          orbitRadius: 18 + ring * 11 + (groupIndex % 3) * 3,
          orbitRadiusY: 10 + ring * 6 + (groupIndex % 4) * 2,
          speed: 0.34 + (groupIndex % 7) * 0.032,
          phase: groupIndex * 0.41 + index * 0.07,
          zAmp: 1.1 + (groupIndex % 5) * 0.24,
          lift: ((groupIndex % 5) - 2) * 7,
          size: 2.1 + (ring % 3) * 0.45,
          x: 0,
          y: 0,
          z: 0,
          screen: null,
        };
      });
      var frameworkKeysByCategory = {};
      frameworkNodes.forEach(function(node) {
        if (!frameworkKeysByCategory[node.category]) frameworkKeysByCategory[node.category] = [];
        frameworkKeysByCategory[node.category].push(node.slug || node.title);
      });

      var stars = Array.from({ length: 180 }, function(_, index) {
        return {
          x: Math.random(),
          y: Math.random(),
          size: 0.5 + Math.random() * 1.7,
          alpha: 0.18 + Math.random() * 0.45,
          twinkle: Math.random() * Math.PI * 2,
          drift: 0.2 + Math.random() * 0.6,
          depth: 0.25 + Math.random() * 0.75,
          phase: index * 0.17,
        };
      });

      function resizeCanvas() {
        var size = getSceneSize(container);
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.max(1, Math.floor(size.width * dpr));
        canvas.height = Math.max(1, Math.floor(size.height * dpr));
        canvas.style.width = size.width + "px";
        canvas.style.height = size.height + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        return size;
      }

      function projectPoint(x, y, z, centerX, centerY) {
        var scale = 0.78 + z * 0.09;
        return {
          x: centerX + x * scale,
          y: centerY + y * scale,
          scale: scale,
          z: z,
        };
      }

      function updateBodies(t, size, depth) {
        var centerX = size.width * 0.47;
        var centerY = size.height * 0.52;
        categoryBodies.forEach(function(body) {
          var orbitX = Math.min(size.width * body.orbitXFactor, size.width * 0.42) + depth * 18;
          var orbitY = Math.min(size.height * body.orbitYFactor, size.height * 0.34) + depth * 14;
          var angle = body.baseAngle + t * body.speed * (1 + depth * 0.18);
          body.x = Math.cos(angle) * orbitX;
          body.y =
            Math.sin(angle + body.tilt) * orbitY +
            Math.cos(t * body.bobSpeed + body.phase) * body.bobAmp;
          body.z = Math.sin(angle * 0.9 + body.phase) * body.zAmp;
          body.screen = projectPoint(body.x, body.y, body.z, centerX, centerY);
        });

        frameworkNodes.forEach(function(node) {
          var body = categoryBodyByCat[node.category] || categoryBodies[0];
          var angle = node.baseAngle + t * node.speed + body.baseAngle * 0.22;
          var orbitRadius = node.orbitRadius + depth * 7;
          node.x = body.x + Math.cos(angle) * orbitRadius;
          node.y =
            body.y +
            node.lift +
            Math.sin(angle * 1.07 + node.phase) * node.orbitRadiusY;
          node.z = body.z + Math.sin(angle + node.phase) * node.zAmp;
          node.screen = projectPoint(node.x, node.y, node.z, centerX, centerY);
        });

        return { centerX: centerX, centerY: centerY };
      }

      var resizeObserver =
        typeof ResizeObserver === "function" ? new ResizeObserver(resizeCanvas) : null;
      if (resizeObserver) resizeObserver.observe(container);
      else window.addEventListener("resize", resizeCanvas);

      var size = resizeCanvas();
      var rafId = 0;
      var disposed = false;
      var startTime = performance.now();
      var categoryHotspots = [];
      var frameworkHotspots = [];

      function getPointerPosition(event) {
        var rect = canvas.getBoundingClientRect();
        return {
          x: event.clientX - rect.left,
          y: event.clientY - rect.top,
        };
      }

      function hitTestScene(position) {
        for (var i = frameworkHotspots.length - 1; i >= 0; i -= 1) {
          var fwHit = frameworkHotspots[i];
          var dxFw = position.x - fwHit.x;
          var dyFw = position.y - fwHit.y;
          if (dxFw * dxFw + dyFw * dyFw <= fwHit.radius * fwHit.radius) return fwHit;
        }
        for (var j = categoryHotspots.length - 1; j >= 0; j -= 1) {
          var catHit = categoryHotspots[j];
          var dxCat = position.x - catHit.x;
          var dyCat = position.y - catHit.y;
          if (dxCat * dxCat + dyCat * dyCat <= catHit.radius * catHit.radius) return catHit;
        }
        return null;
      }

      function handleSceneMove(event) {
        var hit = hitTestScene(getPointerPosition(event));
        canvas.style.cursor = hit ? "pointer" : "default";
      }

      function handleSceneLeave() {
        canvas.style.cursor = "default";
      }

      function handleSceneClick(event) {
        var hit = hitTestScene(getPointerPosition(event));
        if (!hit) {
          setSceneState({
            sceneSelectedCategory: null,
            sceneSelectedFramework: null,
          });
          return;
        }
        if (hit.type === "category") {
          var nextCategory = STATE.sceneSelectedCategory === hit.category ? null : hit.category;
          setSceneState({
            sceneSelectedCategory: nextCategory,
            sceneSelectedFramework: null,
          });
          return;
        }
        if (hit.type === "framework") {
          setSceneState({
            sceneSelectedCategory: hit.category,
            sceneSelectedFramework:
              STATE.sceneSelectedFramework === hit.key ? null : hit.key,
          });
        }
      }

      canvas.addEventListener("mousemove", handleSceneMove);
      canvas.addEventListener("mouseleave", handleSceneLeave);
      canvas.addEventListener("click", handleSceneClick);

      function cleanup() {
        disposed = true;
        if (rafId) window.cancelAnimationFrame(rafId);
        if (resizeObserver) resizeObserver.disconnect();
        else window.removeEventListener("resize", resizeCanvas);
        canvas.removeEventListener("mousemove", handleSceneMove);
        canvas.removeEventListener("mouseleave", handleSceneLeave);
        canvas.removeEventListener("click", handleSceneClick);
        canvas.style.cursor = "default";
      }
      window.__PF_SCENE_CLEANUP__ = cleanup;

      function drawFrame() {
        if (disposed) return;
        rafId = window.requestAnimationFrame(drawFrame);
        var liveSize = getSceneSize(container);
        if (liveSize.width !== size.width || liveSize.height !== size.height) size = resizeCanvas();
        else size = liveSize;
        if (!size.width || !size.height) return;

        var t = (performance.now() - startTime) * 0.001;
        var phase = STATE.sceneMode || "idle";
        var phaseHex = sceneHexString(phase);
        var depth = getConversationDepth();
        var highlights = getSceneHighlights();
        var activeCats = highlights.categories;
        var hasActiveCats = activeCats.size > 0;
        var selectedCategory = STATE.sceneSelectedCategory;
        var selectedFramework = STATE.sceneSelectedFramework;
        var matchedFrameworkKeys = new Set(
          (STATE.sceneFrameworks || [])
            .map(function(framework) { return framework.slug || framework.title; })
            .filter(Boolean)
        );
        var highlightedIndexes = new Set(findHighlightedFrameworkIndexes(fws, 18));
        var expandedFrameworkKeys = new Set(
          selectedCategory && frameworkKeysByCategory[selectedCategory]
            ? frameworkKeysByCategory[selectedCategory]
            : []
        );
        var center = updateBodies(t, size, depth);
        categoryHotspots = [];
        frameworkHotspots = [];

        ctx.clearRect(0, 0, size.width, size.height);

        var bg = ctx.createRadialGradient(
          center.centerX,
          center.centerY,
          0,
          center.centerX,
          center.centerY,
          Math.max(size.width, size.height) * 0.78
        );
        bg.addColorStop(0, getSceneRgba(phase, 0.22));
        bg.addColorStop(0.36, "rgba(16, 21, 45, 0.18)");
        bg.addColorStop(1, "rgba(2, 4, 12, 0)");
        ctx.fillStyle = bg;
        ctx.fillRect(0, 0, size.width, size.height);

        stars.forEach(function(star) {
          var sx = star.x * size.width + Math.sin(t * star.drift + star.phase) * 8 * star.depth;
          var sy = star.y * size.height + Math.cos(t * (star.drift * 0.8) + star.phase) * 5 * star.depth;
          var alpha = star.alpha * (0.72 + Math.sin(t * 1.4 + star.twinkle) * 0.28);
          ctx.fillStyle = "rgba(184, 194, 255, " + alpha.toFixed(3) + ")";
          ctx.beginPath();
          ctx.arc(sx, sy, star.size, 0, Math.PI * 2);
          ctx.fill();
        });

        categoryBodies.forEach(function(body) {
          var orbitX = Math.min(size.width * body.orbitXFactor, size.width * 0.42) + depth * 18;
          var orbitY = Math.min(size.height * body.orbitYFactor, size.height * 0.34) + depth * 14;
          ctx.save();
          ctx.translate(center.centerX, center.centerY);
          ctx.rotate(body.tilt * 0.45);
          ctx.strokeStyle = activeCats.has(body.cat)
            ? rgbaFromHex(body.color, 0.26)
            : "rgba(255,255,255,0.08)";
          ctx.lineWidth = activeCats.has(body.cat) ? 1.35 : 1;
          ctx.beginPath();
          ctx.ellipse(0, 0, orbitX, orbitY, 0, 0, Math.PI * 2);
          ctx.stroke();
          ctx.restore();
        });

        var nodeDrawList = frameworkNodes.slice().sort(function(a, b) {
          return a.z - b.z;
        });
        nodeDrawList.forEach(function(node) {
          var point = node.screen;
          var key = node.slug || node.title;
          var isMatched =
            matchedFrameworkKeys.has(node.slug) ||
            matchedFrameworkKeys.has(node.title);
          var isExpanded = expandedFrameworkKeys.has(key);
          var isHighlighted =
            highlightedIndexes.has(node.frameworkIndex) ||
            selectedFramework === key;
          var isActiveCat = activeCats.has(node.category) || selectedCategory === node.category;
          var alpha = selectedCategory
            ? isExpanded
              ? isHighlighted
                ? 1
                : 0.94
              : 0.08
            : hasActiveCats && !isActiveCat
              ? 0.18
              : isMatched
                ? 0.94
                : 0.62;
          var radius = (
            selectedCategory
              ? isExpanded
                ? isHighlighted
                  ? 4.9
                  : 3.7
                : 1.4
              : isMatched
                ? 3.8
                : 2.05
          ) * point.scale + node.size;

          ctx.fillStyle = rgbaFromHex(node.color, alpha);
          ctx.beginPath();
          ctx.arc(point.x, point.y, radius, 0, Math.PI * 2);
          ctx.fill();

          if (isMatched || isExpanded) {
            ctx.strokeStyle = getSceneRgba(phase, 0.42);
            ctx.lineWidth = 1.15;
            ctx.beginPath();
            ctx.arc(point.x, point.y, radius + 5, 0, Math.PI * 2);
            ctx.stroke();
          }

          if (isExpanded || isMatched) {
            frameworkHotspots.push({
              type: "framework",
              key: key,
              category: node.category,
              x: point.x,
              y: point.y,
              radius: Math.max(12, radius + 8),
            });
          }
        });

        categoryBodies
          .slice()
          .sort(function(a, b) { return a.z - b.z; })
          .forEach(function(body) {
            var point = body.screen;
            var isActive = activeCats.has(body.cat) || selectedCategory === body.cat;
            var coreRadius = (isActive ? 9.6 : 7.2) * point.scale + body.size;
            ctx.strokeStyle = isActive ? getSceneRgba(phase, 0.34) : "rgba(255,255,255,0.1)";
            ctx.lineWidth = isActive ? 1.6 : 1;
            ctx.beginPath();
            ctx.moveTo(center.centerX, center.centerY);
            ctx.lineTo(point.x, point.y);
            ctx.stroke();

            ctx.fillStyle = rgbaFromHex(body.color, isActive ? 1 : hasActiveCats ? 0.74 : 0.88);
            ctx.beginPath();
            ctx.arc(point.x, point.y, coreRadius, 0, Math.PI * 2);
            ctx.fill();

            ctx.fillStyle = rgbaFromHex(body.color, isActive ? 0.22 : 0.12);
            ctx.beginPath();
            ctx.arc(point.x, point.y, coreRadius + 8, 0, Math.PI * 2);
            ctx.fill();

            drawScenePill(
              ctx,
              point.x,
              point.y - coreRadius - 16,
              body.label,
              body.color,
              {
                fontSize: isActive ? 11 : 10,
                padX: isActive ? 11 : 9,
                padY: 5,
                glow: isActive ? 14 : 0,
                stroke: isActive ? rgbaFromHex(body.color, 0.7) : rgbaFromHex(body.color, 0.34),
                fill: isActive ? "rgba(5, 9, 20, 0.9)" : "rgba(5, 9, 20, 0.76)",
              }
            );
            categoryHotspots.push({
              type: "category",
              category: body.cat,
              x: point.x,
              y: point.y,
              radius: Math.max(22, coreRadius + 18),
            });
          });

        var hubPulse = 1 + Math.sin(t * 1.9) * 0.08;
        ctx.save();
        ctx.translate(center.centerX, center.centerY);
        [72, 116, 164].forEach(function(radius, index) {
          ctx.save();
          ctx.rotate(t * (0.08 + index * 0.03) * (index % 2 === 0 ? 1 : -1));
          ctx.strokeStyle = getSceneRgba(phase, 0.18 - index * 0.03);
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.ellipse(0, 0, radius, radius * (0.64 + index * 0.08), 0, 0, Math.PI * 2);
          ctx.stroke();
          ctx.restore();
        });
        ctx.fillStyle = getSceneRgba(phase, 0.18);
        ctx.beginPath();
        ctx.arc(0, 0, 28 * hubPulse, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = getSceneRgba(phase, 1);
        ctx.beginPath();
        ctx.arc(0, 0, 9.5 * hubPulse, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();

        frameworkNodes.forEach(function(node) {
          var key = node.slug || node.title;
          var shouldLabel = selectedCategory
            ? expandedFrameworkKeys.has(key)
            : matchedFrameworkKeys.has(node.slug) || matchedFrameworkKeys.has(node.title);
          if (!shouldLabel) return;
          drawScenePill(
            ctx,
            node.screen.x,
            node.screen.y - (14 + node.screen.scale * 8),
            node.title,
            node.color,
            {
              fontSize: 9,
              padX: 8,
              padY: 4,
              radius: 999,
              stroke: rgbaFromHex(node.color, 0.42),
              fill: "rgba(4, 8, 20, 0.82)",
            }
          );
        });
      }

      drawFrame();
    }, 36);
  }

  function waitForSceneBox(container, onReady, retries) {
    const size = getSceneSize(container);
    if ((size.width > 40 && size.height > 40) || retries <= 0) {
      onReady(size);
      return;
    }
    window.requestAnimationFrame(() => waitForSceneBox(container, onReady, retries - 1));
  }

  function initScene(THREE, fws) {
    const canvas = document.getElementById("pfCanvas");
    const labelsEl = document.getElementById("pfAgentLabels");
    if (!canvas || !canvas.parentElement || !labelsEl) return;
    const container = canvas.parentElement;

    waitForSceneBox(container, (initialSize) => {
      try {
        labelsEl.innerHTML = "";

        const renderer = new THREE.WebGLRenderer({
          canvas,
          antialias: true,
          alpha: true,
          powerPreference: "high-performance",
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
        renderer.setClearColor(0x000000, 0);
        renderer.setSize(initialSize.width, initialSize.height, false);

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(
          58,
          initialSize.width / Math.max(initialSize.height, 1),
          0.1,
          100
        );
        camera.position.set(0, 2.2, 14);
        camera.lookAt(0, 0, 0);

        scene.add(new THREE.AmbientLight(0x223355, 1.05));
        const pointLight = new THREE.PointLight(0x00d4ff, 3.2, 20);
        pointLight.position.set(0, 0, 4.5);
        scene.add(pointLight);
        const phaseLight = new THREE.PointLight(0x00d4ff, 1.8, 22);
        phaseLight.position.set(0, 0, 2.5);
        scene.add(phaseLight);

        const starPos = new Float32Array(2400);
        for (let i = 0; i < 2400; i += 1) starPos[i] = (Math.random() - 0.5) * 70;
        const starGeo = new THREE.BufferGeometry();
        starGeo.setAttribute("position", new THREE.BufferAttribute(starPos, 3));
        const stars = new THREE.Points(
          starGeo,
          new THREE.PointsMaterial({
            color: 0xa7b7ff,
            size: 0.045,
            transparent: true,
            opacity: 0.75,
          })
        );
        scene.add(stars);

        const hub = new THREE.Mesh(
          new THREE.SphereGeometry(0.58, 32, 32),
          new THREE.MeshPhongMaterial({
            color: 0x00d4ff,
            emissive: 0x0082b6,
            emissiveIntensity: 0.95,
            shininess: 140,
          })
        );
        scene.add(hub);

        const rings = [
          { r: 1.0, tube: 0.018, tilt: [0, 0, 0], speed: 0.004, color: 0x00d4ff },
