        var catAngle = catAngles2D[fw.category] || 0;
        var catGroup = fws.filter(function(f) { return f.category === fw.category; });
        var inIdx = catGroup.indexOf(fw);
        var spread = 0.34 + (inIdx / Math.max(catGroup.length, 1)) * 0.72;
        return {
          slug: fw.slug,
          title: fw.title,
          category: fw.category,
          clusterRadius: 34 + spread * 52,
          clusterAngle: catAngle + (inIdx - catGroup.length / 2) * 0.22,
          vertical: ((inIdx % 7) - 3) * 12,
          phase: Math.random() * Math.PI * 2,
          wave: 0.7 + Math.random() * 0.55,
          wobble: 0.54 + (inIdx % 7) * 0.08,
          color: CAT_COL[fw.category] || DEF_COL,
