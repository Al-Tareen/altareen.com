---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const EXCLUDED = new Set(["Business Plans", "Financial Models", "TBA"]);
const all = await getCollection("toolkit");
const frameworks = all
  .filter(
    (item) =>
      item.data.dbTitle === "Frameworks" &&
      !EXCLUDED.has((item.data.primaryCategory ?? "").trim())
  )
  .map((item) => ({
    slug: item.slug,
    title: item.data.title ?? "",
    category: (item.data.primaryCategory ?? "").trim(),
    whenToUse: item.data.whenToUse ?? "",
    whenToUseFull: item.data.whenToUseFull ?? "",
    inputsRequired: item.data.inputsRequired ?? "",
    outputArtifact: item.data.outputArtifact ?? "",
    commonMistakes: item.data.commonMistakes ?? "",
    tags: (item.data.tags ?? []).join(", "),
  }));

const frameworksJson = JSON.stringify(frameworks);
---

<BaseLayout
  title="Prodforce — PM Framework Intelligence"
  description="Multi-agent AI that matches your product management challenge to the right framework and synthesizes expert analysis."
  immersive={true}
>
  <main class="pf-app" role="main" aria-label="Prodforce PM Intelligence">
    <!-- 3D Scene panel -->
    <div class="pf-scene" aria-hidden="true">
      <canvas id="pfCanvas"></canvas>
      <div class="pf-agent-labels" id="pfAgentLabels"></div>
      <div class="pf-scene-hud" id="pfSceneHud"></div>
      <div class="pf-scene-gradient"></div>
      <div class="pf-scene-progress" id="pfSceneProgress"></div>
      <div class="pf-scene-brand">
        <span class="pf-brand-wordmark">PRODFORCE</span>
        <span class="pf-brand-sub">Multi-Agent PM Intelligence</span>
      </div>
    </div>

    <!-- Chat panel -->
    <div class="pf-chat" role="region" aria-label="Chat interface">
      <div class="pf-chat-head">
        <div class="pf-head-left">
          <div class="pf-status-dot" id="pfStatusDot"></div>
          <span class="pf-head-title">PRODFORCE</span>
        </div>
      </div>

      <div class="pf-messages" id="pfMessages" role="log" aria-live="polite"></div>

      <div class="pf-suggestions" id="pfSuggestions" aria-label="Suggested questions"></div>

      <div class="pf-input-area">
        <div class="pf-file-badge" id="pfFileBadge" style="display:none">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span id="pfFileName"></span>
          <button class="pf-file-remove" id="pfFileRemove" aria-label="Remove file">×</button>
        </div>

        <div class="pf-input-bar">
          <button class="pf-attach-btn" id="pfAttachBtn" aria-label="Attach file" title="Attach PDF, TXT, MD, CSV, or JSON">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
          </button>

          <textarea
            id="pfTextarea"
            class="pf-textarea"
            placeholder="What decision are you working through?"
            rows="1"
            maxlength="4000"
            aria-label="Message input"
          ></textarea>

          <button class="pf-send-btn" id="pfSendBtn" aria-label="Send message" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
      </div>

      <input type="file" id="pfFileInput" accept=".pdf,.txt,.md,.csv,.json" style="display:none" aria-hidden="true" />
    </div>
  </main>
</BaseLayout>

<style>
/* ─── App shell ───────────────────────────────────────────────────────────── */
.pf-app {
  display: flex;
  min-height: 100dvh;
  height: 100dvh;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(0,212,255,0.08), transparent 28%),
    radial-gradient(circle at top right, rgba(99,102,241,0.08), transparent 24%),
    #08080f;
  --pf-bg: #08080f;
  --pf-bg-2: #0d0d1a;
  --pf-text: #ddddf0;
  --pf-text-muted: #99a0d7;
  --pf-border: rgba(255,255,255,0.07);
  --pf-border-strong: rgba(255,255,255,0.13);
  --pf-accent: #00d4ff;
  --pf-accent-dim: rgba(0,212,255,0.12);
  --pf-glass: rgba(255,255,255,0.04);
  --pf-glass-hover: rgba(255,255,255,0.07);
}

/* ─── 3D Scene ────────────────────────────────────────────────────────────── */
.pf-scene {
  position: relative;
  flex: 0 0 58%;
  overflow: hidden;
  background: #06060e;
  isolation: isolate;
}
.pf-scene::before,
.pf-scene::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.pf-scene::before {
  background:
    radial-gradient(circle at 28% 26%, rgba(0,212,255,0.22), transparent 34%),
    radial-gradient(circle at 72% 34%, rgba(99,102,241,0.16), transparent 28%),
    radial-gradient(circle at 50% 68%, rgba(16,185,129,0.11), transparent 26%);
  opacity: 0.95;
  animation: pfSceneGlow 10s ease-in-out infinite alternate;
}
.pf-scene::after {
  background:
    repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.02) 0,
      rgba(255,255,255,0.02) 1px,
      transparent 1px,
      transparent 84px
    );
  opacity: 0.35;
  mix-blend-mode: screen;
}
#pfCanvas {
  position: absolute;
  inset: 0;
  display: block;
  width: 100%;
  height: 100%;
  z-index: 1;
}
/* Scene progress bar */
.pf-scene-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4px;
  z-index: 5;
  pointer-events: none;
  background: rgba(255,255,255,0.04);
  overflow: hidden;
}
.pf-scene-progress:empty { background: transparent; }
.pf-scene-progress-fill {
  height: 100%;
  width: 0%;
  border-radius: 0 2px 2px 0;
  transition: width 0.5s ease, background 0.5s ease;
  box-shadow: 0 0 12px var(--bar-glow, rgba(0,212,255,0.3));
}
.pf-agent-labels {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 4;
}
.pf-agent-label {
  position: absolute;
  top: 0; left: 0;
  transform-origin: 0 0;
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--ag-color, #fff);
  padding: 3px 7px;
  border: 1px solid var(--ag-color, rgba(255,255,255,0.2));
  border-radius: 4px;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
  pointer-events: none;
  transition: opacity 0.3s;
  white-space: nowrap;
}
.pf-scene-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, transparent 70%, #08080f 100%);
  pointer-events: none;
  z-index: 3;
}
.pf-scene-brand {
  position: absolute;
  bottom: 28px;
  left: 28px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  z-index: 4;
}
.pf-brand-wordmark {
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 4px;
  color: var(--pf-accent);
  text-transform: uppercase;
}
.pf-brand-sub {
  font-family: var(--font-sans);
  font-size: 11px;
  color: var(--pf-text-muted);
  letter-spacing: 0.5px;
}

/* ─── Chat panel ──────────────────────────────────────────────────────────── */
.pf-chat {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-left: 1px solid var(--pf-border);
  background:
    linear-gradient(180deg, rgba(10,12,24,0.96), rgba(7,8,16,0.98)),
    var(--pf-bg);
}

/* Header bar */
.pf-chat-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 18px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));
  flex-shrink: 0;
}
.pf-head-left { display: flex; align-items: center; gap: 10px; }
.pf-status-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #10b981;
  box-shadow: 0 0 8px #10b981;
  animation: pfPulse 2s ease-in-out infinite;
}
.pf-status-dot.pf-active {
  background: var(--pf-accent);
  box-shadow: 0 0 10px var(--pf-accent);
}
@keyframes pfPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
@keyframes pfSceneGlow {
  from { transform: scale(1) translate3d(0, 0, 0); opacity: 0.82; }
  to { transform: scale(1.06) translate3d(-1.5%, -1%, 0); opacity: 1; }
}
.pf-head-title {
  font-family: var(--font-sans);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 3px;
  color: var(--pf-text);
}
.pf-fw-count {
  font-family: var(--font-sans);
  font-size: 11px;
  color: var(--pf-text-muted);
}


/* Messages */
.pf-messages {
  flex: 1;
  overflow-y: auto;
  padding: 28px 20px 20px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  scroll-behavior: smooth;
  background:
    radial-gradient(circle at top center, rgba(0,212,255,0.05), transparent 30%),
    transparent;
}
.pf-messages::-webkit-scrollbar { width: 4px; }
.pf-messages::-webkit-scrollbar-track { background: transparent; }
.pf-messages::-webkit-scrollbar-thumb { background: var(--pf-border-strong); border-radius: 2px; }

/* Messages */
.pf-msg { display: flex; flex-direction: column; gap: 6px; }
.pf-msg-role {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
}
.pf-msg-user .pf-msg-role { color: var(--pf-accent); text-align: right; }
.pf-msg-assistant .pf-msg-role { color: #8b5cf6; }

.pf-msg-bubble {
  padding: 14px 16px;
  border-radius: 12px;
  font-size: 14px;
  line-height: 1.65;
  color: var(--pf-text);
  max-width: 100%;
}
.pf-msg-user .pf-msg-bubble {
  background: var(--pf-accent-dim);
  border: 1px solid rgba(0,212,255,0.2);
  align-self: flex-end;
  max-width: 85%;
}
.pf-msg-assistant .pf-msg-bubble {
  background: var(--pf-glass);
  border: 1px solid var(--pf-border);
}

/* Markdown rendering */
.pf-msg-bubble h1, .pf-msg-bubble h2, .pf-msg-bubble h3 {
  color: var(--pf-text);
  margin: 14px 0 6px;
  font-family: var(--font-sans);
}
.pf-msg-bubble h1 { font-size: 17px; font-weight: 700; }
.pf-msg-bubble h2 { font-size: 15px; font-weight: 700; border-bottom: 1px solid var(--pf-border); padding-bottom: 6px; }
.pf-msg-bubble h3 { font-size: 14px; font-weight: 600; color: var(--pf-accent); }
.pf-msg-bubble p { margin: 8px 0; }
.pf-msg-bubble ul, .pf-msg-bubble ol { padding-left: 18px; margin: 8px 0; }
.pf-msg-bubble li { margin: 5px 0; }
.pf-msg-bubble strong { color: #fff; font-weight: 700; }
.pf-msg-bubble em { color: #c4c4e0; font-style: italic; }
.pf-msg-bubble code {
  font-family: 'Menlo', monospace;
  font-size: 12px;
  background: rgba(255,255,255,0.08);
  padding: 1px 5px;
  border-radius: 4px;
  color: var(--pf-accent);
}
.pf-msg-bubble pre {
  background: rgba(0,0,0,0.4);
  border: 1px solid var(--pf-border);
  border-radius: 8px;
  padding: 12px;
  overflow-x: auto;
  margin: 10px 0;
}
.pf-msg-bubble pre code { background: none; padding: 0; color: #aaddff; }
.pf-msg-bubble hr { border: none; border-top: 1px solid var(--pf-border); margin: 14px 0; }

/* Streaming cursor */
.pf-cursor {
  display: inline-block;
  width: 2px;
  height: 1em;
  background: var(--pf-accent);
  margin-left: 2px;
  vertical-align: text-bottom;
  animation: pfBlink 1s step-end infinite;
}
@keyframes pfBlink { 50% { opacity: 0; } }

/* PDF download button */
.pf-pdf-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 14px;
  padding: 7px 14px;
  font-size: 12px;
  font-weight: 600;
  font-family: var(--font-sans);
  color: var(--pf-accent);
  background: var(--pf-accent-dim);
  border: 1px solid rgba(0,212,255,0.25);
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.2s, opacity 0.2s;
}
.pf-pdf-btn:hover { background: rgba(0,212,255,0.2); }

/* Pipeline status */
.pf-pipeline {
  padding: 16px;
  background: var(--pf-glass);
  border: 1px solid var(--pf-border);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.pf-pipeline-steps {
  display: flex;
  align-items: center;
  gap: 8px;
}
.pf-pipeline-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  flex: 1;
}
.pf-step-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.2);
  transition: all 0.3s;
}
.pf-pipeline-step.is-active .pf-step-dot {
  background: var(--pf-accent);
  box-shadow: 0 0 10px var(--pf-accent);
  animation: pfPulse 1s ease-in-out infinite;
}
.pf-pipeline-step.is-done .pf-step-dot {
  background: #10b981;
  box-shadow: 0 0 8px #10b981;
}
.pf-step-label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--pf-text-muted);
}
.pf-pipeline-step.is-active .pf-step-label { color: var(--pf-accent); }
.pf-pipeline-step.is-done .pf-step-label { color: #10b981; }
.pf-pipeline-arrow { color: var(--pf-text-muted); font-size: 12px; }
.pf-pipeline-status-msg {
  font-size: 12px;
  color: var(--pf-text-muted);
  font-style: italic;
}

/* Framework cards */
.pf-fw-cards {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.pf-fw-card {
  padding: 12px 14px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--pf-border);
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  animation: pfSlideIn 0.3s ease;
}
@keyframes pfSlideIn {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}
.pf-fw-card-head { display: flex; align-items: center; gap: 8px; }
.pf-fw-cat {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--pf-accent);
  padding: 2px 7px;
  background: var(--pf-accent-dim);
  border-radius: 4px;
}
.pf-fw-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--pf-text);
}
.pf-fw-reason {
  font-size: 12px;
  color: var(--pf-text-muted);
  line-height: 1.5;
}

/* Specialist progress */
.pf-specialists-progress {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.pf-specialist-tag {
  font-size: 11px;
  padding: 4px 10px;
  border-radius: 20px;
  border: 1px solid var(--pf-border);
  color: var(--pf-text-muted);
  display: flex;
  align-items: center;
  gap: 5px;
  transition: all 0.2s;
}
.pf-specialist-tag.is-running {
  border-color: rgba(0,212,255,0.3);
  color: var(--pf-accent);
  background: var(--pf-accent-dim);
}
.pf-specialist-tag.is-done {
  border-color: rgba(16,185,129,0.3);
  color: #10b981;
  background: rgba(16,185,129,0.08);
}

/* Error message */
.pf-msg-error {
  padding: 12px 16px;
  background: rgba(239,68,68,0.08);
  border: 1px solid rgba(239,68,68,0.2);
  border-radius: 10px;
  color: #f87171;
  font-size: 13px;
}

/* Suggestions */
.pf-suggestions {
  display: none;
  flex-wrap: wrap;
  gap: 8px;
  padding: 16px 20px 14px;
  border-top: 1px solid rgba(255,255,255,0.06);
  flex-shrink: 0;
  background:
    linear-gradient(180deg, rgba(8,10,20,0.96), rgba(8,10,20,0.99)),
    radial-gradient(circle at left top, rgba(0,212,255,0.05), transparent 24%);
}
.pf-chip {
  font-family: var(--font-sans);
  font-size: 12px;
  padding: 8px 14px;
  background: rgba(12,17,36,0.88);
  border: 1px solid rgba(98,115,214,0.34);
  border-radius: 20px;
  color: #c7cbf7;
  cursor: pointer;
  transition: all 0.2s;
  text-align: left;
  line-height: 1.35;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
}
.pf-chip:hover {
  background: rgba(0,212,255,0.16);
  border-color: rgba(0,212,255,0.38);
  color: #eff9ff;
  transform: translateY(-1px);
}

/* Input area */
.pf-input-area {
  padding: 12px 16px 16px;
  border-top: 1px solid rgba(255,255,255,0.06);
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex-shrink: 0;
  background: linear-gradient(180deg, rgba(8,10,20,0.98), rgba(7,8,16,1));
}
.pf-file-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  background: var(--pf-accent-dim);
  border: 1px solid rgba(0,212,255,0.2);
  border-radius: 8px;
  font-size: 12px;
  color: var(--pf-accent);
}
.pf-file-badge svg { flex-shrink: 0; }
.pf-file-badge span { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.pf-file-remove {
  background: none;
  border: none;
  color: var(--pf-accent);
  cursor: pointer;
  font-size: 16px;
  padding: 0 2px;
  line-height: 1;
  opacity: 0.7;
}
.pf-file-remove:hover { opacity: 1; }
.pf-input-bar {
  display: flex;
  align-items: flex-end;
  gap: 8px;
  background: rgba(17,18,28,0.95);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 18px;
  padding: 10px 12px;
  transition: border-color 0.2s, box-shadow 0.2s;
  box-shadow: 0 18px 48px rgba(0,0,0,0.22);
}
.pf-input-bar:focus-within {
  border-color: rgba(0,212,255,0.35);
  box-shadow: 0 18px 48px rgba(0,0,0,0.22), 0 0 0 1px rgba(0,212,255,0.1);
}
.pf-attach-btn {
  flex-shrink: 0;
  background: none;
  border: none;
  color: var(--pf-text-muted);
  cursor: pointer;
  padding: 6px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  transition: color 0.2s, background 0.2s;
}
.pf-attach-btn:hover { color: var(--pf-accent); background: var(--pf-accent-dim); }
.pf-textarea {
  flex: 1;
  background: none;
  border: none;
  outline: none;
  resize: none;
  font-family: var(--font-sans);
  font-size: 14px;
  color: var(--pf-text);
  line-height: 1.5;
  min-height: 24px;
  max-height: 120px;
  overflow-y: auto;
  padding: 4px 0;
}
.pf-textarea::placeholder { color: var(--pf-text-muted); }
.pf-send-btn {
  flex-shrink: 0;
  width: 36px; height: 36px;
  border-radius: 10px;
  background: var(--pf-accent);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000;
  transition: opacity 0.2s, transform 0.1s;
}
.pf-send-btn:disabled { opacity: 0.3; cursor: not-allowed; }
.pf-send-btn:not(:disabled):hover { opacity: 0.85; transform: scale(1.04); }

/* ─── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .pf-scene { flex: 0 0 45%; }
}
@media (max-width: 720px) {
  .pf-app {
    flex-direction: column;
    height: 100dvh;
  }
  .pf-scene {
    flex: 0 0 38vh;
    border-right: none;
    border-bottom: 1px solid var(--pf-border);
  }
  .pf-scene-gradient {
    background: linear-gradient(to bottom, transparent 60%, #08080f 100%);
  }
  .pf-chat { flex: 1; }
  .pf-progress-head {
    flex-direction: column;
    gap: 8px;
  }
  .pf-progress-stages {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
@media (max-width: 480px) {
  .pf-scene { flex: 0 0 32vh; }
  .pf-messages { padding: 16px 14px; }
  .pf-input-area { padding: 10px 12px 14px; }
}
</style>

<style is:global>
:root {
  color-scheme: dark;
}
html,
body {
  background: #06060e;
}
.pf-scene-hud {
  position: absolute;
  top: 22px;
  left: 22px;
  width: min(360px, calc(100% - 56px));
  z-index: 4;
  pointer-events: none;
}
.pf-scene-hud-standby-pill {
  display: inline-flex;
  align-items: center;
