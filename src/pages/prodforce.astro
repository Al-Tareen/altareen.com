    const labelsEl = document.getElementById("pfAgentLabels");
    if (!canvas || !canvas.parentElement || !labelsEl) return;
    const container = canvas.parentElement;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    waitForSceneBox(container, () => {
      labelsEl.innerHTML = "";

      var CAT_COL = buildCategoryPalette(fws, false);
      var DEF_COL = "#97a1ff";
      const ratio = () => Math.min(window.devicePixelRatio || 1, 2);

      // Group frameworks by category for clustered layout
      var ALL_CATS_2D = dedupeList(
        fws.map(function(fw) { return fw.category; }).filter(Boolean).concat(Object.keys(CAT_COL))
      );
      var catAngles2D = {};
      ALL_CATS_2D.forEach(function(cat, ci) {
