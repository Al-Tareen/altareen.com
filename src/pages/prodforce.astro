  vertical-align: text-bottom;
  animation: pfBlink 1s step-end infinite;
}
.pf-pdf-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 14px;
  padding: 7px 14px;
  font-size: 12px;
  font-weight: 600;
  font-family: var(--font-sans);
  color: #00d4ff;
  background: rgba(0,212,255,0.12);
  border: 1px solid rgba(0,212,255,0.25);
