}
.pf-pdf-btn:hover { background: rgba(0,212,255,0.2); }
.pf-pipeline {
  padding: 16px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.pf-pipeline-steps {
  display: flex;
  align-items: center;
  gap: 8px;
}
.pf-pipeline-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  flex: 1;
}
.pf-step-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.2);
  transition: all 0.3s;
}
.pf-pipeline-step.is-active .pf-step-dot {
  background: #00d4ff;
  box-shadow: 0 0 10px #00d4ff;
  animation: pfPulse 1s ease-in-out infinite;
}
.pf-pipeline-step.is-done .pf-step-dot {
  background: #10b981;
  box-shadow: 0 0 8px #10b981;
}
.pf-step-label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #99a0d7;
}
.pf-pipeline-step.is-active .pf-step-label { color: #00d4ff; }
.pf-pipeline-step.is-done .pf-step-label { color: #10b981; }
.pf-pipeline-arrow { color: #99a0d7; font-size: 12px; }
.pf-pipeline-status-msg {
  font-size: 12px;
  color: #99a0d7;
  font-style: italic;
}
.pf-fw-cards {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.pf-fw-card {
  padding: 12px 14px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  animation: pfSlideIn 0.3s ease;
}
.pf-fw-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  flex-wrap: wrap;
}
.pf-fw-cat {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #00d4ff;
  padding: 2px 7px;
  background: rgba(0,212,255,0.12);
  border-radius: 4px;
}
.pf-fw-title {
  font-size: 13px;
  font-weight: 700;
  color: #ddddf0;
}
.pf-fw-readiness {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.3px;
  padding: 4px 8px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.05);
  color: #d3d9ff;
}
.pf-fw-readiness.is-high {
  color: #8ef3c0;
  border-color: rgba(16,185,129,0.25);
  background: rgba(16,185,129,0.12);
}
.pf-fw-readiness.is-medium {
  color: #ffd48c;
  border-color: rgba(245,158,11,0.22);
  background: rgba(245,158,11,0.12);
}
.pf-fw-readiness.is-low {
  color: #ffb4b4;
  border-color: rgba(239,68,68,0.22);
  background: rgba(239,68,68,0.1);
}
.pf-fw-reason {
  font-size: 12px;
  color: #99a0d7;
  line-height: 1.5;
}
.pf-fw-meta {
  font-size: 11px;
  color: #cbd0f6;
  line-height: 1.55;
  padding: 8px 10px;
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.025);
}
.pf-fw-section {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.pf-fw-section-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: rgba(210,218,255,0.62);
}
.pf-fw-output-card {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 12px;
  border: 1px solid rgba(0,212,255,0.12);
  background:
    linear-gradient(180deg, rgba(10,16,34,0.88), rgba(8,12,24,0.64)),
    radial-gradient(circle at top left, rgba(0,212,255,0.08), transparent 60%);
}
.pf-fw-output-title {
  font-size: 12px;
  line-height: 1.55;
  color: #e2e8ff;
}
.pf-fw-preview {
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.03);
  min-height: 64px;
}
.pf-fw-preview.is-matrix {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
  padding: 8px;
}
.pf-fw-preview.is-matrix span,
.pf-fw-preview.is-experiment span {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 22px;
  border-radius: 8px;
  border: 1px solid rgba(0,212,255,0.16);
  background: rgba(0,212,255,0.07);
  font-size: 10px;
  color: #d7e8ff;
}
.pf-fw-preview.is-scorecard {
  display: grid;
  gap: 8px;
  padding: 10px;
}
.pf-fw-bar {
  height: 10px;
  border-radius: 999px;
  background: rgba(255,255,255,0.06);
  overflow: hidden;
}
.pf-fw-bar span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, rgba(0,212,255,0.32), rgba(16,185,129,0.55));
}
.pf-fw-bar:nth-child(1) span { width: 82%; }
.pf-fw-bar:nth-child(2) span { width: 66%; }
.pf-fw-bar:nth-child(3) span { width: 48%; }
.pf-fw-preview.is-roadmap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 14px 10px;
}
.pf-fw-preview.is-roadmap span {
  position: relative;
  flex: 1;
  height: 2px;
  background: rgba(0,212,255,0.18);
}
.pf-fw-preview.is-roadmap span::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #00d4ff;
  box-shadow: 0 0 14px rgba(0,212,255,0.32);
  transform: translate(-50%, -50%);
}
.pf-fw-preview.is-metrics {
  display: grid;
  gap: 10px;
  padding: 12px;
}
.pf-fw-metric-node {
  width: 48%;
  height: 14px;
  border-radius: 999px;
  background: rgba(16,185,129,0.24);
  border: 1px solid rgba(16,185,129,0.28);
}
.pf-fw-metric-branch {
  display: flex;
  gap: 8px;
}
.pf-fw-metric-branch span {
  flex: 1;
  height: 12px;
  border-radius: 999px;
  background: rgba(99,102,241,0.18);
  border: 1px solid rgba(99,102,241,0.22);
}
.pf-fw-preview.is-playbook {
  display: grid;
  gap: 8px;
  padding: 10px 12px;
}
.pf-fw-preview.is-playbook span,
.pf-fw-preview.is-memo span {
  display: block;
  height: 8px;
  border-radius: 999px;
  background: rgba(255,255,255,0.08);
}
.pf-fw-preview.is-playbook span::before {
  content: "";
  display: inline-block;
  width: 8px;
  height: 8px;
  margin-right: 8px;
  border-radius: 50%;
  background: rgba(16,185,129,0.75);
}
.pf-fw-preview.is-experiment {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  padding: 10px;
}
.pf-fw-preview.is-memo {
  display: grid;
  gap: 8px;
  padding: 10px 12px;
}
.pf-fw-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.pf-fw-chip {
  display: inline-flex;
  align-items: center;
  padding: 4px 8px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 600;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04);
  color: #dde3ff;
}
.pf-fw-chip.is-required {
  color: #c7f4ff;
  border-color: rgba(0,212,255,0.2);
  background: rgba(0,212,255,0.1);
}
.pf-fw-chip.is-present {
  color: #8ef3c0;
  border-color: rgba(16,185,129,0.22);
  background: rgba(16,185,129,0.1);
}
.pf-fw-chip.is-missing {
  color: #ffd48c;
  border-color: rgba(245,158,11,0.22);
  background: rgba(245,158,11,0.12);
}
.pf-fw-empty {
  font-size: 11px;
  color: rgba(210,218,255,0.56);
  line-height: 1.45;
}
.pf-fw-warning {
  font-size: 11px;
  line-height: 1.5;
  color: #f7c98d;
  padding-top: 4px;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.pf-specialists-progress {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.pf-specialist-tag {
  font-size: 11px;
  padding: 4px 10px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.07);
  color: #99a0d7;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: all 0.2s;
}
.pf-specialist-tag.is-running {
  border-color: rgba(0,212,255,0.3);
  color: #00d4ff;
  background: rgba(0,212,255,0.12);
}
.pf-specialist-tag.is-done {
  border-color: rgba(16,185,129,0.3);
  color: #10b981;
  background: rgba(16,185,129,0.08);
}
.pf-msg-error {
  padding: 12px 16px;
  background: rgba(239,68,68,0.08);
  border: 1px solid rgba(239,68,68,0.2);
  border-radius: 10px;
  color: #f87171;
  font-size: 13px;
}
.pf-suggestions {
  display: none;
  flex-wrap: wrap;
  gap: 8px;
  padding: 12px 20px 14px;
  border-top: 1px solid rgba(255,255,255,0.07);
  flex-shrink: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(0,212,255,0.035));
}
.pf-chip {
  font-family: var(--font-sans);
  font-size: 12px;
  padding: 8px 14px;
  background: rgba(12,17,36,0.88);
  border: 1px solid rgba(98,115,214,0.34);
  border-radius: 20px;
  color: #c7cbf7;
  cursor: pointer;
  transition: all 0.2s;
  text-align: left;
  line-height: 1.35;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
}
.pf-chip:hover {
  background: rgba(0,212,255,0.16);
  border-color: rgba(0,212,255,0.38);
  color: #eff9ff;
  transform: translateY(-1px);
}
.pf-chip-label {
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #94a1df;
  width: 100%;
  padding: 0 2px 2px;
}
.pf-chip-label.is-positive {
  color: #10b981;
}
.pf-chip-label.is-warning {
  color: #f59e0b;
}
.pf-chip-orange {
  background: rgba(245, 158, 11, 0.12) !important;
  border-color: rgba(245, 158, 11, 0.35) !important;
  color: #fbbf24 !important;
}
.pf-chip-orange:hover {
  background: rgba(245, 158, 11, 0.22) !important;
  border-color: rgba(245, 158, 11, 0.5) !important;
  color: #fde68a !important;
  transform: translateY(-1px);
}
.pf-chip-reply {
  background: rgba(16, 185, 129, 0.1) !important;
  border-color: rgba(16, 185, 129, 0.3) !important;
  color: #a7f3d0 !important;
}
.pf-chip-reply:hover {
  background: rgba(16, 185, 129, 0.16) !important;
  border-color: rgba(16, 185, 129, 0.42) !important;
  color: #ecfdf5 !important;
}
.pf-chip-green {
  background: rgba(34, 197, 94, 0.12) !important;
  border-color: rgba(34, 197, 94, 0.32) !important;
  color: #bbf7d0 !important;
}
.pf-chip-green:hover {
  background: rgba(34, 197, 94, 0.18) !important;
  border-color: rgba(34, 197, 94, 0.45) !important;
  color: #f0fdf4 !important;
}
@media (max-width: 720px) {
  .pf-scene-hud {
    top: 14px;
    left: 14px;
    width: calc(100% - 28px);
  }
  .pf-scene-hud-card {
    padding: 14px;
  }
}
</style>

<!-- Pass frameworks to client -->
<script is:inline define:vars={{ frameworksJson }}>
  window.__PF_FRAMEWORKS__ = JSON.parse(frameworksJson);
</script>

<script is:inline>
var DEFAULT_SUGGESTIONS = [
  "We have 3 competing bets for next quarter — how do I evaluate them?",
  "Churn spiked after our latest release. How do I diagnose it?",
  "We're launching an AI feature — what go-to-market framework fits?",
  "Sales wants 6 roadmap items for one strategic account. How should I rank them?",
  "My team cannot align on the product vision. Where should we start?",
  "Adoption is flat after launch. Which framework should I use first?",
  "We need success metrics for a platform with multiple user types.",
  "We are entering a new segment. How do we decide positioning?",
  "Should we build an RFP workflow feature for enterprise deals?",
  "Onboarding conversion dropped after the redesign. How should I investigate it?",
  "We keep getting stakeholder requests for next quarter. How do we prioritize them?",
  "Usage is growing, but retention is weak. What should we analyze first?",
];

/* ─── Bootstrap: load Three.js then init ─────────────────────────────────── */
(function () {
  function bootProdforce(preferThree) {
    if (window.__PF_BOOTED__) return;
    window.__PF_BOOTED__ = true;
    initProdforce(window.__PF_FRAMEWORKS__ || [], { preferThree: !!preferThree });
  }

  const script = document.createElement("script");
  script.src = "https://cdn.jsdelivr.net/npm/three@0.161.0/build/three.min.js";
  script.async = true;
  script.onload = () => bootProdforce(true);
  script.onerror = () => bootProdforce(false);
  document.head.appendChild(script);

  window.setTimeout(() => bootProdforce(Boolean(window.THREE)), 1800);
})();

/* ─── Main init ───────────────────────────────────────────────────────────── */
function initProdforce(frameworks, options) {
  // ── DOM refs ────────────────────────────────────────────────────────────
  const pfMessages   = document.getElementById("pfMessages");
  const pfSuggestions= document.getElementById("pfSuggestions");
  const pfTextarea   = document.getElementById("pfTextarea");
  const pfSendBtn    = document.getElementById("pfSendBtn");
  const pfAttachBtn  = document.getElementById("pfAttachBtn");
  const pfFileInput  = document.getElementById("pfFileInput");
  const pfFileBadge  = document.getElementById("pfFileBadge");
  const pfFileName   = document.getElementById("pfFileName");
  const pfFileRemove = document.getElementById("pfFileRemove");
  const pfStatusDot  = document.getElementById("pfStatusDot");
  const pfSceneHud   = document.getElementById("pfSceneHud");

  if (
    !pfMessages ||
    !pfSuggestions ||
    !pfTextarea ||
    !pfSendBtn ||
    !pfAttachBtn ||
    !pfFileInput ||
    !pfFileBadge ||
    !pfFileName ||
    !pfFileRemove ||
    !pfStatusDot ||
    !pfSceneHud
  ) {
    console.error("[prodforce-init] Missing required DOM nodes.");
    return;
  }

  // ── State ───────────────────────────────────────────────────────────────
  const STATE = {
    isStreaming: false,
    messages: [],
    attachedFile: null,
    currentResponse: "",
    sceneActive: null, // 'orchestrator' | 'specialists' | 'synthesis'
    sceneMode: "idle",
    sceneSummary: "",
    sceneCategories: [],
    sceneCategoryDecisions: [],
    sceneNeedsInPlay: [],
    scenePresent: [],
    sceneMissing: [],
    sceneQuestions: [],
    sceneReplySuggestions: [],
    sceneFrameworks: [],
    sceneFrameworkDecisions: [],
    sceneSelectedCategory: null,
    sceneSelectedFramework: null,
    sceneFocus: null,
    hadFrameworkMatch: false,
  };

  var initialSuggestions = pickSuggestionSet(DEFAULT_SUGGESTIONS, 3);
  const SCENE_PHASE_META = {
    idle: {
      eyebrow: "Ready",
      title: "Waiting to resolve uncertainty",
      body: "Describe a product decision — Prodforce will identify the right frameworks and walk you through them.",
    },
    intake: {
      eyebrow: "Analyzing",
      title: "Understanding your situation",
      body: "Reading the decision context and identifying which PM lanes apply.",
    },
    clarify: {
      eyebrow: "Gathering context",
      title: "Sharpening the recommendation",
      body: "Prodforce identified candidate frameworks and is collecting the details that will change the answer.",
    },
    match: {
      eyebrow: "Frameworks locked",
      title: "Frameworks matched",
      body: "The strongest frameworks for your situation have been identified. Running specialist analysis.",
    },
    specialists: {
      eyebrow: "Agents working",
      title: "Specialist analysis in progress",
      body: "Domain-specific agents are applying each framework to your situation.",
    },
    synthesis: {
      eyebrow: "Finalizing",
      title: "Synthesizing recommendation",
      body: "Merging specialist analyses into one clear, actionable recommendation.",
    },
    done: {
      eyebrow: "Complete",
      title: "Recommendation ready",
      body: "Your recommendation is ready. Refine the context or explore a different decision.",
    },
    error: {
      eyebrow: "Error",
      title: "Something went wrong",
      body: "The analysis encountered an issue. Try rephrasing or send a new challenge.",
    },
  };
  const SCENE_PHASE_META_V2 = {
    idle: {
      eyebrow: "Standing by",
      title: "",
      body: "",
    },
    intake: { eyebrow: "Analyzing", title: "Reading your situation", body: "" },
    clarify: { eyebrow: "Gathering context", title: "Sharpening the recommendation", body: "" },
    match: { eyebrow: "Matched", title: "Frameworks locked", body: "" },
    specialists: { eyebrow: "Working", title: "Specialist agents running", body: "" },
    synthesis: { eyebrow: "Synthesizing", title: "Building recommendation", body: "" },
    done: { eyebrow: "Complete", title: "Recommendation ready", body: "" },
    error: { eyebrow: "Error", title: "Something went wrong", body: "" },
  };

  function dedupeList(list) {
    return Array.from(new Set((list || []).filter(Boolean)));
  }

  function shuffleList(list) {
    var copy = Array.isArray(list) ? list.slice() : [];
    for (var i = copy.length - 1; i > 0; i -= 1) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = copy[i];
      copy[i] = copy[j];
      copy[j] = tmp;
    }
    return copy;
  }

  function pickSuggestionSet(list, count) {
    return shuffleList(list).slice(0, Math.min(count || 4, (list || []).length));
  }

  function sortCategoryDecisions(list) {
    return (Array.isArray(list) ? list.slice() : []).sort(function(a, b) {
      return (b.confidence || 0) - (a.confidence || 0) || (b.score || 0) - (a.score || 0);
    });
  }

  function sortFrameworkDecisions(list) {
    return (Array.isArray(list) ? list.slice() : []).sort(function(a, b) {
      return (b.confidence || b.decisionConfidence || 0) - (a.confidence || a.decisionConfidence || 0) ||
        (b.score || 0) - (a.score || 0);
    });
  }

  const CATEGORY_HEX = {
    "AI Product Quality, Risk & Safety": "#f04876",
    "Business Operating System": "#66badb",
    "Data & Model Evaluation": "#8fd96b",
    "Discovery & Delivery": "#10b981",
    "GTM & Growth": "#8b5cf6",
    "Market & Business Sizing": "#38bdf8",
    "Metrics & Analytics": "#f59e0b",
    "Operating Cadence & Alignment": "#ef4444",
    "Prioritization & Decision Systems": "#fb7185",
    "Roadmap & Portfolio": "#f97316",
    "Strategy & Positioning": "#6366f1",
  };
  const CATEGORY_ALIAS = {
    "AI Product Quality, Risk & Safety": "AI Risk & Safety",
    "Business Operating System": "Business OS",
    "Data & Model Evaluation": "Data & Model Eval",
    "Operating Cadence & Alignment": "Ops Cadence & Alignment",
    "Prioritization & Decision Systems": "Prioritization & Decisions",
  };
  const CATEGORY_FALLBACK_HEX = [
    "#00d4ff",
    "#34d399",
    "#f59e0b",
    "#a78bfa",
    "#fb7185",
    "#38bdf8",
  ];

  function hexToRgbArray(hex) {
    var clean = String(hex || "#97a1ff").replace("#", "");
    return [
      parseInt(clean.slice(0, 2), 16) / 255,
      parseInt(clean.slice(2, 4), 16) / 255,
      parseInt(clean.slice(4, 6), 16) / 255,
    ];
  }

  function rgbFromArray(arr) {
    var color = Array.isArray(arr) ? arr : [0.62, 0.64, 0.9];
    return (
      "rgb(" +
      Math.round(color[0] * 255) +
      "," +
      Math.round(color[1] * 255) +
      "," +
      Math.round(color[2] * 255) +
      ")"
    );
  }

  function buildCategoryPalette(fws, asArray) {
    var categories = dedupeList(
      (fws || [])
        .map(function(fw) { return fw.category; })
        .filter(Boolean)
        .concat(Object.keys(CATEGORY_HEX))
    );
    var palette = {};
    categories.forEach(function(cat, index) {
      var hex = CATEGORY_HEX[cat] || CATEGORY_FALLBACK_HEX[index % CATEGORY_FALLBACK_HEX.length];
      palette[cat] = asArray ? hexToRgbArray(hex) : hex;
    });
    return palette;
  }

  function formatCategoryLabel(cat) {
    return CATEGORY_ALIAS[cat] || cat || "";
  }

  function getConversationDepth() {
    var userTurns = STATE.messages.filter(function(message) {
      return message.role === "user";
    }).length;
    var phaseBoost =
      STATE.sceneMode === "specialists"
        ? 0.2
        : STATE.sceneMode === "synthesis" || STATE.sceneMode === "done"
          ? 0.3
          : STATE.sceneMode === "clarify"
            ? 0.12
            : 0;
    var frameworkBoost = Math.min(0.28, (STATE.sceneFrameworks || []).length * 0.08);
    return Math.min(1, Math.max(0, Math.max(0, userTurns - 1) * 0.16 + phaseBoost + frameworkBoost));
  }

  function inferLikelyCategories(text) {
    var lower = String(text || "").toLowerCase();
    var categories = [];
    if (/\b(ai|safety|risk|privacy|misuse|bias|fairness|model quality)\b/.test(lower))
      categories.push("AI Product Quality, Risk & Safety");
    if (/\b(operating system|playbook|cadence|operating model)\b/.test(lower))
      categories.push("Business Operating System");
    if (/\b(data|model evaluation|a\/b test|experiment|hypothesis)\b/.test(lower))
      categories.push("Data & Model Evaluation");
    if (/\b(discovery|research|interview|customer|user|validate|opportunity|jtbd|jobs)\b/.test(lower))
      categories.push("Discovery & Delivery");
    if (/\b(launch|go-to-market|go to market|gtm|pricing|adoption|retention|churn|growth|funnel)\b/.test(lower))
      categories.push("GTM & Growth");
    if (/\b(market size|tam|sam|som|sizing|segment|total addressable)\b/.test(lower))
      categories.push("Market & Business Sizing");
    if (/\b(metric|metrics|kpi|okr|measure|success|analytics|north star)\b/.test(lower))
      categories.push("Metrics & Analytics");
    if (/\b(stakeholder|cadence|retro|retrospective|postmortem|alignment|escalation|decision rights)\b/.test(lower))
      categories.push("Operating Cadence & Alignment");
    if (/\b(priorit|tradeoff|rice|scoring|rank|decision system|cost.benefit|moscow)\b/.test(lower))
      categories.push("Prioritization & Decision Systems");
    if (/\b(roadmap|portfolio|backlog|bet|quarterly|planning|capacity)\b/.test(lower))
      categories.push("Roadmap & Portfolio");
    if (/\b(vision|strategy|positioning|competitive|differentiat|value prop)\b/.test(lower))
      categories.push("Strategy & Positioning");
    return dedupeList(categories).slice(0, 5);
  }

  var pfSceneProgress = document.getElementById("pfSceneProgress");

  function setSceneState(patch) {
    Object.assign(STATE, patch || {});
    renderSceneHud();
    renderSceneProgress();
  }

  function renderSceneProgress() {
    if (!pfSceneProgress) return;
    var mode = STATE.sceneMode || "idle";
    var percent = 0;
    var color = "";
    var glow = "";
    if (mode === "idle") {
      pfSceneProgress.innerHTML = "";
      return;
    } else if (mode === "intake") {
      percent = 15; color = "#00d4ff"; glow = "rgba(0,212,255,0.4)";
    } else if (mode === "clarify") {
      var pres = dedupeList(STATE.scenePresent).length;
      var miss = dedupeList(STATE.sceneMissing).length;
      var cov = pres + miss > 0 ? pres / (pres + miss) : 0;
      percent = Math.round(20 + cov * 35);
      color = "#f59e0b"; glow = "rgba(245,158,11,0.4)";
    } else if (mode === "match") {
      percent = 60; color = "#8b5cf6"; glow = "rgba(139,92,246,0.4)";
    } else if (mode === "specialists") {
      percent = 75; color = "#6366f1"; glow = "rgba(99,102,241,0.4)";
    } else if (mode === "synthesis") {
      percent = 90; color = "#10b981"; glow = "rgba(16,185,129,0.4)";
    } else if (mode === "done") {
      percent = 100; color = "#10b981"; glow = "rgba(16,185,129,0.4)";
    } else if (mode === "error") {
      percent = 30; color = "#ef4444"; glow = "rgba(239,68,68,0.4)";
    }
    pfSceneProgress.innerHTML =
      '<div class="pf-scene-progress-fill" style="width:' + percent +
      '%;background:' + color + ';--bar-glow:' + glow + '"></div>';
  }

  function renderHudChips(items, tone, limit) {
    return dedupeList(items)
      .slice(0, limit || 4)
      .map((item) => '<span class="pf-scene-pill is-' + tone + '">' + escHtml(item) + "</span>")
      .join("");
  }

  function renderSceneHud() {
    var meta = SCENE_PHASE_META_V2[STATE.sceneMode] || SCENE_PHASE_META_V2.idle;
    var bodyCopy = meta.body || "";
    var isIdle = STATE.sceneMode === "idle";
    if (isIdle) {
      pfSceneHud.innerHTML =
        '<div class="pf-scene-hud-standby-pill">Standing by</div>';
      return;
    }
    pfSceneHud.innerHTML =
      '<div class="pf-scene-hud-card">' +
        '<div class="pf-scene-hud-phase">' + escHtml(meta.eyebrow) + "</div>" +
        '<div class="pf-scene-hud-title">' + escHtml(meta.title) + "</div>" +
        (bodyCopy
          ? '<div class="pf-scene-hud-body">' + escHtml(bodyCopy) + "</div>"
          : "") +
      "</div>";
  }


  // ── Set framework count ─────────────────────────────────────────────────

  // ── Input: auto-resize + enable send ────────────────────────────────────
  function syncComposerState() {
    pfTextarea.style.height = "auto";
    pfTextarea.style.height = Math.min(pfTextarea.scrollHeight, 120) + "px";
    pfSendBtn.disabled = !pfTextarea.value.trim() || STATE.isStreaming;
  }

  pfTextarea.addEventListener("input", () => {
    syncComposerState();
  });

  pfTextarea.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      if (!pfSendBtn.disabled) handleSend();
    }
  });

  pfSendBtn.addEventListener("click", handleSend);
  syncComposerState();

  // ── File upload ─────────────────────────────────────────────────────────
  pfAttachBtn.addEventListener("click", () => pfFileInput.click());
  pfFileInput.addEventListener("change", () => {
    if (pfFileInput.files[0]) handleFile(pfFileInput.files[0]);
    pfFileInput.value = "";
  });
  pfFileRemove.addEventListener("click", clearFile);

  // Drag-and-drop onto textarea area
  const inputArea = pfTextarea.parentElement;
  inputArea.addEventListener("dragover", (e) => { e.preventDefault(); inputArea.style.borderColor = "rgba(0,212,255,0.5)"; });
  inputArea.addEventListener("dragleave", () => { inputArea.style.borderColor = ""; });
  inputArea.addEventListener("drop", (e) => {
    e.preventDefault();
    inputArea.style.borderColor = "";
    if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });

  // ── Starter suggestions ──────────────────────────────────────────────────
  try {
    renderSuggestionChips(initialSuggestions, {
      labelText: "Start here",
      submitOnClick: true,
    });
  } catch (err) {
    console.error("[prodforce-suggestions]", err);
    pfSuggestions.style.display = "none";
  }
  renderSceneHud();
  renderSceneProgress();

  // ── Three.js scene ──────────────────────────────────────────────────────
  window.requestAnimationFrame(() => {
    try {
      if (options && options.preferThree && window.THREE) initScene(window.THREE, frameworks);
      else initConstellationScene(frameworks);
    } catch (err) {
      console.error("[prodforce-scene]", err);
      initConstellationScene(frameworks);
    }
  });

  /* ── Send ──────────────────────────────────────────────────────────────── */
  async function handleSend() {
    const text = pfTextarea.value.trim();
    if (!text || STATE.isStreaming) return;

    pfTextarea.value = "";
    pfTextarea.style.height = "auto";
    pfSuggestions.style.display = "none";
    pfSendBtn.disabled = true;
    window.__PF_PENDING_CLARIFY__ = null;
    window.__PF_PENDING_SUGG__ = null;

    STATE.messages.push({ role: "user", content: text });
    appendMsg("user", text);

    STATE.isStreaming = true;
    STATE.currentResponse = "";
    STATE.hadFrameworkMatch = false;
    pfStatusDot.classList.add("pf-active");
    setSceneState({
      sceneActive: "orchestrator",
      sceneMode: "intake",
      sceneSummary: "Scoping the PM decision before selecting frameworks.",
      sceneCategories: inferLikelyCategories(text),
      sceneCategoryDecisions: [],
      sceneNeedsInPlay: [],
      sceneMissing: [],
      sceneQuestions: [],
      sceneReplySuggestions: [],
      sceneFrameworks: [],
      sceneFrameworkDecisions: [],
      sceneSelectedCategory: null,
      sceneSelectedFramework: null,
      sceneFocus: null,
    });

    const pipelineEl = createPipelineEl();
    pfMessages.appendChild(pipelineEl);
    scrollBottom();

    try {
      const body = { messages: STATE.messages };
      if (STATE.attachedFile) body.file = STATE.attachedFile;

      const resp = await fetch("/api/prodforce-chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });

      if (!resp.ok) {
        let errorMessage = "Request failed (" + resp.status + ")";
        try {
          const errorBody = await resp.json();
          if (errorBody && typeof errorBody.error === "string") errorMessage = errorBody.error;
        } catch {}
        throw new Error(errorMessage);
      }

      const reader = resp.body.getReader();
      const dec = new TextDecoder();
      let buf = "";
      let assistantEl = null;
      let sawDone = false;
      let sawError = false;

      function ensureAssistantBody() {
        if (!assistantEl) {
          assistantEl = createAssistantEl();
          pfMessages.appendChild(assistantEl);
        }
        const bodyEl = assistantEl.querySelector(".pf-msg-body");
        if (!(bodyEl instanceof HTMLElement)) {
          throw new Error("Assistant message container was unavailable.");
        }
        return bodyEl;
      }

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const lines = buf.split("\n");
        buf = lines.pop();

        for (const line of lines) {
          if (!line.startsWith("data: ")) continue;
          let ev;
          try { ev = JSON.parse(line.slice(6)); } catch { continue; }

          if (ev.type === "agent_start") {
            setPipelineStep(pipelineEl, ev.agent, "active");
            setStatusMsg(pipelineEl, ev.label || "");
            setSceneState({
              sceneActive: ev.agent,
              sceneMode:
                ev.agent === "synthesis"
                  ? "synthesis"
                  : ev.agent === "specialists"
                    ? "specialists"
                    : STATE.hadFrameworkMatch
                      ? "match"
                      : "intake",
              sceneSummary: ev.label || STATE.sceneSummary,
            });
          } else if (ev.type === "clarification_needed") {
            setStatusMsg(pipelineEl, "Scoping the decision...");
            var askedInformation = Array.isArray(ev.askedInformation)
              ? ev.askedInformation
              : Array.isArray(ev.missingInformation)
                ? ev.missingInformation.slice(0, 3)
                : [];
            var deferredInformation = Array.isArray(ev.deferredInformation)
              ? ev.deferredInformation
              : Array.isArray(ev.missingInformation)
                ? ev.missingInformation.slice(askedInformation.length)
                : [];
            var suggestedReplies = Array.isArray(ev.suggestedReplies) ? ev.suggestedReplies : [];
            var candidateFrameworks = Array.isArray(ev.candidateFrameworks) ? ev.candidateFrameworks : [];
            var categoryDecisions = Array.isArray(ev.categoryDecisions) ? ev.categoryDecisions : [];
            var frameworkDecisions = Array.isArray(ev.frameworkDecisions) ? ev.frameworkDecisions : [];
            setSceneState({
              sceneActive: "orchestrator",
              sceneMode: "clarify",
              sceneSummary:
                ev.situationSummary ||
                "Prodforce has narrowed the likely frameworks and is collecting the final context that changes the recommendation.",
              sceneCategories: categoryDecisions.length
                ? categoryDecisions.map(function(decision) { return decision.category; })
                : Array.isArray(ev.candidateCategories)
                  ? ev.candidateCategories
                  : [],
              sceneCategoryDecisions: categoryDecisions,
              scenePresent: Array.isArray(ev.presentInformation) ? ev.presentInformation : [],
              sceneNeedsInPlay: [],
              sceneMissing: dedupeList(askedInformation.concat(deferredInformation)),
              sceneQuestions: Array.isArray(ev.questions) ? ev.questions : [],
              sceneReplySuggestions: suggestedReplies,
              sceneFrameworks: candidateFrameworks,
              sceneFrameworkDecisions: frameworkDecisions,
              sceneFocus: null,
            });
            window.__PF_PENDING_CLARIFY__ = {
              askedInformation: askedInformation,
              deferredInformation: deferredInformation,
              questions: Array.isArray(ev.questions) ? ev.questions : [],
              suggestedReplies: suggestedReplies,
              candidateFrameworks: candidateFrameworks,
              categoryDecisions: categoryDecisions,
              frameworkDecisions: frameworkDecisions,
            };
            if (ev.questions?.length) window.__PF_PENDING_SUGG__ = ev.questions;
          } else if (ev.type === "frameworks_matched") {
            STATE.hadFrameworkMatch = true;
            setPipelineStep(pipelineEl, "orchestrator", "done");
            renderFwCards(pipelineEl, ev.frameworks || []);
            var matchedCategoryDecisions = Array.isArray(ev.categoryDecisions) ? ev.categoryDecisions : [];
            var matchedFrameworkDecisions = Array.isArray(ev.frameworkDecisions) ? ev.frameworkDecisions : [];
            setSceneState({
              sceneActive: "orchestrator",
              sceneMode: "match",
              sceneSummary:
                ev.situationSummary ||
                "Framework fit has been established against the captured PM context.",
              sceneCategories: matchedCategoryDecisions.length
                ? matchedCategoryDecisions.map(function(decision) { return decision.category; })
                : dedupeList((ev.frameworks || []).map((fw) => fw.category)),
              sceneCategoryDecisions: matchedCategoryDecisions,
              scenePresent: dedupeList(
                (ev.frameworks || []).flatMap((fw) => fw.presentInputs || [])
              ),
              sceneNeedsInPlay: [],
              sceneMissing: dedupeList(
                (ev.frameworks || []).flatMap((fw) => fw.missingInputs || [])
              ),
              sceneQuestions: Array.isArray(ev.suggestions) ? ev.suggestions : [],
              sceneReplySuggestions: [],
              sceneFrameworks: ev.frameworks || [],
              sceneFrameworkDecisions: matchedFrameworkDecisions,
              sceneFocus: null,
            });
            if (ev.suggestions?.length) window.__PF_PENDING_SUGG__ = ev.suggestions;
          } else if (ev.type === "specialist_start") {
            addSpecialistTag(pipelineEl, ev.framework, "running");
            setSceneState({
              sceneActive: "specialists",
              sceneMode: "specialists",
              sceneSummary: "Running specialist analysis for " + ev.framework + ".",
              sceneFocus: ev.framework,
            });
          } else if (ev.type === "specialist_done") {
            markSpecialistDone(pipelineEl, ev.framework);
          } else if (ev.type === "content") {
            const bodyEl = ensureAssistantBody();
            if (STATE.hadFrameworkMatch) setPipelineStep(pipelineEl, "specialists", "done");
            else setPipelineStep(pipelineEl, "orchestrator", "done");
            if (STATE.hadFrameworkMatch) {
              setSceneState({
                sceneActive: "synthesis",
                sceneMode: "synthesis",
                sceneSummary: "Synthesizing the selected framework analyses into one recommendation.",
                sceneFocus: null,
              });
            }
            STATE.currentResponse += typeof ev.text === "string" ? ev.text : "";
            bodyEl.innerHTML = renderMd(STATE.currentResponse) + '<span class="pf-cursor"></span>';
            scrollBottom();
          } else if (ev.type === "done") {
            sawDone = true;
            if (STATE.currentResponse) {
              const body = ensureAssistantBody();
              body.innerHTML = renderMd(STATE.currentResponse);
              if (STATE.hadFrameworkMatch) {
                const btn = document.createElement("button");
                btn.className = "pf-pdf-btn";
                btn.innerHTML = "↓ Download Analysis";
                btn.addEventListener("click", () => downloadPDF(STATE.currentResponse));
                body.appendChild(btn);
              }
            }
            if (ev.mode === "clarify" || ev.mode === "ask_problem") setPipelineStep(pipelineEl, "orchestrator", "done");
            else setPipelineStep(pipelineEl, "synthesis", "done");
            pipelineEl.remove();
            if (STATE.currentResponse) {
              STATE.messages.push({ role: "assistant", content: STATE.currentResponse });
            }
            var nextSuggestions =
              Array.isArray(ev.suggestions) && ev.suggestions.length
                ? ev.suggestions
                : window.__PF_PENDING_SUGG__;
            var clarifyState = window.__PF_PENDING_CLARIFY__;
            if (ev.mode === "clarify" && clarifyState) {
              if (clarifyState.suggestedReplies && clarifyState.suggestedReplies.length) {
                renderSuggestionChips(clarifyState.suggestedReplies, {
                  tone: "reply",
                  labelText: "Suggested answers",
                  submitOnClick: true,
                });
              } else {
                renderSuggestionChips([]);
              }
              window.__PF_PENDING_CLARIFY__ = null;
              window.__PF_PENDING_SUGG__ = null;
            } else if (nextSuggestions?.length) {
                renderSuggestionChips(nextSuggestions, {
                  labelText: "Explore another angle",
                  submitOnClick: true,
                });
              window.__PF_PENDING_SUGG__ = null;
            } else if (ev.mode === "ask_problem") {
              renderSuggestionChips(pickSuggestionSet(DEFAULT_SUGGESTIONS, 3), {
                labelText: "Start here",
                submitOnClick: true,
              });
            } else {
              renderSuggestionChips(pickSuggestionSet(DEFAULT_SUGGESTIONS, 3));
            }
            setSceneState({
              sceneActive: null,
              sceneMode:
                ev.mode === "clarify"
                  ? "clarify"
                  : ev.mode === "ask_problem"
                    ? "idle"
                    : "done",
              sceneSummary:
                ev.mode === "clarify"
                  ? "Prodforce has narrowed the framework field. Reply with whatever context you have and it will keep moving."
                  : ev.mode === "ask_problem"
                    ? "Waiting to resolve uncertainty."
                  : "Recommendation ready. Refine the context or ask Prodforce to compare another path.",
              sceneNeedsInPlay:
                ev.mode === "clarify" && clarifyState
                  ? clarifyState.askedInformation || STATE.sceneNeedsInPlay
                  : ev.mode === "ask_problem"
                    ? []
                    : STATE.sceneNeedsInPlay,
              sceneMissing:
                ev.mode === "clarify" && clarifyState
                  ? dedupeList((clarifyState.askedInformation || []).concat(clarifyState.deferredInformation || []))
                  : ev.mode === "ask_problem"
                    ? []
                    : STATE.sceneMissing,
              sceneQuestions:
                ev.mode === "clarify" && clarifyState
                  ? clarifyState.questions || STATE.sceneQuestions
                  : ev.mode === "ask_problem"
                    ? []
                    : nextSuggestions || STATE.sceneQuestions,
              sceneReplySuggestions:
                ev.mode === "clarify" && clarifyState
                  ? clarifyState.suggestedReplies || []
                  : [],
              sceneFrameworks:
                ev.mode === "clarify" && clarifyState
                  ? clarifyState.candidateFrameworks || STATE.sceneFrameworks
                  : ev.mode === "ask_problem"
                    ? []
                    : STATE.sceneFrameworks,
              sceneCategoryDecisions:
                ev.mode === "clarify" && clarifyState
                  ? clarifyState.categoryDecisions || STATE.sceneCategoryDecisions
                  : ev.mode === "ask_problem"
                    ? []
                    : STATE.sceneCategoryDecisions,
              sceneFrameworkDecisions:
                ev.mode === "clarify" && clarifyState
                  ? clarifyState.frameworkDecisions || STATE.sceneFrameworkDecisions
                  : ev.mode === "ask_problem"
                    ? []
                    : STATE.sceneFrameworkDecisions,
              sceneCategories:
                ev.mode === "ask_problem"
                  ? []
                  : STATE.sceneCategories,
              scenePresent:
                ev.mode === "ask_problem"
                  ? []
                  : STATE.scenePresent,
              sceneSelectedCategory:
                ev.mode === "ask_problem"
                  ? null
                  : STATE.sceneSelectedCategory,
              sceneSelectedFramework:
                ev.mode === "ask_problem"
                  ? null
                  : STATE.sceneSelectedFramework,
              sceneFocus: null,
            });
          } else if (ev.type === "error") {
            sawError = true;
            pipelineEl.remove();
            appendError(ev.message);
            renderSuggestionChips(pickSuggestionSet(DEFAULT_SUGGESTIONS, 3));
            var friendlyError = humanizeErrorMessage(ev.message);
            setSceneState({
              sceneActive: null,
              sceneMode: "error",
              sceneSummary: friendlyError || "The analysis pipeline hit an unexpected error.",
              sceneNeedsInPlay: [],
              sceneReplySuggestions: [],
              sceneFocus: null,
            });
          }
        }
      }

      if (!sawDone && !sawError && !STATE.currentResponse) {
        throw new Error("Response stream ended before any analysis was returned.");
      }
    } catch (err) {
      pipelineEl.remove();
      var friendlyError = humanizeErrorMessage(err.message || "Unexpected error");
      appendError(friendlyError);
      renderSuggestionChips(pickSuggestionSet(DEFAULT_SUGGESTIONS, 3));
      setSceneState({
        sceneActive: null,
        sceneMode: "error",
        sceneSummary: friendlyError,
        sceneNeedsInPlay: [],
        sceneReplySuggestions: [],
        sceneFocus: null,
      });
    } finally {
      STATE.isStreaming = false;
      STATE.sceneActive = null;
      STATE.attachedFile = null;
      pfStatusDot.classList.remove("pf-active");
      clearFile();
      pfSendBtn.disabled = !pfTextarea.value.trim();
      renderSceneHud();
        scrollBottom();
    }
  }

  /* ── DOM helpers ─────────────────────────────────────────────────────────── */
  function appendMsg(role, content) {
    const el = document.createElement("div");
    el.className = "pf-msg pf-msg-" + role;
    const roleLabel = role === "user" ? "YOU" : "PRODFORCE";
    el.innerHTML =
      '<div class="pf-msg-role">' + escHtml(roleLabel) + "</div>" +
      '<div class="pf-msg-bubble">' +
      (role === "user" ? escHtml(content) : renderMd(content)) +
      "</div>";
    pfMessages.appendChild(el);
    scrollBottom();
  }

  function createAssistantEl() {
    const el = document.createElement("div");
    el.className = "pf-msg pf-msg-assistant";
    el.innerHTML =
      '<div class="pf-msg-role">PRODFORCE</div>' +
      '<div class="pf-msg-bubble"><div class="pf-msg-body"></div></div>';
    return el;
  }

  function humanizeErrorMessage(msg) {
    var text = String(msg || "Unexpected error").replace(/\s+/g, " ").trim();
    if (/rate limit/i.test(text)) {
      return "Prodforce hit the current free-tier model limit. Wait a moment and continue — your context is still in place.";
    }
    return text;
  }

  function appendError(msg) {
    const el = document.createElement("div");
    el.className = "pf-msg-error";
    el.textContent = "Error: " + humanizeErrorMessage(msg);
    pfMessages.appendChild(el);
    scrollBottom();
  }

  function createPipelineEl() {
    const el = document.createElement("div");
    el.className = "pf-pipeline";
    el.innerHTML =
      '<div class="pf-pipeline-steps">' +
        '<div class="pf-pipeline-step" data-step="orchestrator"><div class="pf-step-dot"></div><span class="pf-step-label">Context</span></div>' +
        '<span class="pf-pipeline-arrow">›</span>' +
        '<div class="pf-pipeline-step" data-step="specialists"><div class="pf-step-dot"></div><span class="pf-step-label">Frameworks</span></div>' +
        '<span class="pf-pipeline-arrow">›</span>' +
        '<div class="pf-pipeline-step" data-step="synthesis"><div class="pf-step-dot"></div><span class="pf-step-label">Output</span></div>' +
      "</div>" +
      '<div class="pf-pipeline-status-msg" data-status></div>' +
      '<div class="pf-fw-cards" data-fw-cards></div>' +
      '<div class="pf-specialists-progress" data-specialists></div>';
    return el;
  }

  function setPipelineStep(el, agent, state) {
    const step = el.querySelector('[data-step="' + agent + '"]');
    if (!step) return;
    el.querySelectorAll(".pf-pipeline-step").forEach((s) => {
      if (s !== step) {
        if (!s.classList.contains("is-done")) s.classList.remove("is-active");
      }
    });
    step.classList.remove("is-active", "is-done");
    if (state === "active") step.classList.add("is-active");
    if (state === "done") step.classList.add("is-done");
  }

  function setStatusMsg(el, msg) {
    const s = el.querySelector("[data-status]");
    if (s) s.textContent = msg;
  }

  function inferArtifactKind(text) {
    var lower = String(text || "").toLowerCase();
    if (/\b(matrix|quadrant|2x2|tradeoff)\b/.test(lower)) return "matrix";
    if (/\b(score|scorecard|priorit|rank|ranking)\b/.test(lower)) return "scorecard";
    if (/\b(roadmap|timeline|sequence|phases?)\b/.test(lower)) return "roadmap";
    if (/\b(metric|dashboard|north star|tree)\b/.test(lower)) return "metrics";
    if (/\b(memo|brief|narrative|one-pager|recommendation)\b/.test(lower)) return "memo";
    if (/\b(playbook|workflow|process|operating model)\b/.test(lower)) return "playbook";
    if (/\b(experiment|test|hypothesis)\b/.test(lower)) return "experiment";
    return "blueprint";
  }

  function renderArtifactPreview(outputArtifact) {
    var kind = inferArtifactKind(outputArtifact);
    if (kind === "matrix") {
      return (
        '<div class="pf-fw-preview is-matrix">' +
          '<span>Impact</span><span>Risk</span><span>Effort</span><span>Confidence</span>' +
        "</div>"
      );
    }
    if (kind === "scorecard") {
      return (
        '<div class="pf-fw-preview is-scorecard">' +
          '<div class="pf-fw-bar"><span></span></div>' +
          '<div class="pf-fw-bar"><span></span></div>' +
          '<div class="pf-fw-bar"><span></span></div>' +
        "</div>"
      );
    }
    if (kind === "roadmap") {
      return (
        '<div class="pf-fw-preview is-roadmap">' +
          '<span></span><span></span><span></span><span></span>' +
        "</div>"
      );
    }
    if (kind === "metrics") {
      return (
        '<div class="pf-fw-preview is-metrics">' +
          '<div class="pf-fw-metric-node"></div>' +
          '<div class="pf-fw-metric-branch"><span></span><span></span></div>' +
        "</div>"
      );
    }
    if (kind === "playbook") {
      return (
        '<div class="pf-fw-preview is-playbook">' +
          '<span></span><span></span><span></span>' +
        "</div>"
      );
    }
    if (kind === "experiment") {
      return (
        '<div class="pf-fw-preview is-experiment">' +
          '<span>Hypothesis</span><span>Test</span><span>Readout</span>' +
        "</div>"
      );
    }
    return (
      '<div class="pf-fw-preview is-memo">' +
        '<span></span><span></span><span></span><span></span>' +
      "</div>"
    );
  }

  function renderFrameworkChipRow(items, tone, emptyLabel) {
    const list = dedupeList(items).slice(0, 5);
    if (!list.length) {
      return '<span class="pf-fw-empty">' + escHtml(emptyLabel) + "</span>";
    }
    return list
      .map(
        (item) =>
          '<span class="pf-fw-chip is-' + tone + '">' + escHtml(item) + "</span>"
      )
      .join("");
  }

  function renderFwCards(pipelineEl, fws) {
    const container = pipelineEl.querySelector("[data-fw-cards]");
    if (!container) return;
    container.innerHTML = "";
    fws.forEach((fw) => {
      const card = document.createElement("div");
      card.className = "pf-fw-card";
      const readinessTone =
        fw.confidence === "high" ? "high" : fw.confidence === "medium" ? "medium" : "low";
      card.innerHTML =
        '<div class="pf-fw-card-head">' +
          '<span class="pf-fw-cat">' + escHtml(fw.category) + "</span>" +
          '<span class="pf-fw-readiness is-' + readinessTone + '">' +
            escHtml(fw.readinessLabel || "Context fit pending") +
          "</span>" +
        "</div>" +
        '<div class="pf-fw-title">' + escHtml(fw.title) + "</div>" +
        '<div class="pf-fw-reason">' + escHtml(fw.reason || fw.whenToUse) + "</div>" +
        '<div class="pf-fw-section"><div class="pf-fw-section-label">When to use</div><div class="pf-fw-meta">' +
          escHtml(fw.whenToUseFull || fw.whenToUse || "Prodforce is grounding when this framework becomes the right decision tool.") +
        "</div></div>" +
        '<div class="pf-fw-section"><div class="pf-fw-section-label">Input required</div><div class="pf-fw-meta">' +
          escHtml(fw.inputsRequired || "No explicit framework criteria were provided.") +
        "</div></div>" +
        '<div class="pf-fw-section"><div class="pf-fw-section-label">Produces</div><div class="pf-fw-output-card">' +
          '<div class="pf-fw-output-title">' +
            escHtml(fw.outputArtifact || "Decision artifact and recommendation structure") +
          "</div>" +
          renderArtifactPreview(fw.outputArtifact) +
        "</div></div>" +
        '<div class="pf-fw-section"><div class="pf-fw-section-label">Framework needs</div><div class="pf-fw-chip-row">' +
          renderFrameworkChipRow(
            fw.requiredInputs || [],
            "required",
            "Prodforce is inferring the required inputs from the framework metadata."
          ) +
        "</div></div>" +
        '<div class="pf-fw-section"><div class="pf-fw-section-label">Already grounded</div><div class="pf-fw-chip-row">' +
          renderFrameworkChipRow(
            fw.presentInputs || [],
            "present",
            "Prodforce is still grounding the core decision context."
          ) +
        "</div></div>" +
        '<div class="pf-fw-section"><div class="pf-fw-section-label">Still missing</div><div class="pf-fw-chip-row">' +
          renderFrameworkChipRow(
            fw.missingInputs || [],
            "missing",
            "No major gaps remain for this framework."
          ) +
        "</div></div>" +
        (fw.commonMistakes
          ? '<div class="pf-fw-warning">Avoid: ' + escHtml(fw.commonMistakes) + "</div>"
          : "");
      container.appendChild(card);
    });
  }

  function addSpecialistTag(el, name, state) {
    const c = el.querySelector("[data-specialists]");
    if (!c) return;
    let tag = c.querySelector('[data-fw="' + CSS.escape(name) + '"]');
    if (!tag) {
      tag = document.createElement("div");
      tag.className = "pf-specialist-tag";
      tag.dataset.fw = name;
      tag.innerHTML = '<span>◉</span> ' + escHtml(name);
      c.appendChild(tag);
    }
    tag.classList.toggle("is-running", state === "running");
    tag.classList.toggle("is-done", state === "done");
  }

  function markSpecialistDone(el, name) {
    addSpecialistTag(el, name, "done");
  }

  function renderSuggestionChips(list, opts) {
    pfSuggestions.innerHTML = "";
    if (!list || !list.length) {
      pfSuggestions.style.display = "none";
      return;
    }
    list = list.slice(0, 3);
    var tone = opts && opts.tone ? opts.tone : "default";
    var labelText = opts && opts.labelText ? opts.labelText : "";
    var submitOnClick =
      opts && typeof opts.submitOnClick === "boolean"
        ? opts.submitOnClick
        : tone === "default";
    if (labelText) {
      var label = document.createElement("span");
      label.className =
        "pf-chip-label" +
        (tone === "reply" || tone === "asked"
          ? " is-positive"
          : tone === "missing"
            ? " is-warning"
            : "");
      label.textContent = labelText;
      pfSuggestions.appendChild(label);
    }
    list.forEach(function(s) {
      var btn = document.createElement("button");
      btn.className =
        "pf-chip" +
        (tone === "missing"
          ? " pf-chip-orange"
          : tone === "reply"
            ? " pf-chip-reply"
            : tone === "asked"
              ? " pf-chip-green"
              : "");
      btn.textContent = s;
      btn.addEventListener("click", function() {
        pfTextarea.value = s;
        pfTextarea.dispatchEvent(new Event("input"));
        pfTextarea.focus();
        if (submitOnClick && !STATE.isStreaming) handleSend();
      });
      pfSuggestions.appendChild(btn);
    });
    pfSuggestions.style.display = "flex";
  }

  function scrollBottom() {
    pfMessages.scrollTo({ top: pfMessages.scrollHeight, behavior: "smooth" });
  }

  /* ── File handling ─────────────────────────────────────────────────────── */
  const ACCEPTED_TEXT = ["text/plain", "text/markdown", "text/csv", "application/json"];

  function handleFile(file) {
    if (!file) return;
    const isPDF = file.type === "application/pdf";
    const isText = ACCEPTED_TEXT.includes(file.type) || file.name.match(/\.(txt|md|csv|json)$/i);
    if (!isPDF && !isText) return;

    pfFileName.textContent = file.name;
    pfFileBadge.style.display = "flex";

    const reader = new FileReader();
    if (isPDF) {
      reader.readAsDataURL(file);
      reader.onload = () => {
        const b64 = reader.result.split(",")[1];
        STATE.attachedFile = { name: file.name, fileType: "pdf", base64: b64 };
      };
    } else {
      reader.readAsText(file);
      reader.onload = () => {
        STATE.attachedFile = {
          name: file.name,
          fileType: "text",
          content: String(reader.result || "").slice(0, 50000),
        };
      };
    }
  }

  function clearFile() {
    STATE.attachedFile = null;
    pfFileBadge.style.display = "none";
    pfFileName.textContent = "";
  }

