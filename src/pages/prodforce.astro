  margin: 10px 0;
}
.pf-msg-bubble pre code { background: none; padding: 0; color: #aaddff; }
.pf-msg-bubble hr { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 14px 0; }
.pf-cursor {
  display: inline-block;
  width: 2px;
  height: 1em;
