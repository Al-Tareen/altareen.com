            point.x,
            point.y,
            (isHighlighted ? 3.6 : 1.7) + point.scale * (isHighlighted ? 4.6 : 2.4),
            0,
            Math.PI * 2
          );
          ctx.fill();
          if (isHighlighted) {
            ctx.strokeStyle = getSceneRgba(phase, 0.42);
            ctx.lineWidth = 1.1;
            ctx.beginPath();
            ctx.arc(point.x, point.y, 7 + point.scale * 5, 0, Math.PI * 2);
            ctx.stroke();
          }
        });
        ctx.globalAlpha = 1;

        const hubPulse = 1 + Math.sin(t * 2.1) * 0.08;
        const hubX = size.width * 0.5;
        const hubY = size.height * 0.5;
        ctx.fillStyle = getSceneRgba(phase, 0.18);
        ctx.beginPath();
        ctx.arc(hubX, hubY, 30 * hubPulse, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = getSceneRgba(phase, 1);
        ctx.beginPath();
        ctx.arc(hubX, hubY, 10 * hubPulse, 0, Math.PI * 2);
        ctx.fill();

        categoryBodies.forEach(function(body, index) {
          const point = project(body.x, body.y, body.z, size.width, size.height);
          const isActive = activeCats.has(body.cat);

          ctx.strokeStyle = isActive ? getSceneRgba(phase, 0.34) : "rgba(255,255,255,0.09)";
          ctx.lineWidth = isActive ? 1.4 : 1;
          ctx.beginPath();
          ctx.moveTo(hubX, hubY);
          ctx.lineTo(point.x, point.y);
          ctx.stroke();

          ctx.fillStyle = body.color;
          ctx.globalAlpha = isActive ? 1 : hasActiveCats ? 0.58 : 0.84;
          ctx.beginPath();
          ctx.arc(point.x, point.y, (isActive ? 8.2 : 6.2) + point.scale * 4.2, 0, Math.PI * 2);
          ctx.fill();
          ctx.globalAlpha = isActive ? 0.22 : 0.12;
          ctx.beginPath();
          ctx.arc(point.x, point.y, (isActive ? 16 : 11) + point.scale * 5.1, 0, Math.PI * 2);
          ctx.fill();
          ctx.globalAlpha = 1;
        });

        ALL_CATS_2D.forEach(function(cat) {
          var body = categoryBodyByCat[cat];
          if (!body) return;
          var point = project(body.x, body.y - 18, body.z, size.width, size.height);
          var label = catLabelEls[cat];
          if (!label) return;
          var isActive = activeCats.has(cat);
          label.style.transform =
            "translate(-50%,-50%) translate(" +
            point.x +
            "px," +
            point.y +
            "px) scale(" +
            (isActive ? 1.1 : hasActiveCats ? 0.98 : 1.02) +
            ")";
          label.style.opacity = String(isActive ? 1 : hasActiveCats ? 0.58 : 0.82);
          label.classList.toggle("is-active", isActive);
          label.classList.toggle("is-dim", hasActiveCats && !isActive);
        });

        frameworks.forEach(function(node, index) {
          var key = node.slug || node.title;
          var label = fwLabelEls[key];
          if (!label) return;
          var shouldShow =
            matchedFrameworkKeys.has(node.slug) || matchedFrameworkKeys.has(node.title);
          if (!shouldShow || !node.point) {
            label.style.opacity = "0";
            return;
          }
          var isHighlighted = highlightSet.has(index);
          label.style.transform =
            "translate(-50%,-50%) translate(" +
            node.point.x +
            "px," +
            (node.point.y - 20) +
            "px) scale(" +
            (isHighlighted ? 1.03 : 0.98) +
            ")";
          label.style.opacity = String(isHighlighted ? 1 : 0.82);
          label.style.filter = isHighlighted
            ? "drop-shadow(0 0 10px " + getSceneRgba(phase, 0.35) + ")"
            : "none";
        });
      }

      animate();
    }, 24);
  }
} // end initProdforce
</script>
