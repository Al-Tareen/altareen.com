---
import PageShell from "../components/PageShell.astro";

/**
 * Replace these with your real links/assets
 */
const profile = {
  name: "Al-Ebraheem Tareen",
  title: "AI Transformation • Product Management • Product Strategy",
  photo: "/images/about/al-tareen.jpeg",
  resumeUrl: "/files/Al-Tareen-Resume.pdf",
  linkedin: "https://www.linkedin.com/in/California",
  github: "https://github.com/Al-Tareen",
};
---

<PageShell title="About" hidePageHead={false}
description="Who I am and where to find me.">

  <section class="aboutPage" aria-label="About Al-Ebraheem Tareen">
    <div class="heroCard">
      <div class="heroGrid">
        <!-- Left column -->
        <div class="heroContent">
          <div class="nameBlock">
            <h1 class="heroTitle">{profile.name}</h1>
            <p class="heroSubtitle">{profile.title}</p>
            <div class="heroDivider" aria-hidden="true"></div>
          </div>

          <div class="copyStack">
            <p class="heroSummary">
              Visionary professional and strategic leader with a multi-year track record of driving
              revenue growth through AI, IT, and strategy. Experienced in project and
              product management, I break down complex challenges and lead global teams that
              accelerate digital transformation with scalable, efficient solutions and measurable ROI.
            </p>

            <p class="heroSummary heroSummarySecondary">
Leveraging critical thinking while deploying various mental models, I create long-term, difficult-to-replicate competitive advantage. Driven by execution, I preempt risks, tackle roadblocks, and devise strategic solutions viewing business as relentless value creation for teams and stakeholders, delivering innovative products while achieving transformative business outcomes.
            </p>
          </div>

          <div class="signatureLine" aria-hidden="true"></div>

          <p class="microNote">"An hour of planning can save you 10 hours of doing." — Unknown</p>
        </div>

        <!-- Right column -->
        <aside class="heroRail" aria-label="Profile and actions">
          <div class="profileCard">
            <div class="portraitShell">
              <div class="profileFrame">
                <img
                  class="profileImg"
                  src={profile.photo}
                  alt={`Portrait of ${profile.name}`}
                  loading="lazy"
                />
              </div>
            </div>

            <div class="profileInfo">
              <div class="profileName">{profile.name}</div>
              <div class="profileRole">Houston, TX</div>
            </div>

            <div class="railActions" role="group" aria-label="Primary actions">
              <a class="railBtn primary" href={profile.resumeUrl} download target="_blank" rel="noopener">
                <span class="railIcon" aria-hidden="true">↓</span>
                <span class="railText">Resume</span>
              </a>

              <a class="railBtn" href={profile.linkedin} target="_blank" rel="noopener">
                <span class="railIcon railIconText" aria-hidden="true">in</span>
                <span class="railText">LinkedIn</span>
              </a>

              <a class="railBtn" href={profile.github} target="_blank" rel="noopener">
                <span class="railIcon" aria-hidden="true">⌘</span>
                <span class="railText">GitHub</span>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <style>
    .aboutPage {
      width: 100%;
      max-width: var(--content-width);
      margin: 0 auto;
      padding: 10px 0 72px; /* more breathing room before footer */
      position: relative;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      box-sizing: border-box;
      background: transparent;
    }

    .aboutPage::before,
    .aboutPage::after {
      display: none !important;
      content: none !important;
    }

    /* Outer shell aligns with homepage card language */
    .heroCard {
      margin-top: 6px;
      padding: 12px;
      border-radius: 20px;
      border: 1px solid color-mix(in srgb, var(--border) 78%, transparent);
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--surface) 98%, white 2%),
          color-mix(in srgb, var(--surface) 98%, black 2%)
        );
      box-shadow:
        0 1px 0 rgba(255,255,255,0.62) inset,
        0 8px 20px rgba(0,0,0,0.02);
      position: relative;
      overflow: hidden;
      box-sizing: border-box;
    }

    .heroGrid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 332px;
      gap: 16px;
      align-items: stretch;
      position: relative;
      z-index: 1;
    }

    /* Left content panel */
    .heroContent {
      min-width: 0;
      border-radius: 16px;
      padding: 22px 22px 20px;
      border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
      background: rgba(255, 255, 255, 0.74);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
      box-sizing: border-box;
    }

    .nameBlock {
      margin-bottom: 14px;
    }

    .heroTitle {
      margin: 0;
      color: var(--ink);
      font-size: clamp(1.95rem, 4vw, 3rem);
      font-weight: 650; /* match homepage */
      line-height: 1.02;
      letter-spacing: -0.038em;
      text-wrap: balance;
    }

    .heroSubtitle {
      margin: 10px 0 0;
      color: color-mix(in srgb, var(--ink-secondary, var(--ink-muted)) 90%, var(--ink) 10%);
      font-size: 0.93rem;
      line-height: 1.45;
      font-weight: 500;
      letter-spacing: -0.01em;
      text-wrap: balance;
    }

    .heroDivider {
      width: 100%;
      height: 1px;
      margin: 14px 0 0;
      background: linear-gradient(
        90deg,
        color-mix(in srgb, var(--border) 78%, transparent) 0%,
        color-mix(in srgb, var(--border) 54%, transparent) 48%,
        transparent 100%
      );
    }

    .copyStack {
      display: grid;
      gap: 10px;
    }

    .heroSummary {
      margin: 0;
      color: color-mix(in srgb, var(--ink-secondary, var(--ink-muted)) 90%, var(--ink) 10%);
      font-size: 0.93rem;
      line-height: 1.64;
      max-width: 64ch;
      letter-spacing: -0.005em;
    }

    .heroSummarySecondary {
      color: color-mix(in srgb, var(--ink-secondary, var(--ink-muted)) 88%, var(--ink) 12%);
    }

    .signatureLine {
      margin-top: 14px;
      width: 72px;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(
        90deg,
        color-mix(in srgb, var(--ink) 32%, transparent),
        color-mix(in srgb, var(--ink) 10%, transparent)
      );
    }

    .microNote {
      margin: 10px 0 0;
      color: color-mix(in srgb, var(--ink-muted) 88%, var(--ink) 12%);
      font-size: 0.84rem;
      line-height: 1.35;
      letter-spacing: -0.01em;
    }

    /* Right rail */
    .heroRail {
      min-width: 0;
      display: flex;
      flex-direction: column;
    }

    .profileCard {
      min-width: 0;
      height: 100%;
      border-radius: 16px;
      border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--surface) 98%, white 2%),
          color-mix(in srgb, var(--surface) 98%, black 2%)
        );
      box-shadow:
        0 1px 0 rgba(255,255,255,0.62) inset,
        0 8px 20px rgba(0,0,0,0.018);
      padding: 16px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      box-sizing: border-box;
    }

    .portraitShell {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 2px 0 0;
    }

    .profileFrame {
      width: min(224px, 100%);
      aspect-ratio: 1 / 1;
      border-radius: 999px;
      padding: 4px;
      background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,255,255,0.78));
      border: 1px solid color-mix(in srgb, var(--border) 76%, transparent);
      box-shadow:
        0 10px 24px rgba(0, 0, 0, 0.08),
        inset 0 1px 0 rgba(255,255,255,0.95);
      position: relative;
      margin: 0 auto;
      flex: 0 0 auto;
      box-sizing: border-box;
    }

    .profileFrame::after {
      content: "";
      position: absolute;
      inset: 4px;
      border-radius: 999px;
      pointer-events: none;
      background: linear-gradient(
        180deg,
        rgba(255,255,255,0.14) 0%,
        rgba(255,255,255,0) 42%
      );
    }

    .profileImg {
      display: block;
      width: 100%;
      height: 100%;
      border-radius: 999px;
      object-fit: cover;
      object-position: center 22%;
      transform: scale(1.02);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.26);
    }

    .profileInfo {
      margin-top: 12px;
      text-align: center;
      padding: 0 2px;
    }

    .profileName {
      font-size: 0.98rem;
      font-weight: 650;
      line-height: 1.2;
      letter-spacing: -0.02em;
      color: var(--ink);
      text-wrap: balance;
    }

    .profileRole {
      margin-top: 4px;
      font-size: 0.82rem;
      line-height: 1.3;
      color: color-mix(in srgb, var(--ink-muted) 88%, var(--ink) 12%);
    }

    .railActions {
      width: 100%;
      min-width: 0;
      margin-top: 14px;
      padding-top: 12px;
      border-top: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
      display: grid;
      gap: 8px;
    }

    /* Button system aligned with homepage/Contact page */
    .railBtn {
      width: 100%;
      min-width: 0;
      box-sizing: border-box;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-height: 40px;
      padding: 0 12px;
      border-radius: 10px;
      text-decoration: none;
      border: 1px solid color-mix(in srgb, var(--border) 78%, transparent);
      background: color-mix(in srgb, var(--surface) 98%, black 2%);
      color: var(--ink);
      box-shadow: 0 1px 0 rgba(255,255,255,0.60) inset;
      transition:
        background-color 0.18s var(--ease),
        border-color 0.18s var(--ease),
        color 0.18s var(--ease),
        box-shadow 0.18s var(--ease),
        transform 0.18s var(--ease);
    }

    .railBtn:hover {
      background: color-mix(in srgb, var(--surface) 95%, black 2%);
      border-color: color-mix(in srgb, var(--border) 92%, transparent);
      transform: translateY(-1px);
    }

    .railBtn.primary {
      background: var(--ink);
      color: var(--surface);
      border-color: var(--ink);
      box-shadow: 0 1px 0 rgba(255,255,255,0.10) inset;
    }

    .railBtn.primary:hover {
      background: color-mix(in srgb, var(--ink) 92%, black 8%);
      border-color: color-mix(in srgb, var(--ink) 92%, black 8%);
    }

    .railIcon {
      width: 16px;
      height: 16px;
      flex: 0 0 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 600;
      line-height: 1;
      letter-spacing: 0;
      opacity: 0.9;
      color: currentColor;
      transform: translateY(-0.5px);
    }

    .railIconText {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .railText {
      flex: 1;
      min-width: 0;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      text-align: left;
      font-size: 14px;
      font-weight: 550;
      line-height: 1;
      letter-spacing: -0.01em;
      color: inherit;
    }

    :where(.railBtn):focus-visible {
      outline: none;
      border-color: color-mix(in srgb, var(--border) 92%, transparent);
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.06);
    }

    @media (max-width: 1080px) {
      .heroGrid {
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .profileCard {
        height: auto;
      }

      .profileFrame {
        width: min(208px, 100%);
      }
    }

    @media (max-width: 720px) {
      .aboutPage {
        max-width: none;
        width: 100%;
        padding: 0 0 52px;
        overflow-x: clip;
        box-sizing: border-box;
      }

      .heroCard {
        margin-top: 0;
        padding: 10px;
        border-radius: 16px;
      }

      .heroGrid,
      .heroContent,
      .profileCard {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
      }

      .heroRail { order: 1; }
      .heroContent { order: 2; }

      .heroContent {
        padding: 14px;
        border-radius: 14px;
      }

      .heroTitle {
        font-size: clamp(1.7rem, 8vw, 2.2rem);
      }

      .heroSubtitle {
        font-size: 0.9rem;
      }

      .heroSummary {
        font-size: 0.9rem;
        line-height: 1.58;
      }

      .signatureLine {
        margin-top: 12px;
      }

      .microNote {
        margin-top: 8px;
        font-size: 0.82rem;
      }

      .profileCard {
        padding: 14px;
        border-radius: 14px;
      }

      .profileFrame {
        width: min(190px, 100%);
      }

      .profileInfo {
        margin-top: 10px;
      }

      .railActions {
        margin-top: 12px;
        padding-top: 10px;
        gap: 8px;
      }

      .railBtn {
        min-height: 38px;
        padding: 0 11px;
      }

      .railText {
        font-size: 13px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .railBtn {
        transition: none !important;
      }

      .railBtn:hover {
        transform: none !important;
      }
    }
  </style>
</PageShell>