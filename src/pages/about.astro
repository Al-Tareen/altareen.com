    }

.actionBtn {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-height: 40px;
  padding: 10px 12px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.92);
  color: var(--ink);
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: -0.01em;
  box-shadow: 0 1px 0 rgba(255,255,255,0.62) inset;
  transition:
    transform 0.2s var(--ease),
    box-shadow 0.2s var(--ease),
    border-color 0.2s var(--ease),
    background 0.2s var(--ease);
  cursor: pointer;
  font: inherit;
  text-align: left;
  appearance: none;
}

.actionBtn:hover {
  transform: translateY(-1px);
  border-color: var(--border-strong);
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.04);
  background: #fff;
}

.actionBtn:active:not(:disabled) {
  transform: translateY(0);
}

.actionBtn.primary {
  background: var(--ink);
  color: var(--surface);
  border-color: rgba(0, 0, 0, 0.1);
  box-shadow: 0 6px 14px rgba(0, 0, 0, 0.12);
  font-weight: 600;
}

.actionBtn.primary:hover {
  background: #202024;
  border-color: rgba(0, 0, 0, 0.14);
}

.actionBtn:disabled {
  opacity: 0.78;
  cursor: not-allowed;
}

.actionBtnIcon {
  width: 16px;
  height: 16px;
  flex: 0 0 16px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  line-height: 1;
  color: currentColor;
}

.actionBtnIconText {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: -0.01em;
}

.actionBtnText {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  text-align: left;
  font-size: 13px;
  font-weight: 550;
  line-height: 1;
  letter-spacing: -0.01em;
  color: inherit;
}

.actionBtnSubmit {
  width: auto;
  min-width: 160px;
  justify-content: center;
  padding: 10px 16px;
}

.actionBtnSubmit .actionBtnText {
  flex: 0 1 auto;
  text-align: center;
}

    :where(.actionBtn, .emailLink, .dialogClose):focus-visible {
      outline: none;
      border-color: color-mix(in srgb, var(--border) 92%, transparent);
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.06);
    }

    .contactModalShell {
      position: fixed;
      inset: 0;
      z-index: 260;
      padding: 24px;
      display: grid;
      place-items: center;
    }

    .contactModalShell[hidden] {
      display: none !important;
    }

    .contactBackdrop {
      position: absolute;
      inset: 0;
      background: rgba(10, 14, 22, 0.42);
      backdrop-filter: blur(18px) saturate(115%);
      -webkit-backdrop-filter: blur(18px) saturate(115%);
    }

    .contactDialog {
      position: relative;
      width: min(1040px, calc(100vw - 32px));
      max-height: min(90vh, 860px);
      border-radius: 22px;
      border: 1px solid rgba(255,255,255,0.14);
      background:
        linear-gradient(
          180deg,
          rgba(255,255,255,0.94) 0%,
          rgba(248,248,250,0.9) 100%
        );
      box-shadow:
        0 1px 0 rgba(255,255,255,0.72) inset,
        0 42px 120px rgba(0,0,0,0.22);
      overflow: hidden;
      box-sizing: border-box;
      backdrop-filter: blur(22px);
      -webkit-backdrop-filter: blur(22px);
      transform: translateY(12px) scale(0.985);
      opacity: 0;
      transition:
        transform 0.22s var(--ease),
        opacity 0.22s var(--ease);
    }

    .contactDialog::before {
