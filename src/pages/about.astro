---
import PageShell from "../components/PageShell.astro";

const web3formsKey = "a662d525-6081-49f0-b6d7-6102e3bf1ec2";

const profile = {
  name: "Al-Ebraheem Tareen",
  title: "AI Transformation • Product Management • Product Strategy",
  photo: "/images/about/altareen.jpg",
  linkedin: "https://www.linkedin.com/in/California",
  github: "https://github.com/Al-Tareen",
  resumeUrl: "/files/Al-Tareen-Resume.pdf",
  email: "altareenk@outlook.com",
  location: "Houston, TX",
};

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  alternateName: "Al Tareen",
  url: "https://altareen.com/about/",
  image: "https://altareen.com/images/about/altareen.jpg",
  jobTitle: profile.title,
  email: profile.email,
  homeLocation: {
    "@type": "Place",
    name: profile.location,
  },
  sameAs: [profile.linkedin, profile.github],
};

const aboutBreadcrumbs = [
  { name: "Home", path: "/" },
  { name: "About", path: "/about/" },
];
---

<PageShell
  title="About"
  hidePageHead={false}
  description="Who I am and where to find me."
  keywords="About Al Tareen, AI transformation, product management leader, product strategy, Houston"
  schema={aboutSchema}
  breadcrumbs={aboutBreadcrumbs}
>
  <section class="aboutPage" aria-label="About Al-Ebraheem Tareen">
    <div class="aboutSplitGrid">
      <article class="aboutPanel aboutPanelCopy">
        <div class="aboutCopy">
          <div class="nameBlock">
            <p class="heroSubtitle">{profile.title}</p>
            <div class="heroDivider" aria-hidden="true"></div>
          </div>

          <div class="copyStack">
            <p class="heroSummary">
              Visionary professional and strategic leader with a multi-year track record of driving
              revenue growth through AI, IT, and strategy. Experienced in project and product
              management, I break down complex challenges and lead global teams that accelerate
              digital transformation with scalable, efficient solutions and measurable ROI.
            </p>

            <p class="heroSummary heroSummarySecondary">
              Leveraging critical thinking while deploying various mental models, I create long-term,
              difficult-to-replicate competitive advantage. Driven by execution, I preempt risks,
              tackle roadblocks, and devise strategic solutions while viewing business as relentless
              value creation for teams and stakeholders, delivering innovative products while
              achieving transformative business outcomes.
            </p>
          </div>

          <div class="signatureLine" aria-hidden="true"></div>

          <p class="microNote">“An hour of planning can save you 10 hours of doing.” — Unknown</p>
        
        
        </div>
      </article>

      <aside class="aboutPanel aboutPanelRail" aria-label="Profile and actions">
        <div class="profileRail">
          <div class="portraitShell">
            <div class="profileFrame">
              <img
                class="profileImg"
                src={profile.photo}
                alt={`Portrait of ${profile.name}`}
                loading="lazy"
              />
            </div>
          </div>

          <div class="profileInfo">
            <div class="profileName">{profile.name}</div>
            <div class="profileRole">{profile.location}</div>
          </div>

          <div class="railActions" role="group" aria-label="Primary actions">
            <button class="actionBtn primary js-open-contact"
        type="button"
        onclick="trackEvent('contact_open')">
              <span class="actionBtnIcon" aria-hidden="true">✉</span>
              <span class="actionBtnText">Contact</span>
            </button>

<a class="actionBtn"
   href={profile.linkedin}
   target="_blank"
   rel="noopener"
   onclick="trackEvent('outbound_click', { destination: 'linkedin' })">
                 <span class="actionBtnIcon actionBtnIconText" aria-hidden="true">in</span>
              <span class="actionBtnText">LinkedIn</span>
            </a>

            <a class="actionBtn" href={profile.github} target="_blank" rel="noopener" onclick="trackEvent('outbound_click', { destination: 'github' })">
              <span class="actionBtnIcon" aria-hidden="true">⌘</span>
              <span class="actionBtnText">GitHub</span>
            </a>

            <a class="actionBtn" href={profile.resumeUrl} download target="_blank" rel="noopener" onclick="trackEvent('resume_click')">
              <span class="actionBtnIcon" aria-hidden="true">↓</span>
              <span class="actionBtnText">Resume</span>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <div class="contactModalShell" id="contact-modal" hidden aria-hidden="true">
    <div class="contactBackdrop" data-contact-close></div>

    <div
      class="contactDialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="contact-modal-title"
      aria-describedby="contact-modal-copy"
    >
      <div class="contactDialogHeader">
        <div class="dialogTitleBlock">
          <div class="dialogLabel">Connect</div>
          <h2 id="contact-modal-title" class="dialogTitle">Contact</h2>
          <p id="contact-modal-copy" class="dialogIntro">
            Send a message directly or reach me by email.
          </p>
        </div>

        <button
          class="dialogClose"
          type="button"
          aria-label="Close contact dialog"
          data-contact-close
        >
          <span aria-hidden="true">×</span>
        </button>
      </div>

      <div class="contactDialogBody">
        <div class="dialogFormPane">
          <div class="formCard">
            <form
              id="about-contact-form"
              class="form"
              action="https://api.web3forms.com/submit"
              method="POST"
              aria-label="Contact form"
            >
              <input type="hidden" name="access_key" value={web3formsKey} />
              <input type="hidden" name="subject" value="Contact from altareen.com" />
              <input type="hidden" name="from_name" value="altareen.com Contact Form" />

              <input
                type="checkbox"
                name="botcheck"
                class="gotcha"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
              />

              <div class="fieldRow">
                <div class="field">
                  <label for="contact-name">Name</label>
                  <input
                    type="text"
                    id="contact-name"
                    name="name"
                    required
                    autocomplete="name"
                    placeholder="Your name"
                  />
                </div>

                <div class="field">
                  <label for="contact-email">Email</label>
                  <input
                    type="email"
                    id="contact-email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="you@example.com"
                  />
                </div>
              </div>

              <div class="field">
                <label for="contact-message">Message</label>
                <textarea
                  id="contact-message"
                  name="message"
                  required
                  rows="6"
                  placeholder="Feel free to share what’s on your mind, what you need help with, and any additional details."
                ></textarea>
              </div>

              <div class="actions">
                <button type="submit" class="actionBtn primary actionBtnSubmit" id="about-submit-btn">
                  <span class="actionBtnIcon" aria-hidden="true">→</span>
                  <span class="actionBtnText">Send message</span>
                </button>
              </div>
            </form>

            <div id="form-success" class="success" hidden>
              <p class="successTitle">Message sent.</p>
              <p class="successText">Thanks — I’ll get back to you as soon as I can.</p>
            </div>

            <div id="form-error" class="error" hidden>
              <p class="errorText">Something went wrong. Please email me directly instead.</p>
            </div>
          </div>
        </div>

        <aside class="dialogSidePane" aria-label="Direct contact">
          <div class="sideCard">
            <div class="miniLabel">Direct contact</div>

            <div class="emailBlock">
              <div class="emailLabel">Email</div>
              <a class="emailLink" href={`mailto:${profile.email}`}>{profile.email}</a>
            </div>

            <div class="sideActions">
              <a class="actionBtn primary" href={`mailto:${profile.email}`}>
                <span class="actionBtnIcon" aria-hidden="true">✉</span>
                <span class="actionBtnText">Email me</span>
              </a>

              <button
                class="actionBtn"
                type="button"
                id="copy-email-btn"
                data-email={profile.email}
              >
                <span class="actionBtnIcon" aria-hidden="true">⧉</span>
                <span class="actionBtnText" id="copy-email-text">Copy email</span>
              </button>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <script>
    const modal = document.getElementById("contact-modal");
    const dialog = modal?.querySelector(".contactDialog");
    const openButtons = document.querySelectorAll(".js-open-contact");
    const closeButtons = modal?.querySelectorAll("[data-contact-close]");
    const firstField = document.getElementById("contact-name");

    let lastFocusedEl = null;
    let closeTimer = null;

    function getFocusableEls() {
      if (!dialog) return [];
      return Array.from(
        dialog.querySelectorAll(
          'a[href], button:not([disabled]), textarea, input:not([type="hidden"]), select, [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => !el.hasAttribute("hidden"));
    }

    function openModal() {
      if (!modal) return;

      if (closeTimer) {
        window.clearTimeout(closeTimer);
        closeTimer = null;
      }

      lastFocusedEl = document.activeElement;
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("contact-modal-open");

      requestAnimationFrame(() => {
        modal.dataset.open = "true";
      });

      window.setTimeout(() => {
        firstField?.focus();
      }, 80);
    }

    function closeModal() {
      if (!modal) return;

      modal.dataset.open = "false";
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("contact-modal-open");

      closeTimer = window.setTimeout(() => {
        modal.hidden = true;
        if (lastFocusedEl && typeof lastFocusedEl.focus === "function") {
          lastFocusedEl.focus();
        }
      }, 220);
    }

    openButtons.forEach((btn) => {
      btn.addEventListener("click", openModal);
    });

    closeButtons?.forEach((btn) => {
      btn.addEventListener("click", closeModal);
    });

    document.addEventListener("keydown", (event) => {
      if (!modal || modal.hidden) return;

      if (event.key === "Escape") {
        closeModal();
        return;
      }

      if (event.key === "Tab") {
        const focusable = getFocusableEls();
        if (!focusable.length) return;

        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }
    });

    const form = document.getElementById("about-contact-form");
    const submitBtn = document.getElementById("about-submit-btn");
    const successEl = document.getElementById("form-success");
    const errorEl = document.getElementById("form-error");
    const useAjax = form?.action && form.action.includes("web3forms");

   if (form && useAjax && submitBtn && successEl && errorEl) {
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending...";
    successEl.setAttribute("hidden", "");
    errorEl.setAttribute("hidden", "");

    const formData = new FormData(form);

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: {
          Accept: "application/json",
        },
      });

      const data = await res.json();

      if (res.ok && data.success) {
        form.reset();
        successEl.removeAttribute("hidden");

        // REAL conversion tracking
        trackEvent('contact_submit');
      } else {
        errorEl.removeAttribute("hidden");
        console.error("Web3Forms error:", data);
      }
    } catch (err) {
      errorEl.removeAttribute("hidden");
      console.error("Contact form submit failed:", err);
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML =
        '<span class="actionBtnIcon" aria-hidden="true">→</span><span class="actionBtnText">Send message</span>';
    }
  });
}

    const copyEmailBtn = document.getElementById("copy-email-btn");
    const copyEmailText = document.getElementById("copy-email-text");

    if (copyEmailBtn && copyEmailText) {
      copyEmailBtn.addEventListener("click", async () => {
        const email = copyEmailBtn.getAttribute("data-email");
        if (!email) return;

        try {
          await navigator.clipboard.writeText(email);
          copyEmailText.textContent = "Copied";
          setTimeout(() => {
            copyEmailText.textContent = "Copy email";
          }, 1400);
        } catch {
          copyEmailText.textContent = "Copy failed";
          setTimeout(() => {
            copyEmailText.textContent = "Copy email";
          }, 1400);
        }
      });
    }
  </script>

  <style>
    :global(body.contact-modal-open) {
      overflow: hidden;
    }

