---
import PageShell from "../../components/PageShell.astro";
import { getCollection } from "astro:content";

const IDEAS_CATEGORY = "Business Plans";

const all = await getCollection("toolkit");

// Only show items from the Business Plans category
const items = all.filter(
  (item) => (item.data.primaryCategory || "Uncategorized").trim() === IDEAS_CATEGORY
);

console.log("ideas total:", items.length);

// Build grouped structure
const groupsMap = new Map();
for (const item of items) {
  const c = (item.data.primaryCategory || "Uncategorized").trim();
  if (!groupsMap.has(c)) groupsMap.set(c, []);
  groupsMap.get(c).push(item);
}

const categories = Array.from(groupsMap.keys()).sort((a, b) => a.localeCompare(b));
for (const c of categories) {
  groupsMap.get(c).sort((a, b) => a.data.title.localeCompare(b.data.title));
}
const groups = categories.map((c) => ({ category: c, items: groupsMap.get(c) }));

function catId(name) {
  return (
    "cat-" +
    String(name || "")
      .trim()
      .toLowerCase()
      .replace(/['"]/g, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
  );
}

// Featured (Notion checkbox -> frontmatter `featured: true`)
const featured = items.filter((i) => i.data.featured === true).slice(0, 8);
---

<PageShell
  title="Concepts"
  description="Early-stage concepts and strategic business ideas."
>
  <div class="toolkit">
    {featured.length > 0 && (
      <section class="featuredBlock" id="__featured" data-group="__featured">
        <div class="groupHead">
          <h2 class="groupTitle">
            Featured <span class="count">({featured.length})</span>
          </h2>
        </div>

        <div class="grid">
          {featured.map((item) => (
            <a
              class="card"
              href={`/concepts/${item.slug}/`}
              data-title={item.data.title}
              data-category={item.data.primaryCategory || "Uncategorized"}
              data-when={item.data.whenToUse || ""}
              data-featured="true"
            >
              {item.data.cover ? (
                <div class="thumb" aria-hidden="true">
                  <img
                    class="cover"
                    src={item.data.cover}
                    alt={`Cover for ${item.data.title}`}
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="thumb thumbEmpty" aria-hidden="true">
                  <span class="thumbMark">AL</span>
                </div>
              )}

              <div class="meta">
                <div class="cardTitle">{item.data.title}</div>

                <div class="excerpt">
                  <div class="excerptLabel">Description</div>
                  <div class="whenToUse">
                    {item.data.whenToUse ? item.data.whenToUse : <span class="muted">No description yet.</span>}
                  </div>
                </div>

                {Array.isArray(item.data.tags) && item.data.tags.length > 0 && (
                  <div class="tagsRow" aria-label="Tags">
                    {item.data.tags.slice(0, 4).map((tag) => (
                      <span class="tagChip">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {groups.map((g) => (
      <section class="group" id={catId(g.category)} data-group={g.category}>
        <div class="groupHead">
          <h2 class="groupTitle">
            {g.category} <span class="count">({g.items.length})</span>
          </h2>
          <div class="groupRule" aria-hidden="true"></div>
        </div>

        <div class="grid">
          {g.items.map((item) => (
            <a
              class="card"
              href={`/concepts/${item.slug}/`}
              data-title={item.data.title}
              data-category={item.data.primaryCategory || "Uncategorized"}
              data-when={item.data.whenToUse || ""}
            >
              {item.data.cover ? (
                <div class="thumb" aria-hidden="true">
                  <img
                    class="cover"
                    src={item.data.cover}
                    alt={`Cover for ${item.data.title}`}
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="thumb thumbEmpty" aria-hidden="true">
                  <span class="thumbMark">AL</span>
                </div>
              )}

              <div class="meta">
                <div class="cardTitle">{item.data.title}</div>

                <div class="excerpt">
                  <div class="excerptLabel">Description</div>
                  <div class="whenToUse">
                    {item.data.whenToUse ? item.data.whenToUse : <span class="muted">No description yet.</span>}
                  </div>
                </div>

                {Array.isArray(item.data.tags) && item.data.tags.length > 0 && (
                  <div class="tagsRow" aria-label="Tags">
                    {item.data.tags.slice(0, 4).map((tag) => (
                      <span class="tagChip">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <button id="toTop" class="toTop" type="button" aria-label="Back to top">↑ Top</button>

    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        const toTop = document.getElementById("toTop");
        if (!toTop) return;

        function updateToTop() {
          const show = window.scrollY > 420;
          toTop.classList.toggle("isVisible", show);
        }

        window.addEventListener("scroll", updateToTop, { passive: true });
        toTop.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
        updateToTop();
      });
    </script>

    <style>
      .toolkit {
        padding-top: 8px;
        padding-bottom: 72px;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .group,
      .featuredBlock {
        scroll-margin-top: 96px;
      }

      .isHidden {
        display: none !important;
      }

      .featuredBlock {
        margin-top: 12px;
        padding: 18px;
        border-radius: 16px;
        border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
        background:
          linear-gradient(
            180deg,
            color-mix(in srgb, var(--surface) 98%, white 2%),
            color-mix(in srgb, var(--surface) 98%, black 2%)
          );
        box-shadow:
          0 1px 0 rgba(255,255,255,0.62) inset,
          0 8px 20px rgba(0,0,0,0.018);
      }

      .group {
        margin-top: 0;
      }

      .group + .group {
        margin-top: 34px;
      }

      .groupHead {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 12px;
      }

      .groupTitle {
        margin: 0;
        color: var(--ink);
        font-size: 1rem;
        font-weight: 650;
        letter-spacing: -0.02em;
        line-height: 1.2;
      }

      .count {
        font-weight: 500;
        color: color-mix(in srgb, var(--ink-muted) 88%, var(--ink) 12%);
        font-size: 0.9em;
      }

      .groupRule {
        display: none;
      }

      .grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(auto-fill, minmax(272px, 1fr));
        align-items: stretch;
      }

      .card {
        display: flex;
        flex-direction: column;
        border-radius: 16px;
        text-decoration: none;
        overflow: hidden;
        border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
        background:
          linear-gradient(
            180deg,
            color-mix(in srgb, var(--surface) 98%, white 2%),
            color-mix(in srgb, var(--surface) 98%, black 2%)
          );
        box-shadow:
          0 1px 0 rgba(255,255,255,0.62) inset,
          0 8px 20px rgba(0,0,0,0.018);
        height: 100%;
        color: inherit;
        transition:
          transform 0.2s var(--ease),
          box-shadow 0.2s var(--ease),
          border-color 0.2s var(--ease);
        box-sizing: border-box;
      }

      .card:hover {
        transform: translateY(-1px);
        border-color: color-mix(in srgb, var(--border) 92%, transparent);
        box-shadow:
          0 1px 0 rgba(255,255,255,0.72) inset,
          0 12px 24px rgba(0,0,0,0.035);
      }

      .thumb {
        width: 100%;
        aspect-ratio: 16/9;
        background: linear-gradient(180deg, rgba(0, 0, 0, 0.015) 0%, transparent 100%);
        border-bottom: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      .thumb::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 55%, rgba(0, 0, 0, 0.025));
        pointer-events: none;
      }

      .cover {
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        display: block;
        padding: 5px;
        box-sizing: border-box;
        transition: transform 0.22s var(--ease);
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.86);
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--border) 68%, transparent);
      }

      .card:hover .cover {
        transform: scale(1.01);
      }

      .thumbEmpty {
        background: linear-gradient(145deg, rgba(0, 0, 0, 0.025), rgba(0, 0, 0, 0.01));
      }

      .thumbMark {
        font-weight: 700;
        letter-spacing: 0.08em;
        font-size: 12px;
        color: var(--ink-muted);
        border: 1px solid color-mix(in srgb, var(--border) 76%, transparent);
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.75);
      }

      .meta {
        padding: 16px 16px 18px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 132px;
        height: 100%;
        box-sizing: border-box;
      }

      .cardTitle {
        margin: 0;
        color: var(--ink);
        font-weight: 650;
        letter-spacing: -0.015em;
        line-height: 1.22;
        font-size: 1rem;
      }

      .excerpt {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-top: 0;
        flex: 1;
      }

      .excerptLabel {
        font-size: 10px;
        line-height: 1.1;
        letter-spacing: 0.085em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--ink-muted) 84%, var(--ink) 16%);
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 700;
      }

      .excerptLabel::before {
        content: "";
        width: 8px;
        height: 1px;
        background: color-mix(in srgb, var(--border) 80%, transparent);
      }

      .whenToUse {
        color: color-mix(in srgb, var(--ink-secondary, var(--ink-muted)) 88%, var(--ink) 12%);
        font-size: 0.88rem;
        line-height: 1.52;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: calc(1.52em * 3);
        max-height: calc(1.52em * 3);
      }

      .muted {
        color: var(--ink-muted);
      }

      .tagsRow {
        margin-top: auto;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        padding-top: 2px;
        min-height: 48px;
        align-content: flex-start;
      }

      .tagsRow:empty {
        display: none;
      }

      .tagChip {
        display: inline-flex;
        align-items: center;
        max-width: 100%;
        padding: 5px 8px;
        border-radius: 999px;
        border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
        background: rgba(0, 0, 0, 0.025);
        color: color-mix(in srgb, var(--ink-muted) 82%, var(--ink) 18%);
        font-size: 11px;
        font-weight: 550;
        line-height: 1;
        white-space: nowrap;
      }

      .toTop {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 60;
        min-height: 36px;
        padding: 0 12px;
        border-radius: 999px;
        border: 1px solid color-mix(in srgb, var(--border) 78%, transparent);
        background: color-mix(in srgb, var(--surface) 96%, white 4%);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow:
          0 1px 0 rgba(255,255,255,0.62) inset,
          0 10px 20px rgba(0,0,0,0.05);
        cursor: pointer;
        opacity: 0;
        transform: translateY(8px);
        pointer-events: none;
        transition: opacity 0.2s var(--ease), transform 0.2s var(--ease), border-color 0.2s var(--ease);
        font-size: 12px;
        font-weight: 600;
        color: color-mix(in srgb, var(--ink-muted) 78%, var(--ink) 22%);
      }

      .toTop.isVisible {
        opacity: 0.98;
        transform: translateY(0);
        pointer-events: auto;
      }

      .toTop:hover {
        color: var(--ink);
        border-color: color-mix(in srgb, var(--border) 92%, transparent);
      }

      @media (max-width: 720px) {
        .toolkit {
          padding-bottom: 52px;
        }

        .featuredBlock {
          padding: 12px;
          border-radius: 14px;
        }

        .grid {
          gap: 10px;
          grid-template-columns: 1fr;
        }

        .card {
          border-radius: 14px;
        }

        .meta {
          padding: 14px;
          gap: 8px;
        }

        .cardTitle {
          font-size: 0.96rem;
        }

        .whenToUse {
          font-size: 0.86rem;
          line-height: 1.48;
          min-height: calc(1.48em * 3);
          max-height: calc(1.48em * 3);
        }

        .toTop {
          right: 14px;
          bottom: 14px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          scroll-behavior: auto !important;
        }

        .card,
        .cover,
        .toTop {
          transition: none !important;
        }

        .card:hover {
          transform: none !important;
        }
      }
    </style>
  </div>
</PageShell>