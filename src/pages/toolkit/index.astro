    );
}

  /* =========================================================
     6) GRID / CARDS
     ========================================================= */

  .grid {
    display: grid;
    width: 100%;
    max-width: 1680px;
    margin-inline: auto;
    column-gap: 12px;
    row-gap: 16px;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    align-items: stretch;
  }

  .card {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    text-decoration: none;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 99%, white 1%),
        color-mix(in srgb, var(--surface) 98%, black 2%)
      );
    box-shadow:
      0 1px 0 rgba(255,255,255,0.68) inset,
      0 10px 24px rgba(15, 23, 42, 0.026);
    height: 100%;
    color: inherit;
    transition:
      transform 0.2s var(--ease),
      box-shadow 0.2s var(--ease),
      border-color 0.2s var(--ease);
    box-sizing: border-box;
  }

  .card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.76) inset,
      0 16px 34px rgba(15, 23, 42, 0.05);
  }

  .thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10.5;
    overflow: hidden;
    background: color-mix(in srgb, var(--surface) 95%, black 5%);
  }

  .thumbEmpty {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .thumbMark {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.03em;
