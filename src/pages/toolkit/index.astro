}

.analyticsGrid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
}

/* =========================================================
   CARD BASE
   ========================================================= */

.analyticsCard {
  position: relative;
  overflow: hidden;
  border-radius: 20px;
  padding: 18px 18px 16px;
  min-height: 132px;

  border: 1px solid rgba(255, 255, 255, 0.72);

  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,0.94) 0%,
      rgba(250,250,252,0.9) 46%,
      rgba(244,245,248,0.88) 100%
    );

  backdrop-filter: blur(18px) saturate(125%);
  -webkit-backdrop-filter: blur(18px) saturate(125%);

  box-shadow:
    0 1px 0 rgba(255,255,255,0.95) inset,
    0 10px 24px rgba(15, 23, 42, 0.045),
    0 22px 44px rgba(15, 23, 42, 0.03);

  transition:
    transform 0.22s var(--ease),
    box-shadow 0.22s var(--ease),
    border-color 0.22s var(--ease),
    background 0.22s var(--ease);
}

.analyticsCard::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  border-radius: inherit;
  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,0.52) 0%,
      rgba(255,255,255,0.18) 28%,
      rgba(255,255,255,0.04) 58%,
      rgba(255,255,255,0) 100%
    );
  opacity: 1;
}

.analyticsCard::after {
  content: "";
  position: absolute;
  inset: 1px;
  pointer-events: none;
  border-radius: calc(20px - 1px);
  background:
    radial-gradient(
      120% 90% at 50% 0%,
      rgba(255,255,255,0.38) 0%,
      rgba(255,255,255,0.12) 34%,
      rgba(255,255,255,0) 68%
    );
  opacity: 0.9;
}

.analyticsCard:hover {
  transform: translateY(-2px);
  border-color: rgba(255, 255, 255, 0.9);
  box-shadow:
    0 1px 0 rgba(255,255,255,0.98) inset,
    0 14px 28px rgba(15, 23, 42, 0.055),
    0 28px 52px rgba(15, 23, 42, 0.038);
}

/* old glow stays off */
.analyticsCardGlow {
  display: none;
}

/* =========================================================
   CONTENT STRUCTURE
   ========================================================= */

.analyticsBody {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.analyticsTop {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 10px;
}

.analyticsTitle {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
    color: rgb(5, 35, 80);
    text-align: center;
}

/* =========================================================
   CENTER CONTENT
   ========================================================= */

.analyticsCenter {
  margin-top: 12px;
  margin-bottom: auto;
}

.analyticsCenter--category .analyticsFrameworkName {
