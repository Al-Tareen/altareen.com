  .cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s var(--ease);
  }

  .card:hover .cover {
    transform: scale(1.02);
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px 14px 15px;
    min-height: 124px;
  }

  .cardTitle {
    margin: 0;
    color: var(--ink);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.14;
