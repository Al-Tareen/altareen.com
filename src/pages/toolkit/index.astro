---
import PageShell from "../../components/PageShell.astro";
import { getCollection } from "astro:content";
import analyticsData from "../../data/toolkit-analytics.json";

const HIDDEN_CATEGORIES = new Set(["Business Plans", "TBA", "Financial Models"]);

const all = await getCollection("toolkit");

// DEBUG
const dbTitles = Array.from(new Set(all.map((i) => i.data.dbTitle || ""))).sort();
console.log("toolkit total:", all.length);
console.log("dbTitles:", dbTitles);

const items = all
  .filter((item) => (item.data.dbTitle || "").trim() === "Frameworks")
  .filter((item) => !HIDDEN_CATEGORIES.has((item.data.primaryCategory || "Uncategorized").trim()));

console.log("frameworks visible:", items.length);

// Build grouped structure
const groupsMap = new Map();
for (const item of items) {
  const c = (item.data.primaryCategory || "Uncategorized").trim();
  if (!groupsMap.has(c)) groupsMap.set(c, []);
  groupsMap.get(c).push(item);
}

const categories = Array.from(groupsMap.keys()).sort((a, b) => a.localeCompare(b));
for (const c of categories) {
  groupsMap.get(c).sort((a, b) => a.data.title.localeCompare(b.data.title));
}
const groups = categories.map((c) => ({ category: c, items: groupsMap.get(c) }));

function catId(name) {
  return (
    "cat-" +
    String(name || "")
      .trim()
      .toLowerCase()
      .replace(/['"]/g, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
  );
}

// Featured (Notion checkbox -> frontmatter `featured: true`)
const featured = items.filter((i) => i.data.featured === true).slice(0, 8);

const getFrameworkName = (item) => item?.data?.title || "—";

function prettifyFrameworkName(value) {
  return String(value || "")
    .replace(/^ai-product-quality-risk-safety-/i, "")
    .replace(/^ai-/, "")
    .replace(/^pm-/, "")
    .replace(/-/g, " ")
    .replace(/\b\w/g, (m) => m.toUpperCase())
    .trim();
}

function findToolkitItemBySlugOrTitle(value) {
  const normalized = String(value || "").trim().toLowerCase();
  if (!normalized) return null;

  return (
    items.find((item) => item.slug.toLowerCase() === normalized) ||
    items.find((item) => item.data.title.toLowerCase() === normalized) ||
    null
  );
}

function buildAnalyticsCard(title, rawFrameworkName, metricLabel, metricValue, theme) {
  const matchedItem = findToolkitItemBySlugOrTitle(rawFrameworkName);

  return {
    title,
    frameworkName: matchedItem
      ? matchedItem.data.title
      : prettifyFrameworkName(rawFrameworkName) || "—",
    frameworkCategory: matchedItem
      ? (matchedItem.data.primaryCategory || "Uncategorized")
      : null,
    href: matchedItem ? `/toolkit/${matchedItem.slug}/` : null,
    metricLabel,
    metricValue: metricValue ?? 0,
    theme,
  };
}

const analyticsCards = [
  {
    title: "Top Category",
    frameworkName:
      analyticsData?.topCategory?.categoryName ||
      analyticsData?.topCategory?.frameworkName ||
      "—",
    frameworkCategory: "Most engaged category",
    href: null,
    metricLabel: "Selections",
    metricValue: analyticsData?.topCategory?.metricValue ?? 0,
    theme: "category",
  },
  buildAnalyticsCard(
    "Most Popular Framework",
    analyticsData?.mostPopular?.frameworkName,
    "Views",
    analyticsData?.mostPopular?.metricValue,
    "popular"
  ),
  buildAnalyticsCard(
    "Most Downloaded Framework",
    analyticsData?.mostDownloaded?.frameworkName,
    "Downloads",
    analyticsData?.mostDownloaded?.metricValue,
    "downloaded"
  ),
  buildAnalyticsCard(
    "Most Liked Framework",
    analyticsData?.mostLiked?.frameworkName,
    "Likes",
    analyticsData?.mostLiked?.metricValue,
    "liked"
  ),
];

const pmtoolkitBreadcrumbs = [
  { name: "Home", path: "/" },
  { name: "PM Toolkit", path: "/toolkit/" },
];
---

<PageShell
  title="Product Manager Toolkit"
  description="Frameworks that help product managers make better decisions."
  keywords="product manager toolkit, product management frameworks, PM frameworks, product strategy, prioritization, Altareen"
breadcrumbs={pmtoolkitBreadcrumbs}
>

<div class="toolkit" data-view="grid">
  <div class="controlsBar" role="search" aria-label="Search and filter frameworks">
    <div class="field">
      <span class="icon" aria-hidden="true">⌕</span>
      <input id="q" class="input" type="search" placeholder="Search frameworks…" />
    </div>

<div class="selectWrap">
  <select id="cat" class="select" aria-label="Filter by category">
    <option value="">All categories</option>
    {categories.map((c) => <option value={c}>{c}</option>)}
  </select>
<span class="selectChevron" aria-hidden="true">
  <img class="selectChevronIcon" src="/homepage/downarrow.png" alt="" />
</span></div>

    <div class="rightActions">
      <div class="resultsInline" id="resultsText">Showing {items.length} frameworks</div>

      <div class="viewToggle" role="group" aria-label="View toggle">
        <button id="viewGrid" class="toggleBtn isActive" type="button" aria-pressed="true">
          Grid
        </button>
        <button id="viewCompact" class="toggleBtn" type="button" aria-pressed="false">
          Compact
        </button>
      </div>

      <button id="clear" class="ghost" type="button">Clear</button>
    </div>
  </div> 

{analyticsCards.length > 0 && (
  <section class="analyticsStrip" aria-label="Framework performance overview">
    <div class="analyticsGrid">
      {analyticsCards.map((card) => (
        <article class={`analyticsCard analyticsCard--${card.theme}`}>
          <div class="analyticsCardGlow" aria-hidden="true"></div>

          <div class="analyticsBody">
            <div class="analyticsTop">
              <div class="analyticsTitle">{card.title}</div>
            </div>

            <div class={`analyticsCenter ${card.theme === "category" ? "analyticsCenter--category" : ""}`}>
              {card.href ? (
                <a class="analyticsFrameworkName analyticsFrameworkLink" href={card.href}>
                  {card.frameworkName}
                </a>
              ) : (
                <div class="analyticsFrameworkName">{card.frameworkName}</div>
              )}

              {card.frameworkCategory && card.theme !== "category" && (
                <div class="analyticsCategoryMeta">{card.frameworkCategory}</div>
              )}

              {card.theme === "category" && (
                <div class="analyticsCategoryMeta analyticsCategoryMeta--category">
                  
                </div>
              )}
            </div>

            <div class="analyticsBottomRow">
              <div class="analyticsMetricValue">{card.metricValue}</div>
              <div class="analyticsMetricSuffix">{card.metricLabel}</div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
)}

           <!-- Featured -->
    {featured.length > 0 && (
      <section class="featuredBlock" id="__featured" data-group="__featured" data-expanded="false">
        <div class="groupHead">
          <div class="groupTitleWrap">
            <h2 class="groupTitle">
              Featured <span class="count">({featured.length})</span>
            </h2>
            <div class="groupRule" aria-hidden="true"></div>
          </div>
        </div>

        <div class="groupReveal" data-expand-wrap>
          <div class="grid" data-expand-grid>
            {featured.map((item) => (
<a
  class="card"
  href={`/toolkit/${item.slug}/`}
  data-title={item.data.title}
  data-category={item.data.primaryCategory || "Uncategorized"}
  data-when={item.data.whenToUse || ""}
  data-featured="true"
  onclick={`trackEvent('framework_click', { framework: '${item.slug}', framework_name: '${item.data.title.replace(/'/g, "\\'")}', category: '${(item.data.primaryCategory || "Uncategorized").replace(/'/g, "\\'")}', featured: true })`}
>

                {item.data.cover ? (
                  <div class="thumb" aria-hidden="true">
                    <img class="cover" src={item.data.cover} alt={`Cover for ${item.data.title}`} loading="lazy" />
                  </div>
                ) : (
                  <div class="thumb thumbEmpty" aria-hidden="true">
                    <span class="thumbMark">AL</span>
                  </div>
                )}

                <div class="meta">
                  <div class="cardTitle">{item.data.title}</div>

                  <div class="excerpt">
                    <div class="excerptLabel">When to use</div>
                    <div class="whenToUse">
                      {item.data.whenToUse ? item.data.whenToUse : <span class="muted">—</span>}
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

<div class="groupFooter">
  <button
    class="groupToggle"
    type="button"
    data-expand-toggle
    hidden
    aria-expanded="false"
    aria-label="View all frameworks in this section"
  >
<span class="groupTogglePill" aria-hidden="true">
  <img class="groupToggleIcon" src="/homepage/downarrow.png" alt="" />
</span>
  </button>
</div>
      </section>
    )}

    <!-- Empty state -->
    <div id="empty" class="empty" hidden>
      <div class="emptyTitle">No frameworks found</div>
      <div class="emptyDesc">Try a different search term, or clear filters.</div>
      <button id="emptyClear" class="primary" type="button">Clear filters</button>
    </div>

       <!-- Groups -->
    {groups.map((g) => (
      <section class="group" id={catId(g.category)} data-group={g.category} data-expanded="false">
        <div class="groupHead">
          <div class="groupTitleWrap">
            <h2 class="groupTitle">
              {g.category} <span class="count">({g.items.length})</span>
            </h2>
            <div class="groupRule" aria-hidden="true"></div>
          </div>
        </div>

        <div class="groupReveal" data-expand-wrap>
          <div class="grid" data-expand-grid>
            {g.items.map((item) => (
<a
  class="card"
  href={`/toolkit/${item.slug}/`}
  data-title={item.data.title}
  data-category={item.data.primaryCategory || "Uncategorized"}
  data-when={item.data.whenToUse || ""}
  onclick={`trackEvent('framework_click', { framework: '${item.slug}', framework_name: '${item.data.title.replace(/'/g, "\\'")}', category: '${(item.data.primaryCategory || "Uncategorized").replace(/'/g, "\\'")}', featured: false })`}
>
                {item.data.cover ? (
                  <div class="thumb" aria-hidden="true">
                    <img class="cover" src={item.data.cover} alt={`Cover for ${item.data.title}`} loading="lazy" />
                  </div>
                ) : (
                  <div class="thumb thumbEmpty" aria-hidden="true">
                    <span class="thumbMark">AL</span>
                  </div>
                )}

                <div class="meta">
                  <div class="cardTitle">{item.data.title}</div>

                  <div class="excerpt">
                    <div class="excerptLabel">When to use</div>
                    <div class="whenToUse">
                      {item.data.whenToUse ? item.data.whenToUse : <span class="muted">—</span>}
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

<div class="groupFooter">
  <button
    class="groupToggle"
    type="button"
    data-expand-toggle
    hidden
    aria-expanded="false"
    aria-label="View all frameworks in this section"
  >
<span class="groupTogglePill" aria-hidden="true">
  <img class="groupToggleIcon" src="/homepage/downarrow.png" alt="" />
</span>
  </button>
</div>
      </section>
    ))}

    <!-- Back to top -->
    <button id="toTop" class="toTop" type="button" aria-label="Back to top">↑ Top</button>

<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    try {
      const root = document.querySelector(".toolkit");
      const q = document.getElementById("q");
      const cat = document.getElementById("cat");
      const clear = document.getElementById("clear");
      const empty = document.getElementById("empty");
      const emptyClear = document.getElementById("emptyClear");
      const resultsText = document.getElementById("resultsText");

      const viewGrid = document.getElementById("viewGrid");
      const viewCompact = document.getElementById("viewCompact");
      const toTop = document.getElementById("toTop");

      const expandableSections = Array.from(
        document.querySelectorAll("section.group, section.featuredBlock")
      );

      if (!root) throw new Error("Toolkit root not found (.toolkit).");

      function normalize(s) {
        return (s || "").toLowerCase().trim();
      }

      const controlsBar = document.querySelector(".controlsBar");
      const toolkitRoot = document.querySelector(".toolkit");

      function syncStickyControlBar() {
        if (!controlsBar) return;

        const stickyTop = parseFloat(getComputedStyle(controlsBar).top || "0") || 0;
        const rect = controlsBar.getBoundingClientRect();
        const isSticky = rect.top <= stickyTop + 0.5;

        controlsBar.classList.toggle("isStickyMobile", isSticky);

        if (isSticky && toolkitRoot) {
          const hostRect = toolkitRoot.getBoundingClientRect();
          const leftExpand = Math.max(0, hostRect.left);
          const rightExpand = Math.max(0, window.innerWidth - hostRect.right);
          controlsBar.style.setProperty("--sticky-expand-left", `${leftExpand}px`);
          controlsBar.style.setProperty("--sticky-expand-right", `${rightExpand}px`);
        } else {
          controlsBar.style.removeProperty("--sticky-expand-left");
          controlsBar.style.removeProperty("--sticky-expand-right");
        }
      }

      function queueStickyControlBarSync() {
        window.requestAnimationFrame(syncStickyControlBar);
      }

      function getHasActiveFilter() {
        return Boolean(normalize(q?.value) || (cat?.value || ""));
      }

      function setView(view) {
        root.dataset.view = view;

        const isGrid = view === "grid";
        viewGrid?.classList.toggle("isActive", isGrid);
        viewCompact?.classList.toggle("isActive", !isGrid);

        viewGrid?.setAttribute("aria-pressed", String(isGrid));
        viewCompact?.setAttribute("aria-pressed", String(!isGrid));

        try {
          localStorage.setItem("toolkitView", view);
        } catch {}

        requestAnimationFrame(() => refreshExpandableSections(getHasActiveFilter()));
      }

      function countVisibleCards() {
        return document.querySelectorAll("a.card:not(.isHidden)").length;
      }

      function getVisibleCardsInSection(section) {
        return Array.from(section.querySelectorAll("a.card")).filter(
          (card) => !card.classList.contains("isHidden")
        );
      }

      function refreshExpandableSections(forceExpand = false) {
        const isCompact = root?.dataset.view === "compact";

        expandableSections.forEach((section) => {
          const wrap = section.querySelector("[data-expand-wrap]");
          const toggle = section.querySelector("[data-expand-toggle]");
          const footer = section.querySelector(".groupFooter");

          if (!wrap || !toggle || !footer) return;

          if (section.classList.contains("isHidden")) {
            toggle.hidden = true;
            footer.classList.remove("isVisible");
            toggle.setAttribute("aria-expanded", "false");
            section.classList.remove("isCollapsible", "isCollapsed", "isExpanded");
            wrap.style.removeProperty("--collapsed-h");
            return;
          }

          const cards = getVisibleCardsInSection(section);

          if (!cards.length) {
            toggle.hidden = true;
            footer.classList.remove("isVisible");
            toggle.setAttribute("aria-expanded", "false");
            section.classList.remove("isCollapsible", "isCollapsed", "isExpanded");
            wrap.style.removeProperty("--collapsed-h");
            return;
          }

          const firstTop = cards[0].offsetTop;
          const firstRow = cards.filter((card) => Math.abs(card.offsetTop - firstTop) < 2);
          const firstRowHeight = Math.max(
            ...firstRow.map((card) => card.offsetHeight + (card.offsetTop - firstTop))
          );

          const hasMoreThanOneRow = cards.length > firstRow.length;
          const peek = window.innerWidth <= 720 ? 14 : 18;
          const collapsedHeight = firstRowHeight + peek;

          const expanded = section.dataset.expanded === "true";
          const shouldForceExpand = forceExpand || isCompact;

          if (!hasMoreThanOneRow) {
            toggle.hidden = true;
            footer.classList.remove("isVisible");
            toggle.setAttribute("aria-expanded", "false");
            section.classList.remove("isCollapsible", "isCollapsed", "isExpanded");
            wrap.style.removeProperty("--collapsed-h");
            return;
          }

          if (shouldForceExpand) {
            toggle.hidden = true;
            footer.classList.remove("isVisible");
            toggle.setAttribute("aria-expanded", "true");
            section.classList.add("isCollapsible", "isExpanded");
            section.classList.remove("isCollapsed");
            wrap.style.removeProperty("--collapsed-h");
            return;
          }

          wrap.style.setProperty("--collapsed-h", `${Math.ceil(collapsedHeight)}px`);
          section.classList.add("isCollapsible");
          section.classList.toggle("isExpanded", expanded);
          section.classList.toggle("isCollapsed", !expanded);

          toggle.hidden = false;
          footer.classList.add("isVisible");
          toggle.setAttribute("aria-expanded", String(expanded));
          toggle.setAttribute(
            "aria-label",
            expanded ? "Show less frameworks in this section" : "View all frameworks in this section"
          );
        });
      }

      function applyFilter() {
        const query = normalize(q?.value);
        const selected = cat?.value || "";

        const sections = document.querySelectorAll("section.group, section.featuredBlock, section.spotlightBlock");

        sections.forEach((section) => {
          const cards = section.querySelectorAll("a.card");
          let visibleCount = 0;

          cards.forEach((card) => {
            const title = normalize(card.dataset.title);
            const c = card.dataset.category || "";
            const when = normalize(card.dataset.when || "");

            const catText = normalize(c);
            const matchText = !query || title.includes(query) || catText.includes(query) || when.includes(query);
            const matchCat = !selected || c === selected;

            const show = matchText && matchCat;
            card.classList.toggle("isHidden", !show);
            if (show) visibleCount++;
          });

          section.classList.toggle("isHidden", visibleCount === 0);
        });

        const totalVisible = countVisibleCards();
        if (empty) empty.hidden = totalVisible !== 0;

        if (resultsText) {
          const suffix = totalVisible === 1 ? "framework" : "frameworks";
          resultsText.textContent = `Showing ${totalVisible} ${suffix}`;
        }

        refreshExpandableSections(Boolean(query || selected));
      }

      function clearFilters() {
        if (q) q.value = "";
        if (cat) cat.value = "";
        applyFilter();
        q?.focus();
      }

      function updateToTop() {
        if (!toTop) return;
        const show = window.scrollY > 420;
        toTop.classList.toggle("isVisible", show);
      }

      try {
        const saved = localStorage.getItem("toolkitView");
        if (saved === "compact" || saved === "grid") setView(saved);
      } catch {}

      viewGrid?.addEventListener("click", () => setView("grid"));
      viewCompact?.addEventListener("click", () => setView("compact"));

    window.addEventListener("scroll", queueStickyControlBarSync, { passive: true });
    window.addEventListener("resize", queueStickyControlBarSync);
    window.visualViewport?.addEventListener("resize", queueStickyControlBarSync);
    window.visualViewport?.addEventListener("scroll", queueStickyControlBarSync);

    q?.addEventListener("input", applyFilter);
     cat?.addEventListener("change", () => {
  const selected = cat.value || "";

  if (selected) {
    trackEvent("toolkit_category_select", {
      category: selected,
      page: "pm_toolkit_index",
    });
  }

  applyFilter();
});
      clear?.addEventListener("click", clearFilters);
      emptyClear?.addEventListener("click", clearFilters);

      document.querySelectorAll("[data-expand-toggle]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const section = btn.closest("section.group, section.featuredBlock");
          if (!section) return;

          const expanded = section.dataset.expanded === "true";
          section.dataset.expanded = expanded ? "false" : "true";
          refreshExpandableSections(false);
        });
      });

      window.addEventListener("resize", () => {
        refreshExpandableSections(getHasActiveFilter());
      });

      window.addEventListener("scroll", updateToTop, { passive: true });
      toTop?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
      updateToTop();

      queueStickyControlBarSync();
      setTimeout(queueStickyControlBarSync, 80);
      setTimeout(queueStickyControlBarSync, 220);
      window.addEventListener("load", queueStickyControlBarSync);

      applyFilter();

      requestAnimationFrame(() => refreshExpandableSections(getHasActiveFilter()));
      setTimeout(() => refreshExpandableSections(getHasActiveFilter()), 80);
      setTimeout(() => refreshExpandableSections(getHasActiveFilter()), 260);

      window.addEventListener("load", () => {
        refreshExpandableSections(getHasActiveFilter());
      });
    } catch (e) {
      console.error("[toolkit] init failed:", e);
    }
  });
</script>


<style>
  /* =========================================================
     1) ROOT / TOKENS
     ========================================================= */

  .toolkit {
    width: 100%;
    overflow-x: visible;
    padding-top: 10px;
    padding-bottom: 76px;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    --tk-radius: 18px;
    --tk-radius-sm: 12px;
  }

  .group,
  .featuredBlock,
  .spotlightBlock {
    scroll-margin-top: 102px;
  }

  .isHidden {
    display: none !important;
  }

  /* =========================================================
     2) FEATURED / SPOTLIGHT BLOCKS
     ========================================================= */

  .featuredBlock {
    margin-top: 10px;
    padding: 16px;
    border-radius: var(--tk-radius);
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 98%, white 2%),
        color-mix(in srgb, var(--surface) 98%, black 2%)
      );
    box-shadow:
      0 1px 0 rgba(255,255,255,0.66) inset,
      0 12px 28px rgba(0,0,0,0.022);
  }

  .spotlightBlock {
    margin-top: 12px;
    margin-bottom: 18px;
  }

  .spotlightGrid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
  }

  .spotlightCard {
    border-radius: 18px;
    border-color: color-mix(in srgb, var(--border) 78%, transparent);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.7) inset,
      0 14px 30px rgba(15, 23, 42, 0.032);
  }

  .spotlightCard .thumb {
    aspect-ratio: 16 / 10;
    padding: 5px;
  }

  .spotlightMeta {
    padding: 16px 16px 18px;
    min-height: 148px;
    gap: 10px;
  }

  .spotlightTop {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
  }

  .spotlightKicker {
    font-size: 10px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--ink-muted) 84%, var(--ink) 16%);
  }

  .spotlightCategory {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 76%, transparent);
    background: color-mix(in srgb, var(--surface) 98%, black 2%);
    color: color-mix(in srgb, var(--ink-muted) 82%, var(--ink) 18%);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .spotlightCard .cardTitle {
    font-size: 1.04rem;
  }

  /* =========================================================
     3) GROUP HEADERS / EXPANDERS
     ========================================================= */

  .group {
    margin-top: 25px;
  }

  .group + .group {
    margin-top: 34px;
  }

  .groupHead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 12px;
  }

  .groupTitleWrap {
    min-width: 0;
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  .groupTitle {
    margin: 0;
    color: rgb(5, 35, 80);
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .count {
    font-weight: 500;
    color: color-mix(in srgb, var(--ink-muted) 88%, var(--ink) 12%);
    font-size: 0.9em;
  }

  .groupRule {
    display: none;
  }

  .groupReveal {
    position: relative;
    overflow: clip;
    transition: max-height 560ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: max-height;
  }

  .groupReveal::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 96px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.22s var(--ease);
    background: linear-gradient(
      180deg,
      rgba(247, 247, 248, 0) 0%,
      rgba(247, 247, 248, 0.74) 56%,
      rgba(247, 247, 248, 0.98) 100%
    );
  }

  .isCollapsible.isCollapsed .groupReveal {
    max-height: var(--collapsed-h);
  }

  .isCollapsible.isCollapsed .groupReveal::after {
    opacity: 1;
  }

  .groupFooter {
    display: none;
    justify-content: center;
    align-items: center;
    margin-top: -12px;
    position: relative;
    z-index: 3;
    padding-bottom: 4px;
  }

  .groupFooter.isVisible {
    display: flex;
  }

  .groupToggle {
    margin: 0 auto;
    width: 126px;
    min-height: 36px;
    padding: 0;
    border: 0;
    background: transparent;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 10px;
    cursor: pointer;
  }

  .groupToggle::before,
  .groupToggle::after {
    content: "";
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      color-mix(in srgb, var(--border) 72%, transparent) 50%,
      transparent 100%
    );
    opacity: 0.9;
  }

  .groupToggle[hidden] {
    display: none !important;
  }

  .groupTogglePill {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    box-shadow: none;
    border-radius: 0;
    padding: 0;
    filter: none;
    transform: none;
  }

  .groupTogglePill::before {
    display: none;
  }

  .groupToggle:hover .groupTogglePill {
    transform: translateY(-1px);
    background: transparent;
    border: 0;
    box-shadow: none;
    filter: none;
  }

  .groupToggleIcon {
    width: 14px;
    height: 14px;
    display: block;
    object-fit: contain;
    opacity: 0.98;
    transform: rotate(0deg);
    transition:
      transform 0.28s var(--ease),
      opacity 0.2s var(--ease);
  }

  .groupToggle:hover .groupToggleIcon {
    opacity: 1;
  }

  .isExpanded .groupToggleIcon {
    transform: rotate(180deg);
    opacity: 1;
  }

