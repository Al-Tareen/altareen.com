  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
    color: rgb(5, 35, 80);
}

/* =========================================================
   KEEP ALL 4 THEMES VISUALLY CONSISTENT
   ========================================================= */

.analyticsCard--category,
.analyticsCard--popular,
.analyticsCard--downloaded,
.analyticsCard--liked {
  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,0.94) 0%,
