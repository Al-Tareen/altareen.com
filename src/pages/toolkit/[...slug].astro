---
import PageShell from "../../components/PageShell.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("toolkit");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const routeSlug = Array.isArray(Astro.params.slug)
  ? Astro.params.slug.join("/")
  : Astro.params.slug || "";

let item = Astro.props?.item;

if (!item) {
  const items = await getCollection("toolkit");
  item = items.find((entry) => entry.slug === routeSlug);
}

if (!item) {
  throw new Error(`Toolkit item not found for slug: ${routeSlug}`);
}

const files = Array.isArray(item.data.files) ? item.data.files : [];
const hasFiles = files.length > 0;

// If no files are attached, allow downloading the cover as a fallback
const fallbackDownload = item.data.cover
  ? { name: `${item.data.title || "Download"}`, url: item.data.cover }
  : null;

const downloads = hasFiles ? files : fallbackDownload ? [fallbackDownload] : [];
const hasDownloads = downloads.length > 0;
const hasMultipleDownloads = downloads.length > 1;
const hasSingleDownload = downloads.length === 1;

const normalizeUrl = (f) => f?.path || f?.url || "";

const getExtension = (name = "", url = "") => {
  const source = String(name || url || "").trim().toLowerCase();
  const clean = source.split("?")[0].split("#")[0];
  const ext = clean.includes(".") ? clean.split(".").pop() : "";
  return ext || "";
};

const getFileTypeLabel = (name = "", url = "") => {
  const ext = getExtension(name, url);

  const map = {
    pdf: "PDF",
    doc: "DOC",
    docx: "DOCX",
    ppt: "PPT",
    pptx: "PPTX",
    xls: "XLS",
    xlsx: "XLSX",
    csv: "CSV",
    txt: "TXT",
    zip: "ZIP",
  };

  return map[ext] || (ext ? ext.toUpperCase() : "FILE");
};

const stripExtension = (name = "") => {
  const trimmed = String(name || "").trim();
  return trimmed.replace(/\.[^./\\]+$/, "");
};

const formatDownload = (f, i) => {
  const url = normalizeUrl(f);
  const rawName = f?.name || `Attachment ${i + 1}`;
  return {
    ...f,
    href: url,
    rawName,
    displayName: stripExtension(rawName),
    typeLabel: getFileTypeLabel(rawName, url),
  };
};

const normalizedDownloads = downloads.map(formatDownload);

const sectionIds = {
  when: "when",
  inputs: "inputs",
  output: "output",
  mistakes: "mistakes",
  link: "related",
  downloads: "downloads",
};

// kept for future section nav / jump support
const sections = [
  (item.data.whenToUseFull || item.data.whenToUse)
    ? { id: sectionIds.when, label: "When to use" }
    : null,
  item.data.inputsRequired ? { id: sectionIds.inputs, label: "Inputs" } : null,
  item.data.outputArtifact ? { id: sectionIds.output, label: "Output" } : null,
  item.data.commonMistakes ? { id: sectionIds.mistakes, label: "Mistakes" } : null,
  item.data.link ? { id: sectionIds.link, label: "Related" } : null,
  hasMultipleDownloads ? { id: sectionIds.downloads, label: "Downloads" } : null,
].filter(Boolean);

const primaryDownload = hasDownloads ? normalizedDownloads[0] : null;
const primaryDownloadUrl = primaryDownload ? primaryDownload.href : "";

const isPdf = (f) =>
  getFileTypeLabel(
    f?.rawName || f?.name || "",
    f?.href || f?.url || f?.path || ""
  ) === "PDF";

const primaryAsset =
  (hasDownloads ? normalizedDownloads.find(isPdf) : null) ||
  (hasDownloads ? normalizedDownloads[0] : null);

const primaryAssetUrl = primaryAsset ? primaryAsset.href : "";
const hasPrimaryAsset = Boolean(primaryAssetUrl);
const canPreview = hasPrimaryAsset && isPdf(primaryAsset);

// cleaner glyphs (more consistent across platforms than emoji)
const quickActions = [
  primaryDownloadUrl
    ? {
        kind: "download",
        label: hasSingleDownload ? primaryDownload.displayName : "Download",
        fileType: hasSingleDownload ? primaryDownload.typeLabel : "",
        icon: "↓",
        href: primaryDownloadUrl,
      }
    : null,
  canPreview ? { kind: "preview", label: "Preview", icon: "◦" } : null,
  { kind: "share", label: "Share", icon: "↗" },
  item.data.link ? { kind: "related", label: "Related", icon: "↗", href: item.data.link } : null,
].filter(Boolean);

const showQuickActions = quickActions.length > 0;
const showHeroRail = showQuickActions || hasMultipleDownloads;

const category = item.data.primaryCategory || "PM Toolkit";
const baseTitle = item.data.title || "Framework";

// SEO-optimized page title
const title = `${baseTitle} | Product Management Framework | Altareen`;

// Stronger, keyword-rich dynamic description
const description =
  item.data.description ||
  item.data.whenToUseFull ||
  item.data.whenToUse ||
  `Explore ${baseTitle}, a product management framework for structured decision-making, execution, and strategic planning. Learn when to use it, required inputs, expected outputs, and common mistakes.`;

// Optional keyword enhancer for PageShell if supported
const seoKeywords = [
  baseTitle,
  "product management framework",
  "PM framework",
  "product strategy",
  "AI product management",
  "framework template",
  "Altareen PM Toolkit",
].join(", ");

const publishedDate = item.data.datePublished || undefined;
---

<PageShell
  title={title}
  description={description}
  subtitle={category}
  hidePageHead={true}
  slug={item.slug}
  toolkitType="pm"
  datePublished={publishedDate}
  keywords={seoKeywords}
>
  <div class="toolkitDetail" data-framework-slug={item.slug}>
    <!-- Top row -->
    <div class="topRow">
      <a class="back" href="/toolkit/" aria-label="Back to PM Toolkit">
        <span class="arrow" aria-hidden="true">←</span>
        <span>PM Toolkit</span>
      </a>
    </div>

    <!-- Hero -->
    <header class="hero" aria-label="Framework header">
      <div class="heroGrid">
        {item.data.cover && (
          <div class="coverFrame">
            <div class="coverWrap">
              <img class="cover coverZoom" src={item.data.cover} alt={`Cover for ${title}`} loading="lazy" />

              <!-- Feedback overlay -->
              <div class="coverFeedback" role="group" aria-label="Framework feedback">
                <button
                  class="fbBtn"
                  type="button"
                  data-feedback="like"
                  aria-pressed="false"
                  aria-label="Like this framework"
                  title="Like"
                >
                  <span class="fbIcon" aria-hidden="true">👍</span>
                  <span class="fbLabel">Like</span>
                </button>

                <button
                  class="fbBtn"
                  type="button"
                  data-feedback="dislike"
                  aria-pressed="false"
                  aria-label="Dislike this framework"
                  title="Dislike"
                >
                  <span class="fbIcon" aria-hidden="true">👎</span>
                  <span class="fbLabel">Dislike</span>
                </button>
              </div>
            </div>

            <!-- Sentiment bar + stats -->
            <div class="feedbackStats" aria-label="Community feedback">
              <div
                class="feedbackBar isEmpty"
                data-feedback-bar
                role="img"
                aria-label="Likes and dislikes ratio"
                aria-describedby="feedbackMeta"
              >
                <div class="feedbackBarLikes" data-bar-likes style="width: 0%;"></div>
                <div class="feedbackBarDislikes" data-bar-dislikes style="width: 0%;"></div>
              </div>

              <div class="feedbackMeta" id="feedbackMeta">
                <span class="feedbackPercent" data-feedback-summary>
                  <span data-like-percent>0%</span> helpful
                </span>

                <span class="feedbackDot" data-feedback-summary-dot aria-hidden="true">•</span>

                <div class="feedbackCountsRow" data-feedback-counts>
                  <span class="feedbackCount"><span data-like-count>0</span> likes</span>
                  <span class="feedbackDot" aria-hidden="true">•</span>
                  <span class="feedbackCount"><span data-dislike-count>0</span> dislikes</span>
                </div>
              </div>
            </div>
          </div>
        )}

        {showHeroRail && (
          <aside class="heroRail" aria-label="Quick actions and downloads">
      {showQuickActions && (
  <div class="sideCard" aria-label="Quick Actions">
    <div class="sideTop">
      <div class="sideTitle">Quick Actions</div>
    </div>

    <div class="sideMeta">
      {quickActions.map((a) => {
        if (a.kind === "download") {
          return (
            <a class="qaRow primary qaDownloadRow" href={a.href} download target="_blank" rel="noopener">
              <span class="qaIcon" aria-hidden="true">{a.icon}</span>
              <span class="qaText">{a.label}</span>
              {a.fileType && <span class="qaFileType">{a.fileType}</span>}
            </a>
          );
        }

        if (a.kind === "preview") {
          return (
            <button class="qaRow" type="button" data-preview>
              <span class="qaIcon" aria-hidden="true">{a.icon}</span>
              <span class="qaText">{a.label}</span>
            </button>
          );
        }

        if (a.kind === "share") {
          return (
            <button class="qaRow" type="button" data-share>
              <span class="qaIcon" aria-hidden="true">{a.icon}</span>
              <span class="qaText">{a.label}</span>
            </button>
          );
        }

        return (
          <a class="qaRow" href={a.href} target="_blank" rel="noopener">
            <span class="qaIcon" aria-hidden="true">{a.icon}</span>
            <span class="qaText">{a.label}</span>
            <span class="qaEnd" aria-hidden="true">↗</span>
          </a>
        );
      })}
    </div>
  </div>
)}

{hasMultipleDownloads && (
  <div
    class="sideCard downloadsSideCard"
    id={sectionIds.downloads}
    data-section
    aria-label="Downloads"
  >
    <div class="sideTop">
      <div class="sideTitle">Downloads</div>
      <span class="downloadsCount">{normalizedDownloads.length}</span>
    </div>

    <div class="downloadList">
      {normalizedDownloads.map((f, i) => (
        <a
          class="fileRow"
          href={f.href}
          download
          target="_blank"
          rel="noopener"
          aria-label={`Download ${f.displayName || `Attachment ${i + 1}`}`}
        >
          <span class="fileType" aria-hidden="true">{f.typeLabel}</span>
          <span class="fileName">{f.displayName || `Attachment ${i + 1}`}</span>
        </a>
      ))}
    </div>
  </div>
)}
          </aside>
        )}
      </div>
    </header>

    <!-- Main layout -->
    <div class="layout">
      <article class="content" aria-label="Framework details">
        {(item.data.whenToUseFull || item.data.whenToUse) && (
          <section class="cardBlock lead" id={sectionIds.when} data-section>
            <h2>When to use this</h2>
            <p style="white-space: pre-wrap;">{item.data.whenToUseFull || item.data.whenToUse}</p>
          </section>
        )}

        <div class="grid2">
          {item.data.inputsRequired && (
            <section class="cardBlock" id={sectionIds.inputs} data-section>
              <h2>Inputs Required</h2>
              <p>{item.data.inputsRequired}</p>
            </section>
          )}

          {item.data.outputArtifact && (
            <section class="cardBlock" id={sectionIds.output} data-section>
              <h2>Output Artifact</h2>
              <p>{item.data.outputArtifact}</p>
            </section>
          )}
        </div>

        {item.data.commonMistakes && (
          <section class="cardBlock collapsibleBlock" id={sectionIds.mistakes} data-section>
            <details class="collapse" name="framework-sections">
              <summary class="collapseSummary">
                <span class="collapseTitle">
                  Common Mistakes
                  <span class="collapseChevron" aria-hidden="true">▾</span>
                </span>
              </summary>
              <div class="collapseBody">
                <p style="white-space: pre-wrap;">{item.data.commonMistakes}</p>
              </div>
            </details>
          </section>
        )}

        {item.data.link && (
          <section class="cardBlock" id={sectionIds.link} data-section>
            <h2>Related Link</h2>
            <p>
              <a class="link" href={item.data.link} target="_blank" rel="noopener">
                Open related link →
              </a>
            </p>
          </section>
        )}
      </article>
    </div>

    <!-- PDF Preview Modal -->
    {canPreview && (
      <div class="modal" id="previewModal" aria-hidden="true">
        <div class="modalOverlay" data-close></div>

        <div class="modalPanel" role="dialog" aria-modal="true" aria-label="PDF preview">
          <div class="modalTop">
            <div class="modalTitle">
              <span class="modalName">{primaryAsset?.name || "Preview"}</span>
              <span class="modalHint">Esc to close</span>
            </div>

            <div class="modalActions">
              <a class="pillBtn" href={primaryAssetUrl} download target="_blank" rel="noopener">
                <span class="btnIcon" aria-hidden="true">↓</span>
                <span>Download</span>
              </a>
              <button class="pillBtn" type="button" data-close>
                <span class="btnIcon" aria-hidden="true">✕</span>
                <span>Close</span>
              </button>
            </div>
          </div>

          <div class="modalBody">
            <iframe class="pdfFrame" src={`${primaryAssetUrl}#view=fitH`} title="PDF preview" loading="lazy"></iframe>
          </div>
        </div>
      </div>
    )}

    <!-- Toast -->
    <div class="toast" id="toast" role="status" aria-live="polite">Link copied</div>

    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        try {
          const toast = document.getElementById("toast");
          const shareBtn = document.querySelector("[data-share]");

          function showToast(msg) {
            if (!toast) return;
            toast.textContent = msg || "Done";
            toast.classList.add("isOn");
            window.clearTimeout(window.__toastT);
            window.__toastT = window.setTimeout(() => toast.classList.remove("isOn"), 1200);
          }

          const pageRoot = document.querySelector(".toolkitDetail");
          const frameworkSlug = pageRoot?.dataset?.frameworkSlug || "";

          // ---- Cover feedback (like / dislike) ----
          const likeBtn = document.querySelector('[data-feedback="like"]');
          const dislikeBtn = document.querySelector('[data-feedback="dislike"]');

          const feedbackBarEl = document.querySelector("[data-feedback-bar]");
          const feedbackCountsEl = document.querySelector("[data-feedback-counts]");
          const feedbackSummaryEl = document.querySelector("[data-feedback-summary]");
          const feedbackSummaryDotEl = document.querySelector("[data-feedback-summary-dot]");

          const likeCountEl = document.querySelector("[data-like-count]");
          const dislikeCountEl = document.querySelector("[data-dislike-count]");
          const likeBarEl = document.querySelector("[data-bar-likes]");
          const dislikeBarEl = document.querySelector("[data-bar-dislikes]");

          let currentVote = null; // "like" | "dislike" | null
          let feedbackBusy = false;

          function applyFeedbackState(value) {
            currentVote = value === "like" || value === "dislike" ? value : null;

            [likeBtn, dislikeBtn].forEach((btn) => {
              if (!btn) return;
              const isActive = btn.dataset.feedback === currentVote;
              btn.classList.toggle("isActive", isActive);
              btn.setAttribute("aria-pressed", isActive ? "true" : "false");
            });
          }

          function setFeedbackBusy(isBusy) {
            feedbackBusy = isBusy;

            [likeBtn, dislikeBtn].forEach((btn) => {
              if (!btn) return;
              btn.disabled = isBusy;
              btn.classList.toggle("isBusy", isBusy);
            });
          }

          function renderFeedbackStats(data) {
            const likes = Number(data?.likes || 0);
            const dislikes = Number(data?.dislikes || 0);
            const total = Number(data?.total || 0);

            if (likeCountEl) likeCountEl.textContent = String(likes);
            if (dislikeCountEl) dislikeCountEl.textContent = String(dislikes);

            if (total === 0) {
              if (likeBarEl) likeBarEl.style.width = "0%";
              if (dislikeBarEl) dislikeBarEl.style.width = "0%";

              feedbackBarEl?.classList.add("isEmpty");
              feedbackBarEl?.classList.remove("isPulse");

              if (feedbackSummaryEl) {
                feedbackSummaryEl.textContent = "No ratings yet";
                feedbackSummaryEl.classList.add("isEmpty");
              }

              if (feedbackSummaryDotEl) feedbackSummaryDotEl.style.display = "none";
              if (feedbackCountsEl) feedbackCountsEl.style.display = "none";
              return;
            }

            const likePct = (likes / total) * 100;
            const dislikePct = (dislikes / total) * 100;
            const likePctRounded = Math.round(likePct);

            if (likeBarEl) likeBarEl.style.width = `${likePct}%`;
            if (dislikeBarEl) dislikeBarEl.style.width = `${dislikePct}%`;

            feedbackBarEl?.classList.remove("isEmpty");
            feedbackBarEl?.classList.remove("isPulse");

            if (feedbackBarEl) {
              void feedbackBarEl.offsetWidth;
              feedbackBarEl.classList.add("isPulse");
            }

            if (feedbackSummaryEl) {
              feedbackSummaryEl.innerHTML = `<span data-like-percent>${likePctRounded}%</span> found this helpful`;
              feedbackSummaryEl.classList.remove("isEmpty");
            }

            if (feedbackSummaryDotEl) feedbackSummaryDotEl.style.display = "";
            if (feedbackCountsEl) feedbackCountsEl.style.display = "inline-flex";
          }

          async function loadFeedbackStats() {
            if (!frameworkSlug) return;

            try {
              const res = await fetch(`/api/framework-feedback?slug=${encodeURIComponent(frameworkSlug)}`, {
                method: "GET",
                headers: { Accept: "application/json" },
              });

              if (!res.ok) throw new Error("Failed to load feedback stats");

              const data = await res.json();
              renderFeedbackStats(data);
              applyFeedbackState(data?.userVote || null);
            } catch (err) {
              console.error(err);
              renderFeedbackStats({ likes: 0, dislikes: 0, total: 0 });
              applyFeedbackState(null);
            }
          }

async function submitFeedback(value) {
  if (!frameworkSlug) throw new Error("Missing framework slug");
  if (feedbackBusy) throw new Error("Feedback request already in progress");

  try {
    setFeedbackBusy(true);

    let consent = "declined";

    if (typeof window !== "undefined") {
      try {
        const rawPrefs = localStorage.getItem("cookie_preferences");
        const prefs = rawPrefs ? JSON.parse(rawPrefs) : null;
        const optionalEnabled = Boolean(
          prefs?.optional ?? prefs?.functional ?? prefs?.analytics
        );

        consent = optionalEnabled ? "accepted" : "declined";
      } catch {
        consent = "declined";
      }
    }

    const res = await fetch("/api/framework-feedback", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: JSON.stringify({
        slug: frameworkSlug,
        value: value ?? null,
        consent,
      }),
    });

    if (!res.ok) throw new Error(`Failed to save feedback (${res.status})`);

    const data = await res.json();
    return data;
  } finally {
    setFeedbackBusy(false);
  }
}

          async function handleFeedbackClick(type) {
            if (feedbackBusy) return;

            const prevVote = currentVote;
            const next = currentVote === type ? null : type;

            applyFeedbackState(next);

            try {
              const data = await submitFeedback(next);
              renderFeedbackStats(data);
              applyFeedbackState(data?.userVote ?? next);

              if ((data?.userVote ?? next) === "like") showToast("Marked as helpful");
              else if ((data?.userVote ?? next) === "dislike") showToast("Feedback saved");
              else showToast("Feedback cleared");
            } catch (err) {
              console.error(err);
              applyFeedbackState(prevVote);
              await loadFeedbackStats();
              showToast("Could not save feedback");
            }
          }

          likeBtn?.addEventListener("click", () => handleFeedbackClick("like"));
          dislikeBtn?.addEventListener("click", () => handleFeedbackClick("dislike"));

          loadFeedbackStats();

          function setButtonCopied(btn) {
            if (!btn) return;

            const label = btn.querySelector(".qaLabel");
            const icon = btn.querySelector(".btnIcon");
            const rowText = btn.querySelector(".qaText");
            const rowIcon = btn.querySelector(".qaIcon");

            const prevText = label ? label.textContent : rowText ? rowText.textContent : "";
            const prevIcon = icon ? icon.textContent : rowIcon ? rowIcon.textContent : "";

            btn.classList.add("isCopied");

            if (label) label.textContent = "Copied";
            if (icon) icon.textContent = "✓";
            if (rowText) rowText.textContent = "Copied";
            if (rowIcon) rowIcon.textContent = "✓";

            window.clearTimeout(window.__copiedT);
            window.__copiedT = window.setTimeout(() => {
              btn.classList.remove("isCopied");
              if (label) label.textContent = prevText;
              if (icon) icon.textContent = prevIcon;
              if (rowText) rowText.textContent = prevText;
              if (rowIcon) rowIcon.textContent = prevIcon;
            }, 900);
          }

          async function shareLink() {
            const url = window.location.href;
            const title = document.title || "Link";

            if (navigator.share) {
              try {
                await navigator.share({ title, url });
                showToast("Share opened");
                return;
              } catch {
                // fallback to copy
              }
            }

            try {
              await navigator.clipboard.writeText(url);
              showToast("Link copied");
              setButtonCopied(shareBtn);
            } catch {
              const ta = document.createElement("textarea");
              ta.value = url;
              ta.style.position = "fixed";
              ta.style.left = "-9999px";
              document.body.appendChild(ta);
              ta.select();
              document.execCommand("copy");
              ta.remove();
              showToast("Link copied");
              setButtonCopied(shareBtn);
            }
          }

          shareBtn?.addEventListener("click", shareLink);

          // ---- Preview modal ----
          const modal = document.getElementById("previewModal");
          const openPreviewBtn = document.querySelector("[data-preview]");
          const closeEls = modal ? modal.querySelectorAll("[data-close]") : [];

          function openModal() {
            if (!modal) return;
            modal.setAttribute("aria-hidden", "false");
            document.documentElement.classList.add("modalOpen");
          }

          function closeModal() {
            if (!modal) return;
            modal.setAttribute("aria-hidden", "true");
            document.documentElement.classList.remove("modalOpen");
          }

          openPreviewBtn?.addEventListener("click", openModal);
          closeEls?.forEach((el) => el.addEventListener("click", closeModal));

          window.addEventListener("keydown", (e) => {
            if (e.key === "Escape") closeModal();
          });

          // Keyboard shortcuts
          window.addEventListener("keydown", (e) => {
            if (e.target && ["INPUT", "TEXTAREA"].includes(e.target.tagName)) return;
            if (e.metaKey || e.ctrlKey || e.altKey) return;

            if (e.key.toLowerCase() === "s") shareLink();

            if (e.key.toLowerCase() === "d") {
              const dl = document.querySelector(".qaRow.primary, .qa.primary");
              if (dl) dl.click();
            }

            if (e.key.toLowerCase() === "p") {
              const pv = document.querySelector("[data-preview]");
              if (pv) pv.click();
            }
          });
        } catch {}
      });
    </script>

    <style>
      .toolkitDetail {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 0 28px 48px;
        position: relative;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background: transparent;
      }

      /* Removed top background glow/shadow and texture */
      .toolkitDetail::before,
      .toolkitDetail::after {
        display: none;
        content: none;
      }

      .topRow {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin: 12px 0 20px;
        padding: 0;
        position: relative;
      }

      .back,
      .pillBtn,
      .qaRow {
        border-radius: 12px;
        min-height: 40px;
      }

      .back,
      .pillBtn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--ink);
        padding: 10px 12px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.92);
        font-size: 14px;
        font-weight: 500;
        letter-spacing: -0.01em;
        cursor: pointer;
        transition:
          transform 0.2s var(--ease),
          box-shadow 0.2s var(--ease),
          border-color 0.2s var(--ease),
          background 0.2s var(--ease);
      }

      .back {
        padding: 8px 14px;
      }

      .back:hover,
      .pillBtn:hover {
        transform: translateY(-1px);
        border-color: var(--border-strong);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.04);
        background: #fff;
      }

      .back:active,
