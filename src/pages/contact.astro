---
import PageShell from "../components/PageShell.astro";

// Web3Forms free endpoint (no backend needed)
// Access key provided by user
const web3formsKey = "a662d525-6081-49f0-b6d7-6102e3bf1ec2";
---

<PageShell
  title="Contact"
  description="Send a message or reach me directly by email."
  hidePageHead={false}
>
  <section class="contactPage" aria-label="Contact Al-Ebraheem Tareen">
    <div class="contactGrid">
      <!-- Left / Form -->
      <div class="formPane">
        <div class="formCard">
          <form
            id="contact-form"
            class="form"
            action="https://api.web3forms.com/submit"
            method="POST"
            aria-label="Contact form"
          >
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value="Contact from altareen.com" />
            <input type="hidden" name="from_name" value="altareen.com Contact Form" />

            <!-- Honeypot (Web3Forms bot protection) -->
            <input
              type="checkbox"
              name="botcheck"
              class="gotcha"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />

            <div class="fieldRow">
              <div class="field">
                <label for="name">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Your name"
                />
              </div>

              <div class="field">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="you@example.com"
                />
              </div>
            </div>

            <div class="field">
              <label for="message">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                placeholder="Feel free to share what’s on your mind, what you need help with, and any timing details."
              ></textarea>
            </div>

            <div class="actions">
              <button type="submit" class="submit" id="submit-btn">
                <span class="submitIcon" aria-hidden="true">→</span>
                <span>Send message</span>
              </button>
            </div>
          </form>

          <div id="form-success" class="success" hidden>
            <p class="successTitle">Message sent.</p>
            <p class="successText">Thanks — I’ll get back to you as soon as I can.</p>
          </div>

          <div id="form-error" class="error" hidden>
            <p class="errorText">Something went wrong. Please email me directly instead.</p>
          </div>
        </div>
      </div>

      <!-- Right / Direct contact -->
      <aside class="sidePane" aria-label="Direct contact">
        <div class="sideCard">
          <div class="sideCardTop">
            <div class="miniLabel">Direct contact</div>
          </div>

          <div class="emailBlock">
            <div class="emailLabel">Email</div>
            <a class="emailLink" href="mailto:altareenk@outlook.com">altareenk@outlook.com</a>
          </div>

          <div class="sideActions">
            <a class="sideBtn primary" href="mailto:altareenk@outlook.com">
              <span class="sideIcon" aria-hidden="true">✉</span>
              <span>Email me</span>
            </a>

            <button class="sideBtn" type="button" id="copy-email-btn" data-email="altareenk@outlook.com">
              <span class="sideIcon" aria-hidden="true">⧉</span>
              <span id="copy-email-text">Copy email</span>
            </button>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <script>
    const form = document.getElementById("contact-form");
    const submitBtn = document.getElementById("submit-btn");
    const successEl = document.getElementById("form-success");
    const errorEl = document.getElementById("form-error");
    const useAjax = form?.action && form.action.includes("web3forms");

    if (form && useAjax && submitBtn && successEl && errorEl) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        submitBtn.disabled = true;
        submitBtn.textContent = "Sending...";
        successEl.setAttribute("hidden", "");
        errorEl.setAttribute("hidden", "");

        const formData = new FormData(form);

        try {
          const res = await fetch(form.action, {
            method: "POST",
            body: formData,
            headers: {
              Accept: "application/json",
            },
          });

          const data = await res.json();

          if (res.ok && data.success) {
            form.reset();
            successEl.removeAttribute("hidden");
          } else {
            errorEl.removeAttribute("hidden");
            console.error("Web3Forms error:", data);
          }
        } catch (err) {
          errorEl.removeAttribute("hidden");
          console.error("Contact form submit failed:", err);
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = "Send message";
        }
      });
    }

    const copyEmailBtn = document.getElementById("copy-email-btn");
    const copyEmailText = document.getElementById("copy-email-text");

    if (copyEmailBtn && copyEmailText) {
      copyEmailBtn.addEventListener("click", async () => {
        const email = copyEmailBtn.getAttribute("data-email");
        if (!email) return;

        try {
          await navigator.clipboard.writeText(email);
          copyEmailText.textContent = "Copied";
          setTimeout(() => {
            copyEmailText.textContent = "Copy email";
          }, 1400);
        } catch {
          copyEmailText.textContent = "Copy failed";
          setTimeout(() => {
            copyEmailText.textContent = "Copy email";
          }, 1400);
        }
      });
    }
  </script>

<style is:global>
  .contactPage {
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 8px 0 72px; /* more breathing room before footer */
    position: relative;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .contactPage::before,
  .contactPage::after {
    display: none;
    content: none;
  }

  .contactGrid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 16px;
    align-items: start;
    margin-top: 0;
  }

  .formPane,
  .sidePane {
    min-width: 0;
  }

  .formCard,
  .sideCard {
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 98%, white 2%),
        color-mix(in srgb, var(--surface) 98%, black 2%)
      );
    box-shadow:
      0 1px 0 rgba(255,255,255,0.62) inset,
      0 8px 20px rgba(0,0,0,0.018);
    box-sizing: border-box;
  }

  .formCard {
    padding: 18px;
    transition:
      border-color 0.2s var(--ease),
      box-shadow 0.2s var(--ease);
  }

  .formCard:focus-within {
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.72) inset,
      0 12px 24px rgba(0,0,0,0.035);
  }

  .gotcha {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .fieldRow {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .field label {
    color: var(--ink);
    font-size: 0.84rem;
    line-height: 1.2;
    font-weight: 650;
    letter-spacing: -0.01em;
  }

  .field input,
  .field textarea {
    width: 100%;
    box-sizing: border-box;
    padding: 12px 13px;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    background: color-mix(in srgb, var(--surface) 98%, black 1%);
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.45;
    transition:
      border-color 0.18s var(--ease),
      box-shadow 0.18s var(--ease),
      background-color 0.18s var(--ease);
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: color-mix(in srgb, var(--ink-muted) 92%, var(--ink) 8%);
  }

  .field input:hover,
  .field textarea:hover {
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    background: #fff;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--border) 78%, var(--ink) 16%);
    box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
    background: #fff;
  }

  .field textarea {
    resize: vertical;
    min-height: 154px;
  }

  .actions {
    margin-top: 2px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 40px;
    padding: 0 14px;
    border-radius: 10px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--surface);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 550;
    line-height: 1;
    letter-spacing: 0.003em;
    cursor: pointer;
    box-shadow: 0 1px 0 rgba(255,255,255,0.10) inset;
    transition:
      background-color 0.18s var(--ease),
      border-color 0.18s var(--ease),
      box-shadow 0.18s var(--ease),
      transform 0.18s var(--ease);
  }

  .submit:hover:not(:disabled) {
    background: color-mix(in srgb, var(--ink) 92%, black 8%);
    border-color: color-mix(in srgb, var(--ink) 92%, black 8%);
    transform: translateY(-1px);
  }

  .submit:active:not(:disabled) {
    transform: translateY(0);
  }

  .submit:disabled {
    opacity: 0.78;
    cursor: not-allowed;
  }

  .submitIcon {
    line-height: 1;
    opacity: 0.95;
  }

  .success,
  .error {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
  }

  .successTitle {
    margin: 0 0 4px;
    color: var(--ink);
    font-size: 0.95rem;
    line-height: 1.2;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .successText,
  .errorText {
    margin: 0;
    color: var(--ink-secondary);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .sideCard {
    position: sticky;
    top: calc(var(--siteHeaderH) + 14px);
    padding: 16px;
  }

  .miniLabel {
    margin: 0 0 8px;
    color: color-mix(in srgb, var(--ink-muted) 84%, var(--ink) 16%);
    font-size: 10px;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .sideCardTop h2 {
    margin: 0;
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.15;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .emailBlock {
    margin-top: 12px;
    padding: 12px;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    background: color-mix(in srgb, var(--surface) 98%, black 1%);
  }

  .emailLabel {
    margin-bottom: 6px;
    color: color-mix(in srgb, var(--ink-muted) 92%, var(--ink) 8%);
    font-size: 0.72rem;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .emailLink {
    display: inline-block;
    color: var(--ink);
    text-decoration: none;
    font-weight: 560;
    font-size: 0.92rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 18%, transparent);
    word-break: break-word;
    transition: border-color 0.18s var(--ease), color 0.18s var(--ease);
  }

  .emailLink:hover {
    color: var(--ink);
    border-bottom-color: color-mix(in srgb, var(--ink) 36%, transparent);
  }

  .sideActions {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sideBtn {
    width: 100%;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 40px;
    padding: 0 12px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--border) 78%, transparent);
    background: color-mix(in srgb, var(--surface) 98%, black 2%);
    color: var(--ink);
    text-decoration: none;
    font-size: 14px;
    font-weight: 550;
    line-height: 1;
    letter-spacing: 0.003em;
    cursor: pointer;
    box-shadow: 0 1px 0 rgba(255,255,255,0.60) inset;
    transition:
      background-color 0.18s var(--ease),
      border-color 0.18s var(--ease),
      color 0.18s var(--ease),
      box-shadow 0.18s var(--ease),
      transform 0.18s var(--ease);
  }

  .sideBtn:hover {
    background: color-mix(in srgb, var(--surface) 95%, black 2%);
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    transform: translateY(-1px);
  }

  .sideBtn.primary {
    background: var(--ink);
    color: var(--surface);
    border-color: var(--ink);
    box-shadow: 0 1px 0 rgba(255,255,255,0.10) inset;
  }

  .sideBtn.primary:hover {
    background: color-mix(in srgb, var(--ink) 92%, black 8%);
    border-color: color-mix(in srgb, var(--ink) 92%, black 8%);
  }

  .sideIcon {
    width: 14px;
    flex: 0 0 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    line-height: 1;
    opacity: 0.9;
    color: currentColor;
  }

  :where(.submit, .sideBtn, .emailLink):focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(0,0,0,0.08);
    border-color: color-mix(in srgb, var(--border) 78%, var(--ink) 16%);
  }

  @media (max-width: 980px) {
    .contactGrid {
      grid-template-columns: 1fr;
    }

    .sideCard {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .contactPage {
      max-width: none;
      width: 100%;
      padding: 0 0 48px;
    }

    .contactGrid {
      gap: 12px;
    }

    .formCard,
    .sideCard {
      padding: 14px;
      border-radius: 14px;
    }

    .fieldRow {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .field textarea {
      min-height: 140px;
    }

    .submit {
      width: 100%;
    }

    .sideBtn {
      min-height: 38px;
      font-size: 13px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .submit,
    .sideBtn,
    .formCard,
    .field input,
    .field textarea,
    .emailLink {
      transition: none !important;
    }

    .submit:hover,
    .sideBtn:hover {
      transform: none !important;
    }
  }
</style>
</PageShell>