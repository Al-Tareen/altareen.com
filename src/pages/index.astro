---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const HIDDEN_FRAMEWORK_CATEGORIES = new Set(["Business Plans", "TBA", "Financial Models"]);
const CONCEPT_CATEGORIES = new Set(["Concepts", "Business Plans"]);

const all = await getCollection("toolkit");

const hasCover = (item) => Boolean(item?.data?.cover);

const frameworkPool = all
  .filter((item) => (item.data.dbTitle || "").trim() === "Frameworks")
  .filter((item) => !HIDDEN_FRAMEWORK_CATEGORIES.has((item.data.primaryCategory || "Uncategorized").trim()))
  .filter(hasCover);

const financePool = all
  .filter((item) => (item.data.primaryCategory || "").trim() === "Financial Models")
  .filter(hasCover);

const conceptPool = all
  .filter((item) => CONCEPT_CATEGORIES.has((item.data.primaryCategory || "Uncategorized").trim()))
  .filter(hasCover);

function hashString(value) {
  let hash = 0;
  for (let i = 0; i < value.length; i += 1) {
    hash = (hash << 5) - hash + value.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash);
}

function pickPreviewItems(items, count, seed) {
  return [...items]
    .map((item) => ({
      item,
      score: hashString(`${seed}:${item.slug}`),
    }))
    .sort((a, b) => {
      if (a.score !== b.score) return a.score - b.score;
      return String(a.item.data.title || "").localeCompare(String(b.item.data.title || ""));
    })
    .slice(0, count)
    .map(({ item }) => item);
}

function buildPreviewItems(items, count, seed) {
  return pickPreviewItems(items, count, seed).map((item) => ({
    slug: item.slug,
    cover: item.data.cover,
  }));
}

function chunkItems(items, size) {
  const chunks = [];
  for (let i = 0; i < items.length; i += size) {
    chunks.push(items.slice(i, i + size));
  }
  return chunks.filter((chunk) => chunk.length > 0);
}

const pmPages = chunkItems(buildPreviewItems(frameworkPool, 12, "pm"), 4);
const financePages = chunkItems(buildPreviewItems(financePool, 4, "finance"), 2);
const conceptPages = chunkItems(buildPreviewItems(conceptPool, 2, "concepts"), 2);

const homepageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Al-Ebraheem Tareen",
    alternateName: "Al Tareen",
    url: "https://altareen.com/",
    image: "https://altareen.com/images/about/altareen.jpg",
    jobTitle: "AI Transformation • Product Management • Product Strategy",
    homeLocation: {
      "@type": "Place",
      name: "Houston, TX",
    },
    sameAs: [
      "https://www.linkedin.com/in/California",
      "https://github.com/Al-Tareen",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Al Tareen",
    url: "https://altareen.com/",
  },
];

const homepageBreadcrumbs = [
  { name: "Home", path: "/" },
];
---

<BaseLayout
  title="Al Tareen | AI Transformation, Product Management, Product Strategy"
  description="Explore Al Tareen’s work across AI transformation, product management, product strategy, PM frameworks, financial models, concepts, and selected projects."
  keywords="Al Tareen, AI transformation, product management, product strategy, PM toolkit, finance toolkit, concepts, projects"
  schema={homepageSchema}
  breadcrumbs={homepageBreadcrumbs}
>
  <Header />

  <main class="wrap homepage-shell">
    <section class="hero">
      <p class="eyebrow">AI Transformation • Product Management • Product Strategy</p>

      <h1 id="home-title">Al Tareen</h1>

      <p class="lead">
        Welcome to my website. Explore selected Projects, a PM Toolkit for effective decision-making, a Finance Toolkit containing various models, Concepts that reflect how I think through new opportunities, and more.
      </p>
    </section>

    <section class="grid" aria-label="Homepage sections">
      <a
        class="card card-premium card-pm"
        href="/toolkit"
        onclick="trackEvent('homepage_section_click', { section: 'pm_toolkit', destination: '/toolkit', position: 1 })"
      >
        <div class="card-ambience" aria-hidden="true">
          <img
            class="card-ambience-media"
            src="/homepage/pm.png"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="card-premium-overlay" aria-hidden="true"></div>

        <div class="card-copy">
          <h2>PM Toolkit</h2>
          <p>Frameworks that help product managers make better decisions.</p>
        </div>

        {pmPages.length > 0 && (
          <div class="previewDeck previewDeckPm" data-rotator data-interval="5600">
            <div class="previewWindow previewWindowPm">
              <div class="previewTrack" data-preview-track>
                {pmPages.map((page) => (
                  <div class="previewPage previewPagePm" data-preview-page>
                    {page.map((entry) => (
                      <div class="previewCard previewCardPm">
                        <div class="previewCoverShell">
                          <img
                            class="previewCover"
                            src={entry.cover}
                            alt=""
                            loading="lazy"
                            decoding="async"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </div>

            {pmPages.length > 1 && (
              <div class="previewIndicators">
                {pmPages.map((_, index) => (
                  <span class={`previewDot ${index === 0 ? "isActive" : ""}`} data-preview-dot></span>
                ))}
              </div>
            )}
          </div>
        )}

        <span class="card-arrow" aria-hidden="true">↗</span>
      </a>

      <a
        class="card card-premium card-finance"
        href="/finance-toolkit"
        onclick="trackEvent('homepage_section_click', { section: 'finance_toolkit', destination: '/finance-toolkit', position: 2 })"
      >
        <div class="card-ambience" aria-hidden="true">
          <img
            class="card-ambience-media"
            src="/homepage/finance.png"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="card-premium-overlay" aria-hidden="true"></div>

        <div class="card-copy">
          <h2>Finance Toolkit</h2>
          <p>Financial models for founders and finance professionals.</p>
        </div>

        {financePages.length > 0 && (
          <div class="previewDeck" data-rotator data-interval="6200">
            <div class="previewWindow">
              <div class="previewTrack" data-preview-track>
                {financePages.map((page) => (
                  <div class="previewPage" data-preview-page>
                    {page.map((entry) => (
                      <div class="previewCard">
                        <div class="previewCoverShell">
                          <img
                            class="previewCover"
                            src={entry.cover}
                            alt=""
                            loading="lazy"
                            decoding="async"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </div>

            {financePages.length > 1 && (
              <div class="previewIndicators">
                {financePages.map((_, index) => (
                  <span class={`previewDot ${index === 0 ? "isActive" : ""}`} data-preview-dot></span>
                ))}
              </div>
            )}
          </div>
        )}

        <span class="card-arrow" aria-hidden="true">↗</span>
      </a>

      <a
        class="card card-premium card-concepts"
        href="/concepts"
        onclick="trackEvent('homepage_section_click', { section: 'concepts', destination: '/concepts', position: 3 })"
      >
        <div class="card-ambience" aria-hidden="true">
          <img
            class="card-ambience-media"
            src="/homepage/concepts.png"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="card-premium-overlay" aria-hidden="true"></div>

        <div class="card-copy">
          <h2>Concepts</h2>
          <p>Early-stage concepts and strategic business ideas.</p>
        </div>

        {conceptPages.length > 0 && (
          <div class="previewDeck" data-rotator data-interval="7000">
            <div class="previewWindow">
              <div class="previewTrack" data-preview-track>
                {conceptPages.map((page) => (
                  <div class="previewPage" data-preview-page>
                    {page.map((entry) => (
                      <div class="previewCard">
                        <div class="previewCoverShell">
                          <img
                            class="previewCover"
                            src={entry.cover}
                            alt=""
                            loading="lazy"
                            decoding="async"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </div>

            {conceptPages.length > 1 && (
              <div class="previewIndicators">
                {conceptPages.map((_, index) => (
                  <span class={`previewDot ${index === 0 ? "isActive" : ""}`} data-preview-dot></span>
                ))}
              </div>
            )}
          </div>
        )}

        <span class="card-arrow" aria-hidden="true">↗</span>
      </a>

      <a
        class="card card-premium card-projects"
        href="/projects"
        onclick="trackEvent('homepage_section_click', { section: 'projects', destination: '/projects', position: 4 })"
      >
        <div class="card-ambience" aria-hidden="true">
          <img
            class="card-ambience-media"
            src="/homepage/projects.png"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="card-premium-overlay" aria-hidden="true"></div>

        <div class="card-copy">
          <h2>Projects</h2>
          <p>Selected work across AI Transformation, Product Management, and more.</p>
        </div>

        <span class="card-arrow" aria-hidden="true">↗</span>
      </a>

      <a
        class="card card-premium card-about"
        href="/about"
        onclick="trackEvent('homepage_section_click', { section: 'about', destination: '/about', position: 5 })"
      >
        <div class="card-ambience" aria-hidden="true">
          <img
            class="card-ambience-media"
            src="/homepage/about.png"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="card-premium-overlay" aria-hidden="true"></div>

        <div class="card-copy">
          <h2>About</h2>
          <p>Who I am and where to find me.</p>
        </div>

        <span class="card-arrow" aria-hidden="true">↗</span>
      </a>
    </section>
  </main>

  <Footer />

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const rotators = Array.from(document.querySelectorAll("[data-rotator]"));
      const controls = [];

      function render(track, dots, activeIndex) {
        track.style.setProperty("--active-page", String(activeIndex));

        dots.forEach((dot, index) => {
          dot.classList.toggle("isActive", index === activeIndex);
        });
      }

      rotators.forEach((rotator, rotatorIndex) => {
        const track = rotator.querySelector("[data-preview-track]");
        const pages = Array.from(rotator.querySelectorAll("[data-preview-page]"));
        const dots = Array.from(rotator.querySelectorAll("[data-preview-dot]"));
        const card = rotator.closest(".card");

        if (!track || !pages.length) return;

        let activeIndex = 0;
        let timer = null;
        const interval = Number(rotator.dataset.interval || 5000) + rotatorIndex * 220;

        function stop() {
          if (timer) {
            window.clearInterval(timer);
            timer = null;
          }
        }

        function start() {
          if (prefersReducedMotion || pages.length < 2 || document.hidden) return;
          stop();
          timer = window.setInterval(() => {
            activeIndex = (activeIndex + 1) % pages.length;
            render(track, dots, activeIndex);
          }, interval);
        }

        render(track, dots, activeIndex);
        start();

        card?.addEventListener("mouseenter", stop);
        card?.addEventListener("mouseleave", start);
        card?.addEventListener("focusin", stop);
        card?.addEventListener("focusout", start);

        controls.push({ start, stop });
      });

      document.addEventListener("visibilitychange", () => {
        controls.forEach(({ start, stop }) => {
          if (document.hidden) stop();
          else start();
        });
      });
    });
  </script>
</BaseLayout>

<style>
  :global(header.wrap) {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  :global(main.homepage-shell) {
    background: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    outline: 0 !important;
  }

  .wrap {
    position: relative;
    width: 100%;
    max-width: var(--content-width, 1140px);
    margin: 0 auto;
    padding: 68px 28px 124px;
    box-sizing: border-box;
    isolation: isolate;
    overflow-x: clip;
  }

  .wrap::before {
    content: "";
    position: absolute;
    top: -28px;
    left: -28px;
    width: min(760px, 80vw);
    height: 440px;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(
        72% 72% at 18% 22%,
        rgba(255, 255, 255, 0.98) 0%,
        rgba(255, 255, 255, 0.72) 28%,
        rgba(255, 255, 255, 0.18) 56%,
        rgba(255, 255, 255, 0) 100%
      );
    opacity: 0.9;
    filter: blur(2px);
  }

  .wrap::after {
    content: "";
    position: absolute;
    top: 132px;
    right: -88px;
    width: min(440px, 42vw);
    height: 320px;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(
        64% 64% at 50% 50%,
        rgba(17, 24, 39, 0.08) 0%,
        rgba(17, 24, 39, 0.03) 38%,
        rgba(17, 24, 39, 0) 100%
      );
    filter: blur(18px);
    opacity: 0.54;
  }

  .hero,
  .grid {
    position: relative;
    z-index: 1;
  }

  .hero {
    padding: 6px 0 44px;
    max-width: 64rem;
    isolation: isolate;
  }

  .hero::after {
    content: "";
    display: block;
    margin-top: 34px;
    height: 1px;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--border) 88%, transparent) 0%,
        color-mix(in srgb, var(--border) 54%, transparent) 42%,
        transparent 100%
      );
  }

  .eyebrow {
    margin: 0 0 14px;
    color: color-mix(in srgb, var(--ink-muted) 80%, var(--ink) 20%);
    font-size: 11px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .hero h1 {
    margin: 0 0 16px;
    color: var(--ink);
    font-size: clamp(2.6rem, 5.8vw, 5.15rem);
    font-weight: 680;
    line-height: 0.93;
    letter-spacing: -0.062em;
    text-wrap: balance;
    max-width: 8.15ch;
  }

  .lead {
    margin: 0;
    color: color-mix(in srgb, var(--ink-secondary, var(--ink-muted)) 90%, var(--ink) 10%);
    font-size: 1rem;
    line-height: 1.72;
    max-width: 62ch;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-template-areas:
      "projects projects projects projects pm pm pm pm pm pm pm pm"
      "finance finance finance finance concepts concepts concepts concepts about about about about";
    gap: 14px;
    align-items: stretch;
  }

  .card {
    position: relative;
    display: flex;
    text-decoration: none;
    border-radius: 18px;
    border: 1px solid rgba(22, 30, 42, 0.92);
    box-sizing: border-box;
    overflow: clip;
    transition:
      border-color 0.28s var(--ease),
      box-shadow 0.28s var(--ease),
      transform 0.28s var(--ease),
      background 0.28s var(--ease);
  }

  .card:hover {
    transform: translateY(-2px);
  }

  .card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.32) inset,
      0 0 0 1px rgba(255,255,255,0.02) inset;
  }

  .card-premium {
    --card-accent: rgba(89, 158, 255, 0.12);
    min-height: 320px;
    padding: 24px;
    display: grid;
    grid-template-rows: auto auto;
    gap: 14px;
    align-items: start;
    justify-content: stretch;
    background:
      linear-gradient(180deg, rgba(16, 22, 31, 0.985) 0%, rgba(9, 13, 19, 0.985) 100%);
    border-color: rgba(22, 30, 42, 0.92);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.06) inset,
      0 18px 44px rgba(4, 8, 14, 0.16);
    isolation: isolate;
  }

  .card-premium::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(255,255,255,0.055) 0%,
        rgba(255,255,255,0.012) 18%,
        rgba(255,255,255,0) 36%
      );
  }

  .card-premium:hover {
    border-color: rgba(34, 47, 66, 0.96);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.08) inset,
      0 24px 56px rgba(5, 8, 14, 0.18);
  }

  .card-pm {
    --card-accent: rgba(84, 150, 255, 0.12);
    grid-area: pm;
    min-height: 360px;
  }

  .card-finance {
    --card-accent: rgba(104, 214, 136, 0.11);
    grid-area: finance;
    min-height: 290px;
  }

  .card-concepts {
    --card-accent: rgba(110, 176, 255, 0.1);
    grid-area: concepts;
    min-height: 290px;
  }

  .card-projects {
    --card-accent: rgba(255, 184, 77, 0.1);
    grid-area: projects;
    min-height: 360px;
  }

  .card-about {
    --card-accent: rgba(180, 180, 255, 0.1);
    grid-area: about;
    min-height: 290px;
  }

  .card-copy {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: 6px;
    max-width: 34ch;
  }

  .card-pm .card-copy {
    max-width: 34ch;
  }

  .card-finance .card-copy {
    max-width: 24ch;
  }

  .card-concepts .card-copy,
  .card-projects .card-copy,
  .card-about .card-copy {
    max-width: 22ch;
  }

  .card h2 {
    margin: 0;
    color: rgba(255,255,255,0.985);
    font-size: 1.14rem;
    font-weight: 660;
    line-height: 1.06;
    letter-spacing: -0.024em;
    text-shadow: 0 1px 1px rgba(0,0,0,0.14);
  }

  .card-pm h2,
  .card-finance h2 {
    font-size: 1.28rem;
    letter-spacing: -0.028em;
  }

  .card p {
    margin: 0;
    color: rgba(255,255,255,0.78);
    font-size: 0.92rem;
    line-height: 1.5;
    max-width: 28ch;
  }

  .card-ambience {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .card-ambience::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0) 28%),
      radial-gradient(56% 56% at 78% 26%, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0) 100%);
    pointer-events: none;
  }

  .card-ambience-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    pointer-events: none;
    opacity: 0.72;
    filter: saturate(0.94) contrast(1.02) brightness(0.56);
    transform-origin: center;
    transition:
      transform 0.6s var(--ease),
      filter 0.6s var(--ease),
      opacity 0.6s var(--ease);
  }

  .card-pm .card-ambience-media {
    object-position: 52% 48%;
    transform: scale(1.05);
  }

  .card-finance .card-ambience-media {
    object-position: 52% 50%;
    transform: scale(1.06);
  }

  .card-concepts .card-ambience-media,
  .card-projects .card-ambience-media,
  .card-about .card-ambience-media {
    object-position: 50% 50%;
    transform: scale(1.06);
  }

  .card-premium:hover .card-ambience-media {
    opacity: 0.76;
    filter: saturate(0.98) contrast(1.04) brightness(0.6);
  }

  .card-premium-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.04) 30%, rgba(8, 12, 18, 0.16) 100%),
      linear-gradient(90deg, rgba(6, 10, 16, 0.74) 0%, rgba(6, 10, 16, 0.46) 28%, rgba(6, 10, 16, 0.16) 62%, rgba(6, 10, 16, 0.1) 100%),
      radial-gradient(74% 86% at 84% 54%, var(--card-accent) 0%, rgba(0,0,0,0) 60%);
  }

  .previewDeck {
    position: relative;
    z-index: 4;
    display: grid;
    gap: 10px;
    margin-top: 0px;
    padding-top: 0;
  }

  .previewDeckPm {
    max-width: none;
  }

  .previewWindow {
    overflow: hidden;
    padding: 1px;
  }

  .previewWindowPm {
    -webkit-mask-image: linear-gradient(90deg, #000 0%, #000 88%, rgba(0,0,0,0.66) 94%, transparent 100%);
    mask-image: linear-gradient(90deg, #000 0%, #000 88%, rgba(0,0,0,0.66) 94%, transparent 100%);
  }

  .previewTrack {
    --active-page: 0;
    display: flex;
    width: 100%;
    transform: translateX(calc(var(--active-page) * -100%));
    transition: transform 980ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .previewPage {
    min-width: 100%;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    align-content: start;
  }

  .previewPagePm {
    grid-template-columns: repeat(4, 29.5%);
    gap: 12px;
  }

  .previewCard {
    min-width: 0;
    padding: 4px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.08);
    background:
      linear-gradient(
        180deg,
        rgba(255,255,255,0.035) 0%,
        rgba(255,255,255,0.012) 100%
      );
    box-shadow:
      0 1px 0 rgba(255,255,255,0.04) inset,
      0 8px 18px rgba(0,0,0,0.12);
    transition:
      transform 0.28s var(--ease),
      border-color 0.28s var(--ease),
      box-shadow 0.28s var(--ease);
  }

  .previewCardPm {
    border-radius: 10px;
  }

  .previewCoverShell {
    position: relative;
    aspect-ratio: 1400 / 930;
    overflow: hidden;
    border-radius: 7px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.02);
