---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Al Tareen — Product Manager"
  description="Personal site: projects, PM toolkit, articles, resume, and ways to connect."
>
  <Header />

  <main class="wrap">
    <section class="hero">
      <h1>Product Manager. Builder. Systems thinker.</h1>
      <p class="lead">
        I build practical products and workflows—especially around AI, automation, and operations.
        This is my portfolio, toolkit, and writing hub.
      </p>

      <div class="cta">
        <a class="btn primary" href="/projects">View Projects</a>
        <a class="btn" href="/resume">Resume</a>
        <a class="btn" href="/contact">Contact</a>
      </div>
    </section>

    <section class="grid">
      <a class="card" href="/projects">
        <h2>Projects</h2>
        <p>Selected work, outcomes, and demos.</p>
      </a>
      <a class="card" href="/toolkit">
        <h2>PM Toolkit</h2>
        <p>Templates, checklists, and frameworks I actually use.</p>
      </a>
      <a class="card" href="/finance-toolkit">
        <h2>Finance Toolkit</h2>
        <p>Financial models and templates for planning and analysis.</p>
      </a>
      <a class="card" href="/articles">
        <h2>Articles</h2>
        <p>Notes on product, execution, AI, and career growth.</p>
      </a>
      <a class="card" href="/socials">
        <h2>Socials</h2>
        <p>Where to find me online.</p>
      </a>
      <a class="card" href="/about">
        <h2>About</h2>
        <p>My background and what I’m optimizing for.</p>
      </a>
      <a class="card" href="/contact">
        <h2>Contact</h2>
        <p>Reach me fast without spam.</p>
      </a>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .wrap {
    max-width: var(--content-width, 980px);
    margin: 0 auto;
    padding: 48px 28px 64px;
  }

  .hero {
    padding: 32px 0 48px;
    max-width: 42rem;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin: 0 0 20px;
    color: var(--ink);
  }

  .lead {
    font-size: 1.125rem;
    line-height: 1.65;
    max-width: 38ch;
    color: var(--ink-secondary);
    margin: 0 0 28px;
  }

  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 0;
  }

  .btn {
    display: inline-block;
    padding: 12px 20px;
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
    transition: background 0.22s var(--ease), color 0.22s var(--ease), transform 0.2s var(--ease);
  }

  .btn:not(.primary) {
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--ink);
  }

  .btn:not(.primary):hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .btn.primary {
    background: var(--ink);
    color: var(--surface);
    border: 1px solid var(--ink);
  }

  .btn.primary:hover {
    background: #333;
    border-color: #333;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    padding: 0;
  }

  .card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 24px;
    text-decoration: none;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.28s var(--ease), transform 0.28s var(--ease), border-color 0.28s var(--ease);
  }

  .card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  .card h2 {
    margin: 0 0 8px;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--ink-secondary);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .wrap {
      padding: 32px 20px 48px;
    }
    .hero {
      padding: 24px 0 36px;
    }
    .grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .card {
      padding: 20px;
    }
  }
</style>
