---
import PageShell from "../../components/PageShell.astro";
import { getCollection } from "astro:content";

const CATEGORY_ORDER = [
  "Product Platforms",
  "AI Systems",
  "Enterprise Systems",
  "Software Engineering",
  "Research & Leadership",
];

const projectsBreadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Projects", path: "/projects/" },
];

function slugify(str: string) {
  return String(str || "")
    .trim()
    .toLowerCase()
    .replace(/['"]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function stripMarkdown(raw = "") {
  return String(raw)
    .replace(/^---[\s\S]*?---/, "")
    .replace(/^##\s.+$/gm, "")
    .replace(/^#\s.+$/gm, "")
    .replace(/^\-\s.+$/gm, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_`>#]/g, "")
    .replace(/\n{3,}/g, "\n\n")
    .trim();
}

function firstParagraph(raw = "") {
  const cleaned = stripMarkdown(raw);
  return (
    cleaned
      .split(/\n{2,}/)
      .map((p) => p.replace(/\n/g, " ").trim())
      .find(Boolean) || ""
  );
}

function extFromUrl(url = "") {
  const clean = String(url).split("?")[0].toLowerCase();
  const match = clean.match(/\.[a-z0-9]{2,8}$/);
  return match ? match[0] : "";
}

function isImageExt(ext = "") {
  return [".png", ".jpg", ".jpeg", ".webp", ".gif", ".svg", ".avif"].includes(ext);
}

function isPdfExt(ext = "") {
  return ext === ".pdf";
}

const all = await getCollection("projects");

const rawProjects = all.filter((item) => {
  const dbTitle = String(item.data.dbTitle || "").trim().toLowerCase();
  return dbTitle === "projects" || dbTitle === "project";
});

const normalized = rawProjects.map((item) => {
  const title = String(
    item.data.project ||
      item.data.title ||
      item.slug ||
      "Untitled Project"
  ).trim();

  const primaryCategory = String(
    item.data.primaryCategory ||
      item.data.category ||
      (Array.isArray(item.data.categories) && item.data.categories[0]) ||
      "Uncategorized"
  ).trim();

  const tags = Array.isArray(item.data.tags)
    ? item.data.tags.map(String).map((t) => t.trim()).filter(Boolean).slice(0, 3)
    : [];

  const files = Array.isArray(item.data.files)
    ? item.data.files.filter((f) => f?.url)
    : [];

  const externalLink = String(item.data.url || item.data.link || "").trim();
  const previewFile = files[0] || null;
  const previewUrl = previewFile?.url || "";
  const previewExt = extFromUrl(previewUrl);
  const previewKind = isPdfExt(previewExt)
    ? "pdf"
    : isImageExt(previewExt)
      ? "image"
      : "file";

  const logo = String(item.data.logo || item.data.cover || "").trim();

  const description = String(
    item.data.description ||
      item.data.summary ||
      item.data.excerpt ||
      firstParagraph(item.body || "") ||
      "Details coming soon."
  )
    .replace(/\s+/g, " ")
    .trim();

  const comingSoon = item.data.comingSoon === true;
  const position =
    typeof item.data.position === "number"
      ? item.data.position
      : Number.isFinite(Number(item.data.position))
        ? Number(item.data.position)
        : 0;

  return {
    ...item,
    slugId: slugify(title),
    projectTitle: title,
    primaryCategory,
    tags,
    externalLink,
    previewUrl,
    previewKind,
    logo,
    description,
    comingSoon,
    position,
    sortKey: title.toLowerCase(),
  };
});

const groupsMap = new Map<string, typeof normalized>();
for (const category of CATEGORY_ORDER) groupsMap.set(category, []);

const extraMap = new Map<string, typeof normalized>();

for (const item of normalized) {
  if (groupsMap.has(item.primaryCategory)) {
    groupsMap.get(item.primaryCategory)!.push(item);
  } else {
    if (!extraMap.has(item.primaryCategory)) extraMap.set(item.primaryCategory, []);
    extraMap.get(item.primaryCategory)!.push(item);
  }
}

function sortProjects(list: typeof normalized) {
  list.sort((a, b) => {
    if (a.position !== b.position) return a.position - b.position;
    return a.sortKey.localeCompare(b.sortKey);
  });
}

for (const list of groupsMap.values()) sortProjects(list);
for (const list of extraMap.values()) sortProjects(list);

const groups = [
  ...CATEGORY_ORDER.map((category) => ({
    category,
    items: groupsMap.get(category) || [],
  })).filter((g) => g.items.length > 0),
  ...Array.from(extraMap.entries())
    .sort((a, b) => a[0].localeCompare(b[0]))
    .map(([category, items]) => ({ category, items })),
];

const categories = groups.map((g) => g.category);

const projectsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Projects",
  description:
    "Selected work across AI systems, enterprise platforms, software engineering, and more.",
  url: "https://altareen.com/projects/",
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: projectsBreadcrumbs.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      item: `https://altareen.com${item.path}`,
    })),
  },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: normalized.slice(0, 20).map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.projectTitle,
      url: `https://altareen.com/projects/#${item.slugId}`,
    })),
  },
};
---

<PageShell
  title="Projects"
  hidePageHead={false}
  description="Selected work across AI systems, enterprise platforms and more."
  keywords="Al Tareen projects, AI product manager, AI systems, enterprise systems, product platforms, software engineering"
  breadcrumbs={projectsBreadcrumbs}
  schema={projectsSchema}
>
  <div class="projectsPage projectsRoot">
    <div class="controlsBarSentinel" aria-hidden="true"></div>
    <div class="controlsBar" role="search" aria-label="Search and filter projects">
      <div class="field">
        <span class="icon" aria-hidden="true">⌕</span>
        <input id="q" class="input" type="search" placeholder="Search projects..." />
      </div>

<div class="selectWrap">
  <select id="cat" class="select" aria-label="Filter by category">
    <option value="">All categories</option>
    {categories.map((c) => <option value={c}>{c}</option>)}
  </select>
  <span class="selectChevron" aria-hidden="true">
    <img class="selectChevronIcon" src="/homepage/downarrow.png" alt="" />
  </span>
</div>

<div class="rightActions">
  <div class="resultsInline" id="resultsText">Showing {normalized.length} projects</div>
  <button id="clear" class="ghost" type="button">Clear</button>
</div> 
</div>

    <div id="empty" class="empty" hidden>
      <div class="emptyTitle">No projects found</div>
      <div class="emptyDesc">Try a different search term, or clear filters.</div>
      <button id="emptyClear" class="primary" type="button">Clear filters</button>
    </div>

    {groups.map((group) => (
      <section
        class="projectGroup"
        id={slugify(group.category)}
        data-rail-group
        data-group={group.category}
      >
        <div class="groupHead">
          <div class="groupTitleWrap">
            <h2 class="groupTitle">
              {group.category} <span class="count">({group.items.length})</span>
            </h2>
          </div>
        </div>

        <div class="railShell">
          <div class="railMask">
            <div class="railViewport" data-rail-viewport tabindex="0" aria-label={group.category}>
              <div class="projectRail" data-rail>
                {group.items.map((item) => (
                  <article
                    id={item.slugId}
                    class={`projectCard${item.comingSoon ? " isComingSoon" : ""}`}
                    data-project-card
                    data-title={item.projectTitle}
                    data-category={item.primaryCategory}
                    data-desc={item.description}
                    data-tags={item.tags.join(" ")}
                  >
                    {item.comingSoon && (
                      <div class="comingChrome" aria-hidden="true">
                        <div class="comingChromeTop">
                          <div class="comingLabel">In Development</div>
                          <div class="comingSignalWrap">
                            <span class="comingSignal"></span>
                          </div>
                        </div>
                        <div class="comingTrack">
                          <span class="comingTrackFill"></span>
                        </div>
                      </div>
                    )}

                    <div class="cardGlow" aria-hidden="true"></div>

                    <div class="cardBody">
                      <div class="cardTop">
                        <h3 class="cardTitle">{item.projectTitle}</h3>
                      </div>

                      <p class="cardDesc">{item.description}</p>
                    </div>

                    <div class="cardFooter">
                      <div class="bottomMeta">
                        <div class="logoSlot">
                          {item.logo ? (
                            <img
                              class="projectLogo"
                              src={item.logo}
                              alt={`${item.projectTitle} logo`}
                              loading="lazy"
                            />
                          ) : (
                            <div class="logoFallback" aria-hidden="true">
                              {item.projectTitle.slice(0, 2).toUpperCase()}
                            </div>
                          )}
                        </div>

                        <div class="projectTags">
                          {item.tags.map((tag) => (
                            <span class="tag">{tag}</span>
                          ))}
                        </div>
                      </div>

                      {item.comingSoon ? (
                        <div class="cardActions comingActions" aria-hidden="true">
                          <div class="comingNote">
                            <div class="comingNoteLabel">Coming Soon</div>
                          </div>
                        </div>
                      ) : (
                        <div class="cardActions">
                          {item.externalLink ? (
                            <a
                              class="actionBtn primary projectActionBtn"
                              href={item.externalLink}
                              target="_blank"
                              rel="noreferrer"
                              data-project-cta
                              data-project={item.projectTitle}
                              data-category={item.primaryCategory}
                              data-position={item.position}
                              data-destination="url"
                            >
                              <span class="actionBtnText">View</span>
                              <span class="actionBtnIcon" aria-hidden="true">↗</span>
                            </a>
                          ) : item.previewUrl ? (
                            <button
                              class="actionBtn primary projectActionBtn"
                              type="button"
                              data-preview-open
                              data-preview-title={item.projectTitle}
                              data-preview-url={item.previewUrl}
                              data-preview-kind={item.previewKind}
                              data-project-cta
                              data-project={item.projectTitle}
                              data-category={item.primaryCategory}
                              data-position={item.position}
                              data-destination="file"
                            >
                              <span class="actionBtnText">View</span>
                              <span class="actionBtnIcon" aria-hidden="true">↗</span>
                            </button>
                          ) : (
                            <div class="cardActions isEmpty" aria-hidden="true"></div>
                          )}
                        </div>
                      )}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </div>

          <div class="railFade" aria-hidden="true"></div>

          <button
            class="railFloat railFloatPrev"
            type="button"
            data-rail-prev
            aria-label={`Scroll ${group.category} left`}
          >
            <img class="railArrow railArrowPrev" src="/homepage/downarrow.png" alt="" aria-hidden="true" />
          </button>

          <button
            class="railFloat railFloatNext"
            type="button"
            data-rail-next
            aria-label={`Scroll ${group.category} right`}
          >
            <img class="railArrow railArrowNext" src="/homepage/downarrow.png" alt="" aria-hidden="true" />
          </button>
        </div>
      </section>
    ))}

    <div class="previewModal" id="projectPreviewModal" hidden>
      <div class="previewBackdrop" data-preview-close></div>

      <div
        class="previewPanel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="projectPreviewTitle"
      >
        <div class="previewHead">
          <div class="previewHeadCopy">
            <h3 class="previewTitle" id="projectPreviewTitle">Preview</h3>
            <div class="previewHint">Esc to close</div>
          </div>

          <div class="previewActions">
            <a
              class="actionBtn projectSecondaryBtn previewActionBtn"
              id="projectPreviewOpenNew"
              href="#"
              target="_blank"
              rel="noreferrer"
            >
              <span class="actionBtnText" id="projectPreviewActionText">Open in new tab</span>
              <span class="actionBtnIcon" id="projectPreviewActionIcon" aria-hidden="true">↗</span>
            </a>

            <button
              class="actionBtn previewActionBtn"
              type="button"
              data-preview-close
              aria-label="Close preview"
            >
              <span class="actionBtnText">Close</span>
              <span class="actionBtnIcon" aria-hidden="true">✕</span>
            </button>
          </div>
        </div>

        <div class="previewBody" id="projectPreviewBody"></div>
      </div>
    </div>

    <button id="toTop" class="toTop" type="button" aria-label="Back to top">↑ Top</button>
  </div>
</PageShell>

<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const q = document.getElementById("q");
    const cat = document.getElementById("cat");
    const clear = document.getElementById("clear");
    const empty = document.getElementById("empty");
    const emptyClear = document.getElementById("emptyClear");
    const resultsText = document.getElementById("resultsText");
    const railGroups = Array.from(document.querySelectorAll("[data-rail-group]"));
    const toTop = document.getElementById("toTop");

    function normalize(s) {
      return (s || "").toLowerCase().trim();
    }

    const controlsBar = document.querySelector(".controlsBar");
    const controlsBarSentinel = document.querySelector(".controlsBarSentinel");
    const projectsRoot = document.querySelector(".projectsRoot");
    let stickyControlBarSyncFrame = 0;
    let stickyControlBarState = false;

    function syncStickyControlBar() {
      stickyControlBarSyncFrame = 0;
      if (!controlsBar) return;

      const stickyTop = parseFloat(getComputedStyle(controlsBar).top || "0") || 0;
      const markerRect = controlsBarSentinel
        ? controlsBarSentinel.getBoundingClientRect()
        : controlsBar.getBoundingClientRect();
      const enterThreshold = stickyTop + 0.5;
      const exitThreshold = stickyTop + (window.innerWidth > 720 ? 8 : 0.5);
      const nextSticky = stickyControlBarState
        ? markerRect.top <= exitThreshold
        : markerRect.top <= enterThreshold;

      stickyControlBarState = nextSticky;

      controlsBar.classList.toggle("isStickyMobile", nextSticky);

      if (nextSticky && projectsRoot) {
        const hostRect = projectsRoot.getBoundingClientRect();
        const leftExpand = Math.max(0, hostRect.left);
        const rightExpand = Math.max(0, window.innerWidth - hostRect.right);
        controlsBar.style.setProperty("--sticky-expand-left", `${leftExpand}px`);
        controlsBar.style.setProperty("--sticky-expand-right", `${rightExpand}px`);
        controlsBar.style.setProperty("--sticky-expand-total", `${leftExpand + rightExpand}px`);
      } else {
        controlsBar.style.removeProperty("--sticky-expand-left");
        controlsBar.style.removeProperty("--sticky-expand-right");
        controlsBar.style.removeProperty("--sticky-expand-total");
      }
    }

    function queueStickyControlBarSync() {
      if (stickyControlBarSyncFrame) return;
      stickyControlBarSyncFrame = window.requestAnimationFrame(syncStickyControlBar);
    }

    function countVisibleCards() {
      return document.querySelectorAll("[data-project-card]:not(.isHidden)").length;
    }

    function updateRailButtons(group) {
      const viewport = group.querySelector("[data-rail-viewport]");
      const prev = group.querySelector("[data-rail-prev]");
      const next = group.querySelector("[data-rail-next]");
      const fade = group.querySelector(".railFade");

      if (!viewport || !prev || !next) return;

      if (group.classList.contains("isHidden")) {
        prev.hidden = true;
        next.hidden = true;
        if (fade) fade.hidden = true;
        return;
      }

      const maxScroll = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
      const canScroll = maxScroll > 12;
      const canPrev = canScroll && viewport.scrollLeft > 6;
      const canNext = canScroll && viewport.scrollLeft < maxScroll - 6;

      prev.hidden = !canPrev;
      next.hidden = !canNext;
      if (fade) fade.hidden = !canNext;
    }

    function scrollRail(group, direction) {
      const viewport = group.querySelector("[data-rail-viewport]");
      if (!viewport) return;

      const step = Math.max(viewport.clientWidth * 0.86, 320);
      viewport.scrollBy({
        left: direction * step,
        behavior: "smooth",
      });
    }

    railGroups.forEach((group) => {
      const viewport = group.querySelector("[data-rail-viewport]");
      const prev = group.querySelector("[data-rail-prev]");
      const next = group.querySelector("[data-rail-next]");

      prev?.addEventListener("click", () => scrollRail(group, -1));
      next?.addEventListener("click", () => scrollRail(group, 1));

      viewport?.addEventListener("scroll", () => updateRailButtons(group), {
        passive: true,
      });

      updateRailButtons(group);
    });

    window.addEventListener("resize", () => {
      railGroups.forEach(updateRailButtons);
    });

    function applyFilter() {
      const query = normalize(q?.value);
      const selected = cat?.value || "";
      const sections = document.querySelectorAll("[data-rail-group]");

      sections.forEach((section) => {
        const cards = section.querySelectorAll("[data-project-card]");
        let visibleCount = 0;

        cards.forEach((card) => {
          const title = normalize(card.getAttribute("data-title"));
          const category = card.getAttribute("data-category") || "";
          const desc = normalize(card.getAttribute("data-desc"));
          const tags = normalize(card.getAttribute("data-tags"));

          const matchText =
            !query ||
            title.includes(query) ||
            desc.includes(query) ||
            tags.includes(query) ||
            normalize(category).includes(query);

          const matchCat = !selected || category === selected;
          const show = matchText && matchCat;

          card.classList.toggle("isHidden", !show);
          if (show) visibleCount++;
        });

        section.classList.toggle("isHidden", visibleCount === 0);
      });

      const totalVisible = countVisibleCards();
      if (empty) empty.hidden = totalVisible !== 0;

      if (resultsText) {
        const suffix = totalVisible === 1 ? "project" : "projects";
        resultsText.textContent = `Showing ${totalVisible} ${suffix}`;
      }

      requestAnimationFrame(() => {
        railGroups.forEach(updateRailButtons);
      });
    }

    function clearFilters() {
      if (q) q.value = "";
      if (cat) cat.value = "";
      applyFilter();
      q?.focus();
    }

    function updateToTop() {
      if (!toTop) return;
      const show = window.scrollY > 420;
      toTop.classList.toggle("isVisible", show);
    }

    window.addEventListener("scroll", queueStickyControlBarSync, { passive: true });
    window.addEventListener("resize", queueStickyControlBarSync);

    q?.addEventListener("input", applyFilter);
    cat?.addEventListener("change", applyFilter);
    clear?.addEventListener("click", clearFilters);
    emptyClear?.addEventListener("click", clearFilters);
    window.addEventListener("scroll", updateToTop, { passive: true });
    toTop?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
    updateToTop();
    applyFilter();

    document.querySelectorAll("[data-project-cta]").forEach((el) => {
      el.addEventListener("click", () => {
        const payload = {
          project: el.getAttribute("data-project") || "",
          category: el.getAttribute("data-category") || "",
          position: Number(el.getAttribute("data-position") || 0),
          destination: el.getAttribute("data-destination") || "",
          page: "projects_index",
        };

        if (typeof window.trackEvent === "function") {
          window.trackEvent("project_view_click", payload);
        }
      });
    });

    const modal = document.getElementById("projectPreviewModal");
    const modalTitle = document.getElementById("projectPreviewTitle");
    const modalBody = document.getElementById("projectPreviewBody");
    const openNew = document.getElementById("projectPreviewOpenNew");
    const previewActionText = document.getElementById("projectPreviewActionText");
    const previewActionIcon = document.getElementById("projectPreviewActionIcon");
    const openButtons = document.querySelectorAll("[data-preview-open]");
    const closeButtons = document.querySelectorAll("[data-preview-close]");

    let activePdfRenderToken = 0;
    let pdfJsLibPromise = null;

    async function loadPdfJs() {
      if (window.pdfjsLib) return window.pdfjsLib;
      if (pdfJsLibPromise) return pdfJsLibPromise;

      pdfJsLibPromise = new Promise((resolve, reject) => {
        const existing = document.querySelector('script[data-pdfjs-loader="true"]');

        function finish() {
          if (!window.pdfjsLib) {
            reject(new Error("pdf.js failed to load."));
            return;
          }
          window.pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
          resolve(window.pdfjsLib);
        }

        if (existing) {
          existing.addEventListener("load", finish, { once: true });
          existing.addEventListener("error", () => reject(new Error("pdf.js loader failed.")), { once: true });
          if (window.pdfjsLib) finish();
          return;
        }

        const script = document.createElement("script");
        script.src = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js";
        script.async = true;
        script.dataset.pdfjsLoader = "true";
        script.addEventListener("load", finish, { once: true });
        script.addEventListener("error", () => reject(new Error("pdf.js loader failed.")), { once: true });
        document.head.appendChild(script);
      });

      return pdfJsLibPromise;
    }

function buildPdfPreviewUrl(baseUrl) {
  return `${baseUrl}#view=fitH`;
}

    async function renderPdfPreview(url, title) {
      if (!modalBody) return;

      const renderToken = ++activePdfRenderToken;
      modalBody.innerHTML = "";
      modalBody.dataset.kind = "pdf";

      const stage = document.createElement("div");
      stage.className = "previewPdfStage";

      const loading = document.createElement("div");
      loading.className = "previewPdfLoading";
      loading.textContent = "Loading PDF…";
      stage.appendChild(loading);
      modalBody.appendChild(stage);

      try {
        const pdfjsLib = await loadPdfJs();
        if (renderToken != activePdfRenderToken || !modalBody) return;

        const pdf = await pdfjsLib.getDocument(url).promise;
        if (renderToken != activePdfRenderToken || !modalBody) return;

        stage.innerHTML = "";

        const doc = document.createElement("div");
        doc.className = "previewPdfDoc";
        stage.appendChild(doc);

        const availableWidth = Math.max(320, (modalBody.clientWidth || stage.clientWidth || 960) - 32);
        const targetWidth = Math.max(280, Math.min(1400, availableWidth));
        const pixelRatio = Math.min(window.devicePixelRatio || 1, 2);

        for (let pageNumber = 1; pageNumber <= pdf.numPages; pageNumber += 1) {
          if (renderToken != activePdfRenderToken || !modalBody) return;

          const page = await pdf.getPage(pageNumber);
          const baseViewport = page.getViewport({ scale: 1 });
          const scale = targetWidth / baseViewport.width;
          const viewport = page.getViewport({ scale });

          const pageWrap = document.createElement("div");
          pageWrap.className = "previewPdfPage";

          const canvas = document.createElement("canvas");
          canvas.className = "previewPdfPageCanvas";
          const context = canvas.getContext("2d", { alpha: false });

          canvas.width = Math.floor(viewport.width * pixelRatio);
          canvas.height = Math.floor(viewport.height * pixelRatio);
          canvas.style.width = `${viewport.width}px`;
          canvas.style.height = `${viewport.height}px`;

          pageWrap.appendChild(canvas);
          doc.appendChild(pageWrap);

          await page.render({
            canvasContext: context,
            viewport,
            transform: pixelRatio !== 1 ? [pixelRatio, 0, 0, pixelRatio, 0, 0] : null,
          }).promise;
        }
      } catch (error) {
        if (renderToken != activePdfRenderToken || !modalBody) return;
        stage.innerHTML = "";

        const frame = document.createElement("iframe");
        frame.className = "previewFrame previewPdfFrame";
        frame.src = buildPdfPreviewUrl(url);
        frame.title = title || "PDF preview";
        frame.loading = "lazy";
        frame.setAttribute("aria-label", title || "PDF preview");
        stage.appendChild(frame);
      }
    }

    function buildPreview(kind, url, title) {
      if (!modalBody) return;

      modalBody.innerHTML = "";
      modalBody.dataset.kind = kind || "file";

      if (kind === "pdf") {
        renderPdfPreview(url, title);
        return;
      }

if (kind === "image") {
  const stage = document.createElement("div");
  stage.className = "previewImageStage";

  const canvas = document.createElement("div");
  canvas.className = "previewImageCanvas";

  const img = document.createElement("img");
  img.className = "previewImage";
  img.src = url;
  img.alt = title;
  img.loading = "eager";
  img.decoding = "async";

  img.addEventListener("load", () => {
    if (!modalBody) return;
    modalBody.scrollTop = 0;
    modalBody.scrollLeft = 0;
  });

  canvas.appendChild(img);
  stage.appendChild(canvas);
  modalBody.appendChild(stage);
  return;
}

      const fallback = document.createElement("div");
      fallback.className = "previewFallback";
      fallback.innerHTML = `
        <div class="previewFallbackTitle">Preview unavailable in modal</div>
        <p class="previewFallbackDesc">Use the action above to open the file in a new tab.</p>
      `;
      modalBody.appendChild(fallback);
    }

    function lockPreviewScroll() {
      const scrollbarComp = Math.max(0, window.innerWidth - document.documentElement.clientWidth);
      document.documentElement.style.setProperty("--preview-scrollbar-comp", `${scrollbarComp}px`);
      document.body.style.paddingRight = `${scrollbarComp}px`;
      document.documentElement.classList.add("previewIsOpen");
      document.body.classList.add("previewIsOpen");
    }

    function unlockPreviewScroll() {
      document.documentElement.classList.remove("previewIsOpen");
      document.body.classList.remove("previewIsOpen");
      document.documentElement.style.removeProperty("--preview-scrollbar-comp");
      document.body.style.paddingRight = "";
    }

    function openPreview(title, url, kind) {
      if (!modal || !modalTitle || !modalBody || !openNew) return;

      modalTitle.textContent = title || "Preview";
      buildPreview(kind, url, title || "Preview");
      openNew.href = url;

      if (kind === "pdf") {
        openNew.setAttribute("download", "");
        if (previewActionText) previewActionText.textContent = "Download";
        if (previewActionIcon) previewActionIcon.textContent = "↓";
      } else {
        openNew.removeAttribute("download");
        if (previewActionText) previewActionText.textContent = "Open in new tab";
        if (previewActionIcon) previewActionIcon.textContent = "↗";
      }

      modal.hidden = false;

      if (typeof modal.scrollTo === "function") {
        modal.scrollTo({ top: 0, left: 0, behavior: "instant" });
      } else {
        modal.scrollTop = 0;
      }

      modalBody.scrollTop = 0;
      modalBody.scrollLeft = 0;
      lockPreviewScroll();
    }

    function closePreview() {
      if (!modal || !modalBody) return;
      activePdfRenderToken += 1;
      modal.hidden = true;
      modalBody.innerHTML = "";
      modalBody.removeAttribute("data-kind");
      openNew?.removeAttribute("download");
      if (previewActionText) previewActionText.textContent = "Open in new tab";
      if (previewActionIcon) previewActionIcon.textContent = "↗";
      unlockPreviewScroll();
    }
    openButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const title = btn.getAttribute("data-preview-title") || "Preview";
        const url = btn.getAttribute("data-preview-url") || "";
        const kind = btn.getAttribute("data-preview-kind") || "file";
        if (!url) return;
        openPreview(title, url, kind);
      });
    });

    closeButtons.forEach((btn) => {
      btn.addEventListener("click", closePreview);
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && modal && !modal.hidden) {
        closePreview();
      }
    });
  });
</script>

