---
import PageShell from "../../components/PageShell.astro";

const projects = [
  {
    title: "Enterprise AI Platform",
    description: "Led product strategy for an AI-powered automation platform that reduced manual ops by 60% across 12 enterprise accounts.",
    tags: ["AI", "Automation", "Enterprise"],
    href: "#",
  },
  {
    title: "Service Desk Cost Reduction",
    description: "Designed automation workflows that cut tier-1 ticket volume by 40% and lowered per-ticket cost by 35%.",
    tags: ["Automation", "Cost Reduction", "Product"],
    href: "#",
  },
  {
    title: "Multi-Agent AI Workflows",
    description: "Product-led R&D for agent orchestration that improved task completion rates by 2x with human-in-the-loop guardrails.",
    tags: ["AI", "Agents", "Product"],
    href: "#",
  },
  {
    title: "altareen.com",
    description: "Portfolio site built with Astro—fast, accessible, and easy to maintain for showcasing product work.",
    tags: ["Web", "Astro", "Product"],
    href: "#",
  },
];
---

<PageShell title="Projects" description="Selected work with measurable outcomes.">
  <div class="projects-grid">
    {
      projects.map((project) => (
        <article class="project-card">
          <h2 class="project-title">{project.title}</h2>
          <p class="project-desc">{project.description}</p>
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <a class="btn" href={project.href}>View Details</a>
        </article>
      ))
    }
  </div>
</PageShell>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    padding-top: 8px;
    padding-bottom: 72px; /* homepage-style footer breathing room */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  @media (min-width: 720px) {
    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 100%;
    padding: 18px 18px 16px;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 98%, white 2%),
        color-mix(in srgb, var(--surface) 98%, black 2%)
      );
    box-shadow:
      0 1px 0 rgba(255,255,255,0.62) inset,
      0 8px 20px rgba(0,0,0,0.018);
    transition:
      transform 0.2s var(--ease),
      box-shadow 0.2s var(--ease),
      border-color 0.2s var(--ease);
    box-sizing: border-box;
  }

  .project-card:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.72) inset,
      0 12px 24px rgba(0,0,0,0.035);
  }

  .project-title {
    margin: 0;
    color: var(--ink);
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: -0.015em;
    line-height: 1.22;
  }

  .project-desc {
    margin: 0;
    color: color-mix(in srgb, var(--ink-secondary, var(--ink-muted)) 88%, var(--ink) 12%);
    font-size: 0.9rem;
    line-height: 1.52;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-content: flex-start;
    margin-top: 2px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 5px 8px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    background: rgba(0, 0, 0, 0.025);
    color: color-mix(in srgb, var(--ink-muted) 82%, var(--ink) 18%);
    font-size: 11px;
    font-weight: 550;
    line-height: 1;
    white-space: nowrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 4px;
    min-height: 36px;
    padding: 0 12px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--border) 78%, transparent);
    background: color-mix(in srgb, var(--surface) 98%, black 2%);
    color: var(--ink);
    text-decoration: none;
    font-size: 13px;
    font-weight: 550;
    line-height: 1;
    box-shadow: 0 1px 0 rgba(255,255,255,0.55) inset;
    transition:
      background-color 0.18s var(--ease),
      border-color 0.18s var(--ease),
      transform 0.18s var(--ease);
    align-self: flex-start;
  }

  .btn:hover {
    background: color-mix(in srgb, var(--surface) 95%, black 2%);
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    transform: translateY(-1px);
  }

  .btn:active {
    transform: translateY(0);
  }

  @media (max-width: 720px) {
    .projects-grid {
      gap: 10px;
      padding-bottom: 52px;
    }

    .project-card {
      padding: 14px;
      border-radius: 14px;
      gap: 8px;
    }

    .project-title {
      font-size: 0.96rem;
    }

    .project-desc {
      font-size: 0.86rem;
      line-height: 1.48;
    }

    .btn {
      min-height: 34px;
      font-size: 12px;
      border-radius: 9px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .btn {
      transition: none !important;
    }

    .project-card:hover,
    .btn:hover {
      transform: none !important;
    }
  }
</style>
