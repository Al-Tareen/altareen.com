---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

const {
  title,
  description,
  subtitle,
  hidePageHead = false,
} = Astro.props;
---

<BaseLayout title={title} description={description}>

<!-- Thin page loader -->
<div id="pageLoaderBar" class="page-loader-bar" aria-hidden="true"></div>

  <Header />
  <main class={`wrap ${hidePageHead ? "isHeadHidden" : ""}`}>
    {!hidePageHead && (
      <header class="pagehead">
        <h1>{title}</h1>

        {subtitle && <div class="subtitle">{subtitle}</div>}

        {description && <p class="desc">{description}</p>}
      </header>
    )}

    <section class="content">
      <slot />
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .wrap {
    max-width: var(--content-width, 980px);
    margin: 0 auto;
    padding: 40px 28px 56px;
    flex: 1;
    width: 100%;
  }

  /* Detail pages (framework/concepts) already render their own internal header */
  .wrap.isHeadHidden {
    padding-top: 24px;
  }

  .pagehead {
    padding: 16px 0 28px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 28px;
  }

  .pagehead h1 {
    margin: 0 0 10px;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--ink);
  }

  .subtitle {
    display: inline-flex;
    width: fit-content;
    margin: 0 0 12px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: rgba(0, 0, 0, 0.03);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-secondary);
  }

  .desc {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-secondary);
    max-width: 70ch;
  }

  .content {
    padding: 0;
    min-width: 0;
  }

  @media (max-width: 980px) {
    .wrap {
      padding: 28px 20px 44px;
    }

    .wrap.isHeadHidden {
      padding-top: 16px;
    }

    .pagehead {
      padding: 10px 0 20px;
      margin-bottom: 20px;
    }
  }

  .page-loader-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: linear-gradient(90deg,rgb(75, 75, 75),rgb(114, 114, 114));
    z-index: 9999;
    transition: width 0.2s ease;
    pointer-events: none;
  }

  .page-loader-bar.active {
    /* width is controlled dynamically via JS */
  }
</style>

<script is:inline type="module">
  const loader = document.getElementById('pageLoaderBar');

  let progress = 0;
  let interval;

  const startLoader = () => {
    loader.classList.add('active');
    progress = 0;
    loader.style.width = '0%';

    interval = setInterval(() => {
      // Increase progress gradually (max ~90%)
      progress += Math.random() * 4;
      if (progress < 90) {
        loader.style.width = progress + '%';
      }
    }, 150);
  };

  const finishLoader = () => {
    clearInterval(interval);
    loader.style.width = '100%';
    setTimeout(() => {
      loader.classList.remove('active');
      loader.style.width = '0%';
    }, 250);
  };

  // Intercept internal links
  document.addEventListener('click', (e) => {
    const link = e.target.closest('a');
    if (!link) return;

    if (
      link.target === '_blank' ||
      link.href.startsWith('mailto:') ||
      link.href.startsWith('tel:') ||
      !link.href.startsWith(window.location.origin)
    ) return;

    e.preventDefault();
    startLoader();

    setTimeout(() => {
      window.location.href = link.href;
    }, 50);
  });

  // Complete loader on page load / back/forward cache
  window.addEventListener('pageshow', finishLoader);
  window.addEventListener('load', finishLoader);
</script>