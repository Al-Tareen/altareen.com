---
const {
  title = "Al Tareen",
  description = "AI Transformation • Product Management • Strategy",
  keywords = "",
  slug = "",
  toolkitType = "",
  datePublished,
  schema = null,
  breadcrumbs = [],
} = Astro.props;

const metaKeywords = typeof keywords === "string" ? keywords : "";

const siteUrl = Astro.site ?? "https://dev.altareen.com";
const canonical = new URL(Astro.url.pathname, siteUrl).toString();

const isToolkitDetail = ["pm", "finance", "concepts"].includes(toolkitType) && Boolean(slug);

const ogImage = isToolkitDetail
  ? new URL(`/toolkit-covers/${slug}.png`, siteUrl).toString()
  : new URL("/logo.png", siteUrl).toString();

const publishedDate = (() => {
  if (!datePublished) return undefined;
  const parsed = new Date(datePublished);
  return Number.isNaN(parsed.getTime()) ? undefined : parsed.toISOString();
})();

const authorUrl = new URL("/about/", siteUrl).toString();
const publisherLogo = new URL("/logo.png", siteUrl).toString();

const jsonLd = isToolkitDetail
  ? {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      headline: title,
      description,
      image: {
        "@type": "ImageObject",
        url: ogImage,
        width: 1200,
        height: 630,
      },
      url: canonical,
      author: {
        "@type": "Person",
        name: "Al Tareen",
        url: authorUrl,
      },
      publisher: {
        "@type": "Organization",
        name: "Al Tareen",
        logo: {
          "@type": "ImageObject",
          url: publisherLogo,
          width: 512,
          height: 512,
        },
      },
      ...(publishedDate ? { datePublished: publishedDate } : {}),
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonical,
      },
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: title,
      description,
      url: canonical,
      image: ogImage,
    };

const breadcrumbJsonLd =
  Array.isArray(breadcrumbs) && breadcrumbs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          item: new URL(item.path, siteUrl).toString(),
        })),
      }
    : null;

const schemaGraph = [
  jsonLd,
  ...(schema
    ? Array.isArray(schema)
      ? schema
      : [schema]
    : []),
  ...(breadcrumbJsonLd ? [breadcrumbJsonLd] : []),
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="keywords" content={metaKeywords} />
  <link rel="canonical" href={canonical} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={isToolkitDetail ? "article" : "website"} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Al Tareen" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  {publishedDate && isToolkitDetail && (
    <meta property="article:published_time" content={publishedDate} />
  )}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={title} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <title>{title}</title>

  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)}></script>

  <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2HCBGG64QQ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-2HCBGG64QQ');
</script>

<script>
  window.trackEvent = function(name, params = {}) {
    console.log("trackEvent fired:", name, params);
    if (typeof gtag === "function") {
      gtag('event', name, params);
    } else {
      console.warn("gtag is not available");
    }
  };
</script>

</head>
<body>
  <div id="pageLoaderBar" class="page-loader-bar" aria-hidden="true"></div>

  <div class="siteShell">
    <slot />

    <div id="cookie-overlay" class="cookieOverlay"></div>

    <div
      id="cookie-banner"
      class="cookieBanner"
      role="dialog"
      aria-modal="true"
      aria-labelledby="cookie-title"
      aria-describedby="cookie-copy"
    >
      <div class="cookieContent">
        <div class="cookieHeader">
          <div class="cookieEyebrow">Privacy</div>
          <h2 id="cookie-title" class="cookieTitle">Cookie Preferences</h2>
          <p id="cookie-copy" class="cookieBody">
            We use essential storage to keep the site functional and remember your privacy choice.
            You can also allow optional features that improve experience and help us understand site performance.
          </p>
        </div>

        <div class="cookiePrefs">
          <div class="cookiePrefItem cookiePrefLocked">
            <div class="cookiePrefMeta">
              <div class="cookiePrefTitle">Essential</div>
              <div class="cookiePrefDesc">
                Required for core functionality and storing your privacy preferences.
              </div>
            </div>
            <div class="cookiePill cookiePillLocked">Always On</div>
          </div>

          <label class="cookiePrefItem" for="cookie-optional">
            <div class="cookiePrefMeta">
              <div class="cookiePrefTitle">Optional Features</div>
              <div class="cookiePrefDesc">
                Includes preference-based features and analytics, such as remembering framework votes and understanding site usage.
              </div>
            </div>
            <span class="cookieSwitchWrap">
              <input id="cookie-optional" class="cookieSwitchInput" type="checkbox" />
              <span class="cookieSwitch" aria-hidden="true"></span>
            </span>
          </label>
        </div>

        <div class="cookieActions">
          <button id="cookie-essential-only" class="cookieBtn">Essential Only</button>
          <button id="cookie-allow-optional" class="cookieBtn primary">Allow Optional</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const banner = document.getElementById("cookie-banner");
      const overlay = document.getElementById("cookie-overlay");
      const essentialOnlyBtn = document.getElementById("cookie-essential-only");
      const allowOptionalBtn = document.getElementById("cookie-allow-optional");
      const optionalInput = document.getElementById("cookie-optional");

      const PREFERENCES_KEY = "cookie_preferences";
      const LEGACY_CONSENT_KEY = "cookie_consent";

      function getDefaultPreferences() {
        return {
          essential: true,
          optional: false,
          functional: false,
          analytics: false,
        };
      }

      function normalizePreferences(raw) {
        const optional =
          typeof raw?.optional === "boolean"
            ? raw.optional
            : Boolean(raw?.functional) || Boolean(raw?.analytics);

        return {
          essential: true,
          optional,
          functional: optional,
          analytics: optional,
        };
      }

      function readPreferences() {
        try {
          const raw = localStorage.getItem(PREFERENCES_KEY);
          if (!raw) return null;

          return normalizePreferences(JSON.parse(raw));
        } catch {
          return null;
        }
      }

      function writePreferences(prefs) {
        const normalized = normalizePreferences(prefs);

        localStorage.setItem(PREFERENCES_KEY, JSON.stringify(normalized));
        localStorage.setItem(
          LEGACY_CONSENT_KEY,
          normalized.optional ? "accepted" : "declined"
        );
      }

      function hydrateInputs(prefs) {
        if (optionalInput) optionalInput.checked = Boolean(prefs?.optional);
      }

      function showBanner() {
        if (!banner || !overlay) return;

        overlay.style.display = "block";
        banner.style.display = "block";

        requestAnimationFrame(() => {
          overlay.style.opacity = "1";
          banner.style.opacity = "1";
          banner.style.transform = "translate(-50%, -50%) scale(1)";
        });
      }

      function hideBanner() {
        if (!banner || !overlay) return;

        banner.style.opacity = "0";
        banner.style.transform = "translate(-50%, -47%) scale(0.985)";
        overlay.style.opacity = "0";

        setTimeout(() => {
          banner.style.display = "none";
          overlay.style.display = "none";
        }, 220);
      }

      function deleteCookie(name) {
        const hostname = window.location.hostname;

        document.cookie = `${name}=; Max-Age=0; path=/`;
        document.cookie = `${name}=; Max-Age=0; path=/; domain=${hostname}`;
        document.cookie = `${name}=; Max-Age=0; path=/; domain=.${hostname}`;
      }

      function clearAnalyticsCookies() {
        [
          "_ga",
          "_gid",
          "_gat",
          "_clck",
          "_clsk",
          "_fbp",
          "_gcl_au",
        ].forEach(deleteCookie);
      }

      function clearAnalyticsStorage() {
        [
          "clarity",
          "ga_client_id",
          "analytics_session",
        ].forEach((key) => {
          localStorage.removeItem(key);
          sessionStorage.removeItem(key);
        });
      }

      function loadAnalytics() {
        if (window.__analyticsLoaded) return;
        window.__analyticsLoaded = true;

        console.log("Optional features enabled.");
      }

      function applyPreferences(prefs) {
        if (prefs.optional) {
          loadAnalytics();
        } else {
          clearAnalyticsCookies();
          clearAnalyticsStorage();
        }
      }

      function saveAndApply(prefs) {
        const normalized = normalizePreferences(prefs);
        writePreferences(normalized);
        applyPreferences(normalized);
        hydrateInputs(normalized);
        hideBanner();
      }

      window.openCookiePreferences = function () {
        const prefs = readPreferences() || getDefaultPreferences();
        hydrateInputs(prefs);
        showBanner();
      };

      const existingPrefs = readPreferences();

      if (!existingPrefs) {
        const defaults = getDefaultPreferences();
        hydrateInputs(defaults);
        showBanner();
      } else {
        hydrateInputs(existingPrefs);
        applyPreferences(existingPrefs);
      }

      essentialOnlyBtn?.addEventListener("click", () => {
        saveAndApply({
          essential: true,
          optional: false,
          functional: false,
          analytics: false,
        });
      });

      allowOptionalBtn?.addEventListener("click", () => {
        saveAndApply({
          essential: true,
          optional: true,
          functional: true,
          analytics: true,
        });
      });

      overlay?.addEventListener("click", () => {
        const prefs = readPreferences();
        if (prefs) hideBanner();
      });
    });
  </script>
</body>
</html>

<style>
  :global(:root) {
    --scrollbar-bg: #fff;
    --scrollbar-thumb: #333;
    --scrollbar-thumb-hover: #555;
  }

  :global(html),
  :global(body) {
    scrollbar-width: thin;
    scrollbar-color: var(--scrollbar-thumb) var(--scrollbar-bg);
  }

  :global(html::-webkit-scrollbar),
  :global(body::-webkit-scrollbar) {
    width: 8px;
    height: 8px;
  }

  :global(html::-webkit-scrollbar-track),
  :global(body::-webkit-scrollbar-track) {
    background: var(--scrollbar-bg);
  }

  :global(html::-webkit-scrollbar-thumb),
  :global(body::-webkit-scrollbar-thumb) {
    background-color: var(--scrollbar-thumb);
    border-radius: 999px;
    border: 2px solid var(--scrollbar-bg);
  }

  :global(html::-webkit-scrollbar-thumb:hover),
  :global(body::-webkit-scrollbar-thumb:hover) {
    background-color: var(--scrollbar-thumb-hover);
  }

  :global(:root) {
    color-scheme: light;
    --font-sans: "Outfit", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    --ink: #1d1d1f;
    --ink-secondary: rgba(0, 0, 0, 0.65);
    --ink-muted: rgba(0, 0, 0, 0.5);
    --surface: #ffffff;
    --surface-subtle: #fafafa;
    --border: rgba(0, 0, 0, 0.08);
    --border-strong: rgba(0, 0, 0, 0.12);
    --radius-sm: 10px;
    --radius-md: 14px;
    --radius-lg: 18px;
    --radius-xl: 22px;
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
    --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.06);
    --shadow-lg: 0 20px 48px rgba(0, 0, 0, 0.08);
    --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --content-width: 980px;
  }

  :global(body) {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
    background: var(--surface-subtle);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  :global(a) {
    color: inherit;
  }

  :global(.siteShell) {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  :global(*),
  :global(*::before),
  :global(*::after) {
    box-sizing: border-box;
  }

  .page-loader-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: linear-gradient(90deg, rgb(75, 75, 75), rgb(114, 114, 114));
    z-index: 9999;
    transition: width 0.2s ease;
    pointer-events: none;
  }

  .page-loader-bar.active {}

  .cookieOverlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.24);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 9998;
    display: none;
    opacity: 0;
    transition: opacity 0.22s ease;
  }

  .cookieBanner {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -47%) scale(0.985);
    width: calc(100% - 32px);
    max-width: 520px;
    z-index: 9999;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 98%, white 2%),
        color-mix(in srgb, var(--surface) 98%, black 2%)
      );
    box-shadow:
      0 2px 0 rgba(255,255,255,0.6) inset,
      0 18px 40px rgba(0,0,0,0.12);
    padding: 22px 20px 18px;
    display: none;
    opacity: 0;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .cookieContent {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cookieHeader {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cookieEyebrow {
    font-size: 10px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .cookieTitle {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.08;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .cookieBody {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--ink-secondary);
  }

  .cookiePrefs {
    display: grid;
    gap: 10px;
  }

  .cookiePrefItem {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 14px;
    align-items: center;
    padding: 14px;
    border-radius: 14px;
    border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    background: rgba(255,255,255,0.72);
  }

  .cookiePrefLocked {
    opacity: 0.96;
  }

  .cookiePrefMeta {
    min-width: 0;
  }

  .cookiePrefTitle {
    font-size: 0.96rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .cookiePrefDesc {
    margin-top: 4px;
    font-size: 0.84rem;
    line-height: 1.45;
    color: var(--ink-secondary);
  }

  .cookiePill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 32px;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 78%, transparent);
    background: rgba(0,0,0,0.04);
    color: var(--ink);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .cookieSwitchWrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .cookieSwitchInput {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .cookieSwitch {
    width: 48px;
    height: 30px;
    border-radius: 999px;
    background: rgba(0,0,0,0.12);
    border: 1px solid color-mix(in srgb, var(--border) 76%, transparent);
    position: relative;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .cookieSwitch::after {
    content: "";
    position: absolute;
    top: 3px;
    left: 3px;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.14);
    transition: transform 0.2s ease;
  }

  .cookieSwitchInput:checked + .cookieSwitch {
    background: var(--ink);
    border-color: var(--ink);
  }

  .cookieSwitchInput:checked + .cookieSwitch::after {
    transform: translateX(18px);
  }

  .cookieActions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .cookieBtn {
    min-height: 42px;
    padding: 0 14px;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    background: color-mix(in srgb, var(--surface) 98%, black 2%);
    color: var(--ink);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: -0.01em;
    cursor: pointer;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      background 0.18s ease;
  }

  .cookieBtn:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--border) 92%, transparent);
    box-shadow: 0 10px 18px rgba(0,0,0,0.04);
  }

  .cookieBtn.primary {
    background: var(--ink);
    color: var(--surface);
    border-color: var(--ink);
  }

  .cookieBtn.primary:hover {
    background: color-mix(in srgb, var(--ink) 92%, black 8%);
  }

  @media (max-width: 640px) {
    .cookieBanner {
      max-width: 100%;
      padding: 18px 16px 16px;
      border-radius: 16px;
    }

    .cookieActions {
      grid-template-columns: 1fr;
    }

    .cookiePrefItem {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>